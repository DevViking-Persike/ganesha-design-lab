@namespace Ganesha.DesignLab.Shared.Components.Composites.ActionList
@using Ganesha.DesignLab.Shared.Extensions

<ul class="@_cssClass" role="list">
    @ChildContent
</ul>

@code {
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-action-list")
        .AddClass(AdditionalCssClass)
        .Build();
}
