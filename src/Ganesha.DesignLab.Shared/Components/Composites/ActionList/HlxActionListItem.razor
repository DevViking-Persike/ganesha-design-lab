@namespace Ganesha.DesignLab.Shared.Components.Composites.ActionList
@using Ganesha.DesignLab.Shared.Extensions

<li class="@_cssClass">

    @* ── Clickable main area ─────────────────────────────────────────── *@
    <div class="gns-action-list-item__body"
         role="@(OnClick.HasDelegate ? "button" : null)"
         tabindex="@(OnClick.HasDelegate ? 0 : null)"
         aria-pressed="@(IsSelected.ToString().ToLower())"
         @onclick="HandleClick"
         @onkeydown="HandleKeyDown">

        @* Icon *@
        @if (!string.IsNullOrEmpty(Icon))
        {
            <span class="gns-action-list-item__icon @Icon" aria-hidden="true"></span>
        }

        @* Text content *@
        <div class="gns-action-list-item__text">
            <span class="gns-action-list-item__title">@Title</span>

            @if (!string.IsNullOrEmpty(Description))
            {
                <span class="gns-action-list-item__description">@Description</span>
            }
        </div>

        @* Meta slot *@
        @if (Meta is not null)
        {
            <div class="gns-action-list-item__meta">
                @Meta
            </div>
        }

    </div>

    @* ── Actions (outside clickable area) ───────────────────────────── *@
    @if (Actions is not null)
    {
        <div class="gns-action-list-item__actions"
             role="toolbar"
             aria-label="Item actions"
             @onclick:stopPropagation="true">
            @Actions
        </div>
    }

</li>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public RenderFragment? Meta { get; set; }
    [Parameter] public bool IsSelected { get; set; } = false;
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-action-list-item")
        .AddClass("gns-action-list-item--selected",    IsSelected)
        .AddClass("gns-action-list-item--clickable",   OnClick.HasDelegate)
        .AddClass("gns-action-list-item--has-icon",    !string.IsNullOrEmpty(Icon))
        .AddClass("gns-action-list-item--has-actions", Actions is not null)
        .AddClass(AdditionalCssClass)
        .Build();

    private async Task HandleClick()
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            await HandleClick();
    }
}
