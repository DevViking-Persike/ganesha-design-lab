@namespace Ganesha.DesignLab.Shared.Components.Composites.AppShell
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass">

    @* ── Sidebar ────────────────────────────────────────────────────── *@
    <aside class="gns-app-shell__sidebar" aria-label="Application sidebar">
        @Sidebar
    </aside>

    @* ── Mobile overlay backdrop ─────────────────────────────────────── *@
    @if (!IsSidebarCollapsed)
    {
        <div class="gns-app-shell__overlay"
             aria-hidden="true"
             @onclick="HandleOverlayClick">
        </div>
    }

    @* ── Right column: TopBar + Main ─────────────────────────────────── *@
    <div class="gns-app-shell__body">

        <header class="gns-app-shell__topbar">
            @TopBar
        </header>

        <main class="gns-app-shell__main" id="gns-main-content" tabindex="-1">
            @ChildContent
        </main>

    </div>

</div>

@code {
    [Parameter, EditorRequired] public RenderFragment? Sidebar      { get; set; }
    [Parameter, EditorRequired] public RenderFragment? TopBar       { get; set; }
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }

    [Parameter] public bool IsSidebarCollapsed { get; set; } = false;
    [Parameter] public EventCallback<bool> IsSidebarCollapsedChanged { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-app-shell")
        .AddClass("gns-app-shell--collapsed", IsSidebarCollapsed)
        .AddClass(AdditionalCssClass)
        .Build();

    private async Task HandleOverlayClick()
    {
        if (IsSidebarCollapsedChanged.HasDelegate)
            await IsSidebarCollapsedChanged.InvokeAsync(true);
    }
}
