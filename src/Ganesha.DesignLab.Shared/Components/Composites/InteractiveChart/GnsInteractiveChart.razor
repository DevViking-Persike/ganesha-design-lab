@namespace Ganesha.DesignLab.Shared.Components.Composites.InteractiveChart
@using Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass">
    <div class="gns-interactive-chart__header">
        <h3 class="gns-interactive-chart__title">@Title</h3>
        @if (Options != null && Options.Count > 0)
        {
            <div class="gns-interactive-chart__options">
                @foreach (var opt in Options)
                {
                    <button type="button" 
                            class="gns-interactive-chart__option @(opt.Id == SelectedOptionId ? "gns-interactive-chart__option--selected" : "")"
                            @onclick="() => SelectOption(opt.Id)">
                        @opt.Label
                    </button>
                }
            </div>
        }
    </div>

    <div class="gns-interactive-chart__body">
        @if (SelectedData != null)
        {
            @if (ChartType == InteractiveChartType.Bar)
            {
                <GnsBarChart Data="@SelectedData" Height="@Height" ShowLabels="true" ShowValues="true" />
            }
            else if (ChartType == InteractiveChartType.Line)
            {
                <GnsLineChart Series="@([new ChartSeries(Title, SelectedData.Select(d => d.Value).ToList())])" 
                              Labels="@(SelectedData.Select(d => d.Label).ToList())" 
                              Height="@Height" 
                              ShowArea="true" 
                              ShowAreaGradient="true" />
            }
            else if (ChartType == InteractiveChartType.Bubble)
            {
                <div class="gns-interactive-chart__bubble-placeholder">
                    <span>(Bubble chart is best visualized directly via GnsBubbleChart)</span>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Chart";
    [Parameter] public InteractiveChartType ChartType { get; set; } = InteractiveChartType.Bar;
    [Parameter] public int Height { get; set; } = 320;
    
    [Parameter, EditorRequired] public IReadOnlyList<InteractiveChartOption> Options { get; set; } = [];
    [Parameter] public EventCallback<string> OnOptionSelected { get; set; }

    [Parameter] public string? AdditionalCssClass { get; set; }

    private string? SelectedOptionId { get; set; }

    protected override void OnInitialized()
    {
        if (Options.Count > 0)
            SelectedOptionId = Options[0].Id;
    }

    private string _cssClass => CssClassBuilder
        .Create("gns-interactive-chart")
        .AddClass(AdditionalCssClass)
        .Build();

    private IReadOnlyList<ChartDataPoint>? SelectedData => 
        Options.FirstOrDefault(o => o.Id == SelectedOptionId)?.Data;

    private async Task SelectOption(string id)
    {
        SelectedOptionId = id;
        if (OnOptionSelected.HasDelegate)
        {
            await OnOptionSelected.InvokeAsync(id);
        }
    }
}
