@namespace Ganesha.DesignLab.Shared.Components.Composites.MetricCard
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" style="@_inlineStyle">
    @ChildContent
</div>

@code {
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }

    /// <summary>Number of columns on large viewports (default 4).</summary>
    [Parameter] public int Columns { get; set; } = 4;

    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-metric-grid")
        .AddClass($"gns-metric-grid--cols-{Columns}", Columns is >= 1 and <= 6)
        .AddClass(AdditionalCssClass)
        .Build();

    // Fall back to inline custom property when Columns is outside the predefined set
    private string? _inlineStyle => Columns is >= 1 and <= 6
        ? null
        : $"--_metric-cols:{Columns}";
}
