@namespace Ganesha.DesignLab.Shared.Components.Composites.PageHeader
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass">

    @* ── Breadcrumb ──────────────────────────────────────────────────── *@
    @if (Breadcrumb is not null)
    {
        <div class="gns-page-header__breadcrumb">
            @Breadcrumb
        </div>
    }

    @* ── Title row ───────────────────────────────────────────────────── *@
    <div class="gns-page-header__row">

        <div class="gns-page-header__text">

            @if (!string.IsNullOrEmpty(Eyebrow))
            {
                <span class="gns-page-header__eyebrow">@Eyebrow</span>
            }

            <h1 class="gns-page-header__title">@Title</h1>

            @if (!string.IsNullOrEmpty(Description))
            {
                <p class="gns-page-header__description">@Description</p>
            }

        </div>

        @if (Actions is not null)
        {
            <div class="gns-page-header__actions" role="toolbar" aria-label="Page actions">
                @Actions
            </div>
        }

    </div>

</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public RenderFragment? Breadcrumb { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-page-header")
        .AddClass("gns-page-header--has-breadcrumb", Breadcrumb is not null)
        .AddClass("gns-page-header--has-eyebrow",    !string.IsNullOrEmpty(Eyebrow))
        .AddClass("gns-page-header--has-description", !string.IsNullOrEmpty(Description))
        .AddClass(AdditionalCssClass)
        .Build();
}
