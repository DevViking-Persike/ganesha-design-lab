@namespace Ganesha.DesignLab.Shared.Components.Composites.ProjectTimeline
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

@if (_groups.Count == 0)
{
    <GnsEmptyState Title="No timeline items"
                   Description="Add tasks with dates and categories to visualize the roadmap." />
}
else
{
    <div class="@_cssClass">
        <header class="gns-project-timeline__header">
            <div>
                <h3 class="gns-project-timeline__title" style="color: var(--gns-color-text-primary) !important;">@Title</h3>
                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <p class="gns-project-timeline__subtitle">@Subtitle</p>
                }
            </div>

            <div class="gns-project-timeline__summary-pills" aria-label="Timeline summary">
                <span class="gns-project-timeline__pill">
                    <strong class="gns-project-timeline__pill-value">@Tasks.Count</strong>
                    <span class="gns-project-timeline__pill-label">tasks</span>
                </span>
                <span class="gns-project-timeline__pill">
                    <strong class="gns-project-timeline__pill-value">@CompletedTasks</strong>
                    <span class="gns-project-timeline__pill-label">completed</span>
                </span>
                <span class="gns-project-timeline__pill">
                    <strong class="gns-project-timeline__pill-value">@_groups.Count</strong>
                    <span class="gns-project-timeline__pill-label">workstreams</span>
                </span>
            </div>
        </header>

        <div class="gns-project-timeline__shell">
            <aside class="gns-project-timeline__sidebar">
                <div class="gns-project-timeline__sidebar-header">@SidebarTitle</div>
                <div class="gns-project-timeline__sidebar-body">
                    @foreach (var group in _groups)
                    {
                        var isExpanded = IsExpanded(group.Name);

                        <div class="gns-project-timeline__sidebar-group">
                            <button type="button"
                                    class="gns-project-timeline__category-button"
                                    aria-expanded="@isExpanded"
                                    @onclick="() => ToggleCategory(group.Name)">
                                <span class="gns-project-timeline__toggle" aria-hidden="true">@(isExpanded ? "-" : "+")</span>
                                <span class="gns-project-timeline__category-dot"
                                      style="@($"background:{group.AccentColor};")"></span>
                                <span class="gns-project-timeline__category-name">@group.Name</span>
                                <span class="gns-project-timeline__category-count">@group.Tasks.Count items</span>
                            </button>

                            @if (isExpanded)
                            {
                                @foreach (var task in group.Tasks)
                                {
                                    <div class="gns-project-timeline__task-label-row">
                                        <span class="gns-project-timeline__task-label">@task.Name</span>
                                        <span class="gns-project-timeline__task-progress">@ClampProgress(task.Progress)%</span>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            </aside>

            <div class="gns-project-timeline__board">
                <div class="gns-project-timeline__timeline-header" style="@($"width:{TimelineWidth}px")">
                    <div class="gns-project-timeline__months">
                        @foreach (var month in _months)
                        {
                            <div class="gns-project-timeline__month"
                                 style="@($"width:{month.DayCount * DayWidth}px")">
                                @month.Label
                            </div>
                        }
                    </div>

                    <div class="gns-project-timeline__days">
                        @foreach (var day in _days)
                        {
                            var isWeekend = day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                            var isToday = day == EffectiveToday;
                            var dayClass = CssClassBuilder
                                .Create("gns-project-timeline__day")
                                .AddClass("gns-project-timeline__day--weekend", isWeekend)
                                .AddClass("gns-project-timeline__day--today", isToday)
                                .Build();

                            <div class="@dayClass" style="@($"width:{DayWidth}px")">
                                <span class="gns-project-timeline__day-week">@GetWeekdayLabel(day)</span>
                                <span class="gns-project-timeline__day-number">@day.Day</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="gns-project-timeline__canvas" style="@($"width:{TimelineWidth}px")">
                    <div class="gns-project-timeline__grid" aria-hidden="true">
                        @foreach (var day in _days)
                        {
                            <div class="gns-project-timeline__grid-line" style="@($"width:{DayWidth}px")"></div>
                        }
                    </div>

                    @foreach (var group in _groups)
                    {
                        <div class="gns-project-timeline__scope-row"></div>

                        @if (IsExpanded(group.Name))
                        {
                            @foreach (var task in group.Tasks)
                            {
                                <div class="gns-project-timeline__bar-row">
                                    <div class="gns-project-timeline__bar"
                                         title="@BuildTaskTitle(task)"
                                         style="@BuildBarStyle(task, group.AccentColor)">
                                        <div class="gns-project-timeline__bar-progress"
                                             style="@($"width:{ClampProgress(task.Progress)}%")"></div>
                                        <span class="gns-project-timeline__bar-label">@task.Name</span>
                                    </div>
                                </div>
                            }
                        }
                    }

                    @if (ShowTodayMarker && EffectiveToday >= _rangeStart && EffectiveToday <= _rangeEnd)
                    {
                        <div class="gns-project-timeline__today-marker"
                             style="@($"left:{GetPosition(EffectiveToday)}px")"
                             aria-label="Today marker">
                            <div class="gns-project-timeline__today-dot"></div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <footer class="gns-project-timeline__footer">
            <div class="gns-project-timeline__footer-metrics">
                <span class="gns-project-timeline__footer-pill">
                    <strong class="gns-project-timeline__pill-value">@Tasks.Count</strong>
                    <span class="gns-project-timeline__pill-label">Total tasks</span>
                </span>
                <span class="gns-project-timeline__footer-pill">
                    <strong class="gns-project-timeline__pill-value">@CompletedTasks</strong>
                    <span class="gns-project-timeline__pill-label">Completed</span>
                </span>
            </div>

            <div class="gns-project-timeline__legend">
                @foreach (var group in _groups)
                {
                    <span class="gns-project-timeline__legend-item">
                        <span class="gns-project-timeline__legend-dot"
                              style="@($"background:{group.AccentColor};")"></span>
                        <span>@group.Name</span>
                    </span>
                }
            </div>
        </footer>
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = "Project timeline";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string SidebarTitle { get; set; } = "Workstreams / Tasks";
    [Parameter, EditorRequired] public IReadOnlyList<ProjectTimelineTask> Tasks { get; set; } = [];
    [Parameter] public IReadOnlyList<ProjectTimelineCategory>? Categories { get; set; }
    [Parameter] public int DayWidth { get; set; } = 40;
    [Parameter] public int StartPaddingDays { get; set; } = 3;
    [Parameter] public int EndPaddingDays { get; set; } = 10;
    [Parameter] public bool ShowTodayMarker { get; set; } = true;
    [Parameter] public DateOnly? Today { get; set; }
    [Parameter] public string CultureName { get; set; } = "en-US";
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static readonly string[] AccentPalette =
    [
        "var(--gns-primary-500,#3F51B5)",
        "var(--gns-violet-500,#9C27B0)",
        "var(--gns-warning-500,#FFC107)",
        "var(--gns-success-500,#4CAF50)",
        "var(--gns-danger-500,#F44336)",
        "var(--gns-info-500,#00BCD4)"
    ];

    private readonly HashSet<string> _expandedCategories = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<ProjectTimelineGroup> _groups = [];
    private readonly List<DateOnly> _days = [];
    private readonly List<ProjectTimelineMonth> _months = [];
    private DateOnly _rangeStart;
    private DateOnly _rangeEnd;
    private bool _expansionInitialized;

    private string _cssClass => CssClassBuilder
        .Create("gns-project-timeline")
        .AddClass(AdditionalCssClass)
        .Build();

    private int TimelineWidth => _days.Count * DayWidth;
    private int CompletedTasks => Tasks.Count(task => ClampProgress(task.Progress) >= 100);
    private DateOnly EffectiveToday => Today ?? DateOnly.FromDateTime(DateTime.Today);

    protected override void OnParametersSet()
    {
        BuildGroups();
        BuildTimelineRange();
    }

    private void BuildGroups()
    {
        _groups.Clear();
        var previouslyKnownCategories = _expandedCategories.ToHashSet(StringComparer.OrdinalIgnoreCase);

        var categoryDefinitions = Categories?
            .ToDictionary(category => category.Name, StringComparer.OrdinalIgnoreCase)
            ?? new Dictionary<string, ProjectTimelineCategory>(StringComparer.OrdinalIgnoreCase);

        var orderedCategories = new List<string>();
        foreach (var task in Tasks)
        {
            if (!orderedCategories.Contains(task.Category, StringComparer.OrdinalIgnoreCase))
            {
                orderedCategories.Add(task.Category);
            }
        }

        for (var index = 0; index < orderedCategories.Count; index++)
        {
            var categoryName = orderedCategories[index];
            var tasks = Tasks
                .Where(task => string.Equals(task.Category, categoryName, StringComparison.OrdinalIgnoreCase))
                .OrderBy(task => task.StartDate)
                .ThenBy(task => task.EndDate)
                .ToList();

            categoryDefinitions.TryGetValue(categoryName, out var categoryDefinition);
            var accentColor = categoryDefinition?.AccentColor
                ?? tasks.FirstOrDefault(task => !string.IsNullOrWhiteSpace(task.AccentColor))?.AccentColor
                ?? AccentPalette[index % AccentPalette.Length];

            _groups.Add(new ProjectTimelineGroup(categoryName, accentColor, tasks));
        }

        var activeCategoryNames = _groups.Select(group => group.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
        _expandedCategories.RemoveWhere(category => !activeCategoryNames.Contains(category));

        if (!_expansionInitialized)
        {
            foreach (var group in _groups)
            {
                _expandedCategories.Add(group.Name);
            }

            _expansionInitialized = true;
        }
        else
        {
            foreach (var group in _groups)
            {
                if (!previouslyKnownCategories.Contains(group.Name))
                {
                    _expandedCategories.Add(group.Name);
                }
            }
        }
    }

    private void BuildTimelineRange()
    {
        _days.Clear();
        _months.Clear();

        if (Tasks.Count == 0)
        {
            _rangeStart = EffectiveToday.AddDays(-StartPaddingDays);
            _rangeEnd = EffectiveToday.AddDays(EndPaddingDays);
        }
        else
        {
            var minTaskDate = Tasks.Min(task => task.StartDate);
            var maxTaskDate = Tasks.Max(task => task.EndDate);

            _rangeStart = minTaskDate.AddDays(-StartPaddingDays);
            _rangeEnd = maxTaskDate.AddDays(EndPaddingDays);
        }

        var current = _rangeStart;
        ProjectTimelineMonth? activeMonth = null;

        while (current <= _rangeEnd)
        {
            _days.Add(current);

            var monthLabel = current.ToDateTime(TimeOnly.MinValue)
                .ToString("MMMM yyyy", ResolveCulture());
            monthLabel = ResolveCulture().TextInfo.ToTitleCase(monthLabel);

            if (activeMonth is null || !string.Equals(activeMonth.Label, monthLabel, StringComparison.Ordinal))
            {
                if (activeMonth is not null)
                {
                    _months.Add(activeMonth);
                }

                activeMonth = new ProjectTimelineMonth(monthLabel, 1);
            }
            else
            {
                activeMonth = activeMonth with { DayCount = activeMonth.DayCount + 1 };
            }

            current = current.AddDays(1);
        }

        if (activeMonth is not null)
        {
            _months.Add(activeMonth);
        }
    }

    private CultureInfo ResolveCulture()
    {
        try
        {
            return CultureInfo.GetCultureInfo(CultureName);
        }
        catch (CultureNotFoundException)
        {
            return CultureInfo.InvariantCulture;
        }
    }

    private bool IsExpanded(string categoryName) => _expandedCategories.Contains(categoryName);

    private void ToggleCategory(string categoryName)
    {
        if (!_expandedCategories.Add(categoryName))
        {
            _expandedCategories.Remove(categoryName);
        }
    }

    private int GetPosition(DateOnly date) => (_days.Count == 0 ? 0 : (date.DayNumber - _rangeStart.DayNumber) * DayWidth);

    private int GetWidth(ProjectTimelineTask task)
    {
        var spanDays = Math.Max(1, task.EndDate.DayNumber - task.StartDate.DayNumber + 1);
        return spanDays * DayWidth;
    }

    private string BuildBarStyle(ProjectTimelineTask task, string accentColor)
        => $"left:{GetPosition(task.StartDate)}px;width:{GetWidth(task)}px;--gns-project-timeline-accent:{accentColor};";

    private static int ClampProgress(int progress) => Math.Clamp(progress, 0, 100);

    private string GetWeekdayLabel(DateOnly date)
    {
        var abbreviated = ResolveCulture().DateTimeFormat.GetAbbreviatedDayName(date.DayOfWeek);
        return abbreviated.Length > 0 ? abbreviated[..1].ToUpperInvariant() : "?";
    }

    private static string BuildTaskTitle(ProjectTimelineTask task)
        => $"{task.Name} ({task.StartDate:yyyy-MM-dd} -> {task.EndDate:yyyy-MM-dd})";

    private sealed record ProjectTimelineGroup(string Name, string AccentColor, IReadOnlyList<ProjectTimelineTask> Tasks);
    private sealed record ProjectTimelineMonth(string Label, int DayCount);
}
