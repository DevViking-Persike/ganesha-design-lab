@namespace Ganesha.DesignLab.Shared.Components.Composites.SearchFilter
@using Ganesha.DesignLab.Shared.Extensions
@using Ganesha.DesignLab.Shared.Components.DesignSystem.Form

<div class="@_cssClass" role="search">

    @* ── Search input ────────────────────────────────────────────────── *@
    <div class="gns-search-filter__search">
        @* SVG icon overlaid via absolute positioning in CSS *@
        <span class="gns-search-filter__search-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7 12A5 5 0 1 0 7 2a5 5 0 0 0 0 10zm4.243-.757 2.5 2.5"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round" />
            </svg>
        </span>
        <GnsInputText
            Value="@SearchValue"
            ValueChanged="@HandleSearchChanged"
            Placeholder="@(SearchPlaceholder ?? "Search...")"
            AdditionalCssClass="gns-search-filter__input" />
    </div>

    @* ── Filter slots ────────────────────────────────────────────────── *@
    @if (Filters is not null)
    {
        <div class="gns-search-filter__filters">
            @Filters
        </div>
    }

    @* ── Right-side actions ──────────────────────────────────────────── *@
    @if (Actions is not null)
    {
        <div class="gns-search-filter__actions" role="toolbar" aria-label="Toolbar actions">
            @Actions
        </div>
    }

</div>

@code {
    [Parameter] public string? SearchValue { get; set; }
    [Parameter] public EventCallback<string> SearchValueChanged { get; set; }
    [Parameter] public string? SearchPlaceholder { get; set; } = "Search...";
    [Parameter] public RenderFragment? Filters { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-search-filter")
        .AddClass("gns-search-filter--has-filters", Filters is not null)
        .AddClass("gns-search-filter--has-actions", Actions is not null)
        .AddClass(AdditionalCssClass)
        .Build();

    private async Task HandleSearchChanged(string value)
    {
        if (SearchValueChanged.HasDelegate)
            await SearchValueChanged.InvokeAsync(value);
    }
}
