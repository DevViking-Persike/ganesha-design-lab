@namespace Ganesha.DesignLab.Shared.Components.Composites.Sidebar
@using Ganesha.DesignLab.Shared.Extensions

<nav class="@_cssClass" aria-label="@(IsCollapsed ? "Navigation (collapsed)" : "Navigation")">

    @* ── Header / Brand ──────────────────────────────────────────────── *@
    <div class="gns-sidebar__header">
        @if (Header is not null)
        {
            @Header
        }
        else
        {
            <div class="gns-sidebar__brand">
                @if (!string.IsNullOrEmpty(BrandLogoUrl))
                {
                    <img class="gns-sidebar__brand-logo"
                         src="@BrandLogoUrl"
                         alt="@(BrandName ?? "Logo")"
                         aria-hidden="@(string.IsNullOrEmpty(BrandName) ? null : "true")" />
                }
                else
                {
                    <span class="gns-sidebar__brand-icon" aria-hidden="true">
                        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="28" height="28" rx="6" fill="var(--gns-color-interactive-primary-bg)" />
                            <path d="M7 14L13 20L21 8" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </span>
                }
                @if (!string.IsNullOrEmpty(BrandName))
                {
                    <span class="gns-sidebar__brand-name">@BrandName</span>
                }
            </div>
        }
    </div>

    @* ── Navigation Content ──────────────────────────────────────────── *@
    <div class="gns-sidebar__nav" role="list">
        @ChildContent
    </div>

    @* ── Footer ──────────────────────────────────────────────────────── *@
    @if (Footer is not null)
    {
        <div class="gns-sidebar__footer">
            @Footer
        </div>
    }

</nav>

@code {
    [Parameter] public string? BrandName { get; set; }
    [Parameter] public string? BrandLogoUrl { get; set; }
    [Parameter] public RenderFragment? Header { get; set; }
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public bool IsCollapsed { get; set; } = false;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-sidebar")
        .AddClass("gns-sidebar--collapsed", IsCollapsed)
        .AddClass(AdditionalCssClass)
        .Build();
}
