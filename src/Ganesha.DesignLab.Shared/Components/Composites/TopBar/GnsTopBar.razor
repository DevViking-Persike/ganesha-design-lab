@namespace Ganesha.DesignLab.Shared.Components.Composites.TopBar
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="banner">

    @* ── Left section ────────────────────────────────────────────────── *@
    <div class="gns-top-bar__left">

        @* Hamburger toggle *@
        <button
            type="button"
            class="gns-top-bar__menu-btn"
            aria-label="Toggle navigation menu"
            @onclick="HandleMenuToggle">
            <span class="gns-top-bar__menu-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2.5 5h15M2.5 10h15M2.5 15h15"
                          stroke="currentColor"
                          stroke-width="1.75"
                          stroke-linecap="round" />
                </svg>
            </span>
        </button>

        @* Custom left content (e.g., breadcrumb from parent) *@
        @if (LeftContent is not null)
        {
            <div class="gns-top-bar__left-content">
                @LeftContent
            </div>
        }
        else if (!string.IsNullOrEmpty(Title))
        {
            <span class="gns-top-bar__title">@Title</span>
        }

    </div>

    @* ── Right section ───────────────────────────────────────────────── *@
    @if (RightContent is not null)
    {
        <div class="gns-top-bar__right">
            @RightContent
        </div>
    }

</div>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? LeftContent { get; set; }
    [Parameter] public RenderFragment? RightContent { get; set; }
    [Parameter] public EventCallback OnMenuToggle { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-top-bar")
        .AddClass(AdditionalCssClass)
        .Build();

    private async Task HandleMenuToggle()
    {
        if (OnMenuToggle.HasDelegate)
            await OnMenuToggle.InvokeAsync();
    }
}
