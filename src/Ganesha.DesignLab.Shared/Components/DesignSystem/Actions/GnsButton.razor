@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Actions
@using Ganesha.DesignLab.Shared.Extensions

<button
    type="@Type"
    class="@_cssClass"
    disabled="@(IsDisabled || IsLoading)"
    aria-disabled="@((IsDisabled || IsLoading).ToString().ToLower())"
    aria-busy="@IsLoading.ToString().ToLower()"
    @onclick="HandleClick">

    @if (IsLoading)
    {
        @if (!string.IsNullOrEmpty(LoadingAssetPath))
        {
            <span class="gns-button__svg-loader" aria-hidden="true" style="aspect-ratio: @LoadingAspectRatio;">
                <span class="gns-button__svg-loader-bg" style="@_svgMaskStyle"></span>
                <span class="gns-button__svg-loader-fill" style="@_svgMaskStyle"></span>
            </span>
        }
        else
        {
            <span class="gns-button__spinner" aria-hidden="true"></span>
        }
        <span class="gns-button__loading-label">@(ChildContent is not null ? ChildContent : (RenderFragment)(__builder => { __builder.AddContent(0, Label); }))</span>
    }
    else
    {
        @if (!string.IsNullOrEmpty(IconLeft))
        {
            <span class="gns-button__icon gns-button__icon--left @IconLeft" aria-hidden="true"></span>
        }

        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else if (!string.IsNullOrEmpty(Label))
        {
            <span class="gns-button__label">@Label</span>
        }

        @if (!string.IsNullOrEmpty(IconRight))
        {
            <span class="gns-button__icon gns-button__icon--right @IconRight" aria-hidden="true"></span>
        }
    }
</button>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public ButtonVariant Variant { get; set; } = ButtonVariant.Primary;
    [Parameter] public ButtonSize Size { get; set; } = ButtonSize.Medium;
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public bool IsDisabled { get; set; } = false;
    [Parameter] public string? IconLeft { get; set; }
    [Parameter] public string? IconRight { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public string? LoadingAssetPath { get; set; }
    [Parameter] public string LoadingAspectRatio { get; set; } = "1 / 1";
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _svgMaskStyle =>
        $"-webkit-mask-image:url('{LoadingAssetPath}');mask-image:url('{LoadingAssetPath}');-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;-webkit-mask-position:center;mask-position:center;-webkit-mask-size:contain;mask-size:contain;";

    private string _cssClass => CssClassBuilder
        .Create("gns-button")
        .AddClass("gns-button--primary",   Variant == ButtonVariant.Primary)
        .AddClass("gns-button--secondary", Variant == ButtonVariant.Secondary)
        .AddClass("gns-button--ghost",     Variant == ButtonVariant.Ghost)
        .AddClass("gns-button--danger",    Variant == ButtonVariant.Danger)
        .AddClass("gns-button--outline",   Variant == ButtonVariant.Outline)
        .AddClass("gns-button--sm",        Size == ButtonSize.Small)
        .AddClass("gns-button--md",        Size == ButtonSize.Medium)
        .AddClass("gns-button--lg",        Size == ButtonSize.Large)
        .AddClass("gns-button--loading",   IsLoading)
        .AddClass("gns-button--disabled",  IsDisabled)
        .AddClass("gns-button--icon-only",  string.IsNullOrEmpty(Label) && ChildContent is null && (!string.IsNullOrEmpty(IconLeft) || !string.IsNullOrEmpty(IconRight)))
        .AddClass(AdditionalCssClass)
        .Build();

    private async Task HandleClick()
    {
        if (!IsDisabled && !IsLoading && OnClick.HasDelegate)
            await OnClick.InvokeAsync();
    }
}
