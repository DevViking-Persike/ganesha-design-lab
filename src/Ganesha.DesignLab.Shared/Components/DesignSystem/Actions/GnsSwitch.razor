@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Actions
@using Ganesha.DesignLab.Shared.Extensions

<label class="@_cssClass">
    <span class="gns-switch__track"
          role="switch"
          tabindex="@(IsDisabled ? -1 : 0)"
          aria-checked="@Value.ToString().ToLower()"
          aria-disabled="@IsDisabled.ToString().ToLower()"
          aria-label="@Label"
          @onclick="HandleToggle"
          @onkeydown="HandleKeyDown">
        <span class="gns-switch__thumb"></span>
    </span>

    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="gns-switch__label">@Label</span>
    }

    <input type="checkbox"
           class="gns-switch__input"
           checked="@Value"
           disabled="@IsDisabled"
           aria-hidden="true"
           tabindex="-1"
           @onchange="HandleChange" />
</label>

@code {
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public bool IsDisabled { get; set; } = false;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-switch")
        .AddClass("gns-switch--checked",  Value)
        .AddClass("gns-switch--disabled", IsDisabled)
        .AddClass(AdditionalCssClass)
        .Build();

    private async Task HandleToggle()
    {
        if (IsDisabled) return;
        await ValueChanged.InvokeAsync(!Value);
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (IsDisabled) return;
        if (e.Value is bool boolValue)
            await ValueChanged.InvokeAsync(boolValue);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (IsDisabled) return;
        if (e.Key is " " or "Enter")
            await ValueChanged.InvokeAsync(!Value);
    }
}
