@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="img" aria-label="Bar chart">
    @if (Data is { Count: > 0 })
    {
        var chartLayout = ComputeBarLayout();

        <svg class="gns-bar-chart__svg"
             viewBox="0 0 @chartLayout.ChartWidth @chartLayout.ChartHeight"
             xmlns="http://www.w3.org/2000/svg"
             width="@chartLayout.ChartWidth"
             height="@chartLayout.ChartHeight">

            @* Y-axis grid lines + labels *@
            @for (int g = 0; g <= chartLayout.GridLineCount; g++)
            {
                var fraction  = (double)g / chartLayout.GridLineCount;
                var gridValue = chartLayout.EffectiveMax * (1 - fraction);
                var yPos      = chartLayout.PaddingTop + fraction * chartLayout.PlotHeight;
                var gridLabel = FormatGridValue(gridValue);

                <line class="gns-bar-chart__grid-line"
                      x1="@chartLayout.PaddingLeft" y1="@Inv(yPos, "F1")"
                      x2="@(chartLayout.PaddingLeft + chartLayout.PlotWidth)" y2="@Inv(yPos, "F1")" />

                @SvgText((chartLayout.PaddingLeft - 8).ToString(CultureInfo.InvariantCulture), Inv(yPos, "F1"),
                    @"class=""gns-bar-chart__y-label"" text-anchor=""end"" dominant-baseline=""middle""",
                    gridLabel)
            }

            @* Bars *@
            @for (int i = 0; i < chartLayout.BarCount; i++)
            {
                var point      = Data[i];
                var barColor   = point.Color ?? GetPaletteColor(i);
                var ratio      = chartLayout.EffectiveMax > 0 ? Math.Clamp(point.Value / chartLayout.EffectiveMax, 0, 1) : 0;
                var barH       = ratio * chartLayout.PlotHeight;
                var xCenter    = chartLayout.PaddingLeft + (i + 0.5) * chartLayout.GroupWidth;
                var xBar       = xCenter - chartLayout.BarWidth / 2;
                var yBar       = chartLayout.PaddingTop + chartLayout.PlotHeight - barH;
                var animDelay  = IsAnimated ? $"{i * 60}ms" : "0ms";
                var animClass  = IsAnimated ? "gns-bar-chart__bar--animated" : "";

                <g class="gns-bar-chart__bar-group">
                    @* Invisible hover target for full column height *@
                    <rect class="gns-bar-chart__hover-target"
                          x="@Inv(xBar, "F1")"
                          y="@chartLayout.PaddingTop.ToString("F1", CultureInfo.InvariantCulture)"
                          width="@Inv(chartLayout.BarWidth, "F1")"
                          height="@chartLayout.PlotHeight.ToString("F1", CultureInfo.InvariantCulture)"
                          fill="transparent" />

                    @* Actual bar *@
                    <rect class="gns-bar-chart__bar @animClass"
                          x="@Inv(xBar, "F1")"
                          y="@Inv(yBar, "F1")"
                          width="@Inv(chartLayout.BarWidth, "F1")"
                          height="@Inv(barH, "F1")"
                          rx="3"
                          ry="3"
                          fill="@barColor"
                          style="transform-origin: @(Inv(xCenter, "F1"))px @(Inv(chartLayout.PaddingTop + chartLayout.PlotHeight, "F1"))px; --gns-bar-delay: @animDelay;">
                        <title>@point.Label: @point.Value.ToString("G4", CultureInfo.InvariantCulture)</title>
                    </rect>

                    @* Value label above bar *@
                    @if (ShowValues)
                    {
                        @SvgText(Inv(xCenter, "F1"), Inv(yBar - 8, "F1"),
                            @"class=""gns-bar-chart__value-label"" text-anchor=""middle""",
                            point.Value.ToString("G4", CultureInfo.InvariantCulture))
                    }

                    @* X-axis label below bar *@
                    @if (ShowLabels)
                    {
                        @SvgText(Inv(xCenter, "F1"), Inv(chartLayout.PaddingTop + chartLayout.PlotHeight + 22, "F1"),
                            @"class=""gns-bar-chart__x-label"" text-anchor=""middle""",
                            TruncateLabel(point.Label, 10))
                    }
                </g>
            }
        </svg>
    }
    else
    {
        <p class="gns-bar-chart__empty">No data</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ChartDataPoint> Data { get; set; } = [];
    [Parameter] public double? MaxValue { get; set; }
    [Parameter] public int Height { get; set; } = 320;
    [Parameter] public bool ShowLabels { get; set; } = true;
    [Parameter] public bool ShowValues { get; set; } = true;
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static readonly string[] Palette =
    [
        "var(--gns-primary-500,#3F51B5)",
        "var(--gns-success-500,#4CAF50)",
        "var(--gns-warning-500,#FFC107)",
        "var(--gns-danger-500,#F44336)",
        "var(--gns-info-500,#00BCD4)",
        "var(--gns-violet-500,#9C27B0)",
        "var(--gns-rosa-300,#F06292)",
        "var(--gns-ouro-500,#D4AF37)"
    ];

    private string _cssClass => CssClassBuilder
        .Create("gns-bar-chart")
        .AddClass("gns-bar-chart--animated", IsAnimated)
        .AddClass(AdditionalCssClass)
        .Build();

    private static string GetPaletteColor(int index) => Palette[index % Palette.Length];

    private static string Inv(double value, string format) => value.ToString(format, CultureInfo.InvariantCulture);

    private static string FormatGridValue(double value)
    {
        if (value >= 1_000_000) return $"{(value / 1_000_000).ToString("G3", CultureInfo.InvariantCulture)}M";
        if (value >= 1_000) return $"{(value / 1_000).ToString("G3", CultureInfo.InvariantCulture)}K";
        return value.ToString("G4", CultureInfo.InvariantCulture);
    }

    private static string TruncateLabel(string label, int maxLength)
        => label.Length > maxLength ? label[..maxLength] + "\u2026" : label;

    private static MarkupString SvgText(string x, string y, string attrs, string content)
        => new($"<text x=\"{x}\" y=\"{y}\" {attrs}>{System.Net.WebUtility.HtmlEncode(content)}</text>");

    private BarLayout ComputeBarLayout()
    {
        var effectiveMax  = MaxValue ?? Data.Max(d => d.Value);
        var paddingLeft   = 80;
        var paddingRight  = 24;
        var paddingTop    = 32;
        var paddingBottom = ShowLabels ? 40 : 20;
        var chartWidth    = 640;
        var chartHeight   = Height;
        var plotWidth     = chartWidth - paddingLeft - paddingRight;
        var plotHeight    = chartHeight - paddingTop - paddingBottom;
        var barCount      = Data.Count;
        var groupWidth    = plotWidth / (double)barCount;
        var barWidth      = Math.Max(4, groupWidth * 0.6);

        return new BarLayout(effectiveMax, paddingLeft, paddingTop, chartWidth, chartHeight,
            plotWidth, plotHeight, barCount, groupWidth, barWidth, 5);
    }

    private record BarLayout(
        double EffectiveMax, int PaddingLeft, int PaddingTop,
        int ChartWidth, int ChartHeight,
        int PlotWidth, int PlotHeight, int BarCount,
        double GroupWidth, double BarWidth, int GridLineCount);
}
