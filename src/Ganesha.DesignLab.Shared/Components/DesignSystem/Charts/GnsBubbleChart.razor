@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="img" aria-label="Bubble chart" style="@_inlineStyle">
    @if (Data is { Count: > 0 })
    {
        var chartLayout = ComputeLayout();

        <svg class="gns-bubble-chart__svg"
             viewBox="0 0 @chartLayout.ViewW @chartLayout.ViewH"
             xmlns="http://www.w3.org/2000/svg"
             width="@chartLayout.ViewW"
             height="@chartLayout.ViewH">

            <defs>
                @* ── Radial gradient per bubble (infographic-style depth) ── *@
                @for (int i = 0; i < Data.Count; i++)
                {
                    var gradId    = GetBubbleGradientId(i);
                    var baseColor = Data[i].Color ?? GetPaletteColor(i);

                    <radialGradient id="@gradId" cx="35%" cy="35%" r="65%">
                        <stop offset="0%" stop-color="white" stop-opacity="0.45" />
                        <stop offset="40%" stop-color="@baseColor" stop-opacity="0.85" />
                        <stop offset="100%" stop-color="@baseColor" stop-opacity="1" />
                    </radialGradient>
                }

                @* ── Drop-shadow filter for 3D depth ── *@
                <filter id="@BubbleShadowFilterId" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="2" stdDeviation="3" flood-opacity="0.18" />
                </filter>

                @* ── Glow filter for hover state ── *@
                <filter id="@BubbleGlowFilterId" x="-40%" y="-40%" width="180%" height="180%">
                    <feGaussianBlur stdDeviation="4" result="blur" />
                    <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
            </defs>

            @* ── Horizontal grid lines + Y labels ── *@
            @if (ShowGrid)
            {
                @for (int g = 0; g <= chartLayout.GridLines; g++)
                {
                    var frac   = (double)g / chartLayout.GridLines;
                    var yValue = chartLayout.YMax - frac * chartLayout.YRange;
                    var yPos   = chartLayout.PaddingTop + frac * chartLayout.PlotH;

                    <line class="gns-bubble-chart__grid-h"
                          x1="@chartLayout.PaddingLeft" y1="@Inv(yPos)"
                          x2="@(chartLayout.PaddingLeft + chartLayout.PlotW)" y2="@Inv(yPos)" />

                    @SvgText((chartLayout.PaddingLeft - 8).ToString(CultureInfo.InvariantCulture), Inv(yPos),
                        @"class=""gns-bubble-chart__y-label"" text-anchor=""end"" dominant-baseline=""middle""",
                        FormatGridValue(yValue))
                }
            }

            @* ── Vertical grid lines + X labels ── *@
            @if (ShowGrid)
            {
                @for (int g = 0; g <= chartLayout.GridLines; g++)
                {
                    var frac   = (double)g / chartLayout.GridLines;
                    var xValue = chartLayout.XMin + frac * chartLayout.XRange;
                    var xPos   = chartLayout.PaddingLeft + frac * chartLayout.PlotW;

                    <line class="gns-bubble-chart__grid-v"
                          x1="@Inv(xPos)" y1="@chartLayout.PaddingTop"
                          x2="@Inv(xPos)" y2="@(chartLayout.PaddingTop + chartLayout.PlotH)" />

                    @SvgText(Inv(xPos), Inv(chartLayout.PaddingTop + chartLayout.PlotH + 22),
                        @"class=""gns-bubble-chart__x-label"" text-anchor=""middle""",
                        FormatGridValue(xValue))
                }
            }

            @* ── Connector lines from bubble center to label ── *@
            @if (ShowLabels)
            {
                @for (int i = 0; i < Data.Count; i++)
                {
                    var point = Data[i];
                    var cx    = MapX(point.X, chartLayout);
                    var cy    = MapY(point.Y, chartLayout);
                    var r     = MapRadius(point.Size, chartLayout);
                    var color = point.Color ?? GetPaletteColor(i);

                    @* Line extends upward from bubble edge to label *@
                    var lineEndY = cy - r - 24;
                    if (lineEndY < chartLayout.PaddingTop + 4) lineEndY = cy + r + 24;

                    <line class="gns-bubble-chart__connector"
                          x1="@Inv(cx)" y1="@Inv(cy - r - 2)"
                          x2="@Inv(cx)" y2="@Inv(lineEndY + 12)"
                          stroke="@color" />

                    @* Dot at the connector endpoint *@
                    <circle class="gns-bubble-chart__connector-dot"
                            cx="@Inv(cx)" cy="@Inv(lineEndY + 12)"
                            r="2.5"
                            fill="@color" />

                    @* Label text *@
                    @SvgText(Inv(cx), Inv(lineEndY + 6),
                        @"class=""gns-bubble-chart__label"" text-anchor=""middle""",
                        TruncateLabel(point.Label, 12))
                }
            }

            @* ── Bubbles (rendered after connectors so they overlap) ── *@
            @for (int i = 0; i < Data.Count; i++)
            {
                var point     = Data[i];
                var color     = point.Color ?? GetPaletteColor(i);
                var cx        = MapX(point.X, chartLayout);
                var cy        = MapY(point.Y, chartLayout);
                var r         = MapRadius(point.Size, chartLayout);
                var animDelay = IsAnimated ? $"{i * 80}ms" : "0ms";
                var animClass = IsAnimated ? "gns-bubble-chart__bubble--animated" : "";
                var gradId    = $"url(#{GetBubbleGradientId(i)})";

                <circle class="gns-bubble-chart__bubble @animClass"
                        cx="@Inv(cx)"
                        cy="@Inv(cy)"
                        r="@Inv(r)"
                        fill="@gradId"
                        stroke="@color"
                        stroke-width="1.5"
                        stroke-opacity="0.6"
                        filter="@($"url(#{BubbleShadowFilterId})")"
                        style="--gns-bubble-delay: @animDelay;">
                    <title>@point.Label: @point.X.ToString("G4", CultureInfo.InvariantCulture) × @point.Y.ToString("G4", CultureInfo.InvariantCulture) (@point.Size.ToString("G4", CultureInfo.InvariantCulture))</title>
                </circle>

                @* ── Inner highlight ring (3D specular effect) ── *@
                <circle class="gns-bubble-chart__highlight @animClass"
                        cx="@Inv(cx - r * 0.18)"
                        cy="@Inv(cy - r * 0.18)"
                        r="@Inv(r * 0.35)"
                        fill="white"
                        fill-opacity="0.15"
                        style="--gns-bubble-delay: @animDelay;" />

                @* ── Value badge inside larger bubbles ── *@
                @if (ShowValues && r >= 16)
                {
                    @SvgText(Inv(cx), Inv(cy + 1),
                        @"class=""gns-bubble-chart__value"" text-anchor=""middle"" dominant-baseline=""central""",
                        point.Size.ToString("G3", CultureInfo.InvariantCulture))
                }
            }
        </svg>
    }
    else
    {
        <p class="gns-bubble-chart__empty">No data</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<BubbleDataPoint> Data { get; set; } = [];
    [Parameter] public int Height { get; set; } = 400;
    [Parameter] public double MinBubbleRadius { get; set; } = 8;
    [Parameter] public double MaxBubbleRadius { get; set; } = 48;
    [Parameter] public bool ShowGrid { get; set; } = true;
    [Parameter] public bool ShowLabels { get; set; } = true;
    [Parameter] public bool ShowValues { get; set; } = true;
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static readonly string[] Palette =
    [
        "var(--gns-primary-500,#3F51B5)",
        "var(--gns-success-500,#4CAF50)",
        "var(--gns-warning-500,#FFC107)",
        "var(--gns-danger-500,#F44336)",
        "var(--gns-info-500,#00BCD4)",
        "var(--gns-violet-500,#9C27B0)",
        "var(--gns-rosa-300,#F06292)",
        "var(--gns-ouro-500,#D4AF37)"
    ];

    private string _cssClass => CssClassBuilder
        .Create("gns-bubble-chart")
        .AddClass("gns-bubble-chart--animated", IsAnimated)
        .AddClass(AdditionalCssClass)
        .Build();
    private string _inlineStyle => $"--gns-bubble-hover-filter: url(#{BubbleGlowFilterId});";
    private readonly string _chartId = Guid.NewGuid().ToString("N")[..8];
    private string BubbleShadowFilterId => $"gns-bubble-shadow-{_chartId}";
    private string BubbleGlowFilterId => $"gns-bubble-glow-{_chartId}";

    private static string GetPaletteColor(int index) => Palette[index % Palette.Length];
    private string GetBubbleGradientId(int index) => $"gns-bubble-grad-{_chartId}-{index}";
    private static string Inv(double value) => value.ToString("F1", CultureInfo.InvariantCulture);

    private static string FormatGridValue(double value)
    {
        if (Math.Abs(value) >= 1_000_000) return $"{(value / 1_000_000).ToString("G3", CultureInfo.InvariantCulture)}M";
        if (Math.Abs(value) >= 1_000) return $"{(value / 1_000).ToString("G3", CultureInfo.InvariantCulture)}K";
        return value.ToString("G4", CultureInfo.InvariantCulture);
    }

    private static string TruncateLabel(string label, int maxLength)
        => label.Length > maxLength ? label[..maxLength] + "\u2026" : label;

    private static MarkupString SvgText(string x, string y, string attrs, string content)
        => new($"<text x=\"{x}\" y=\"{y}\" {attrs}>{System.Net.WebUtility.HtmlEncode(content)}</text>");

    private double MapX(double value, BubbleLayout l)
        => l.PaddingLeft + (l.XRange > 0 ? (value - l.XMin) / l.XRange * l.PlotW : l.PlotW / 2.0);

    private double MapY(double value, BubbleLayout l)
        => l.PaddingTop + (l.YRange > 0 ? (l.YMax - value) / l.YRange * l.PlotH : l.PlotH / 2.0);

    private double MapRadius(double size, BubbleLayout l)
        => l.SizeRange > 0
            ? MinBubbleRadius + (size - l.SizeMin) / l.SizeRange * (MaxBubbleRadius - MinBubbleRadius)
            : (MinBubbleRadius + MaxBubbleRadius) / 2.0;

    private BubbleLayout ComputeLayout()
    {
        var paddingLeft   = 80;
        var paddingRight  = 40;
        var paddingTop    = 40;
        var paddingBottom = 48;
        var viewW         = 640;
        var viewH         = Height;
        var plotW         = viewW - paddingLeft - paddingRight;
        var plotH         = viewH - paddingTop - paddingBottom;

        var xMin = Data.Min(d => d.X);
        var xMax = Data.Max(d => d.X);
        var yMin = Data.Min(d => d.Y);
        var yMax = Data.Max(d => d.Y);
        var sizeMin = Data.Min(d => d.Size);
        var sizeMax = Data.Max(d => d.Size);

        // Add 10% margin so bubbles don't sit on edges
        var xMargin = (xMax - xMin) * 0.1;
        var yMargin = (yMax - yMin) * 0.1;
        if (xMargin == 0) xMargin = Math.Abs(xMin) * 0.1 + 1;
        if (yMargin == 0) yMargin = Math.Abs(yMin) * 0.1 + 1;

        xMin -= xMargin;
        xMax += xMargin;
        yMin -= yMargin;
        yMax += yMargin;

        return new BubbleLayout(
            paddingLeft, paddingTop, paddingRight, paddingBottom,
            viewW, viewH, plotW, plotH,
            xMin, xMax, xMax - xMin,
            yMin, yMax, yMax - yMin,
            sizeMin, sizeMax, sizeMax - sizeMin,
            5);
    }

    private record BubbleLayout(
        int PaddingLeft, int PaddingTop, int PaddingRight, int PaddingBottom,
        int ViewW, int ViewH, int PlotW, int PlotH,
        double XMin, double XMax, double XRange,
        double YMin, double YMax, double YRange,
        double SizeMin, double SizeMax, double SizeRange,
        int GridLines);
}
