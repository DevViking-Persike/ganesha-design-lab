@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="img" aria-label="Donut chart">
    @if (Data is { Count: > 0 })
    {
        var donut = ComputeDonutLayout();
        var segments = ComputeSegments(donut);

        <div class="gns-donut-chart__chart-wrap">
            <svg class="gns-donut-chart__svg"
                 width="@Size" height="@Size"
                 viewBox="0 0 @Size @Size"
                 xmlns="http://www.w3.org/2000/svg"
                 style="transform: rotate(-90deg);">

                @* Track circle *@
                <circle class="gns-donut-chart__track"
                        cx="@Inv(donut.Cx, "F1")"
                        cy="@Inv(donut.Cy, "F1")"
                        r="@Inv(donut.Radius, "F2")"
                        stroke-width="@StrokeWidth"
                        fill="none" />

                @* Segments *@
                @for (int i = 0; i < segments.Count; i++)
                {
                    var seg = segments[i];

                    <circle class="gns-donut-chart__segment @(IsAnimated ? "gns-donut-chart__segment--animated" : "")"
                            cx="@Inv(donut.Cx, "F1")"
                            cy="@Inv(donut.Cy, "F1")"
                            r="@Inv(donut.Radius, "F2")"
                            stroke="@seg.Color"
                            stroke-width="@StrokeWidth"
                            fill="none"
                            stroke-dasharray="@(Inv(seg.DashLen, "F2")) @(Inv(donut.Circumference - seg.DashLen, "F2"))"
                            stroke-dashoffset="@(Inv(seg.DashOffset, "F2"))"
                            style="--gns-donut-circumference: @(Inv(donut.Circumference, "F2")); --gns-donut-delay: @seg.AnimDelay;">
                        <title>@seg.Label: @seg.Value.ToString("G4", CultureInfo.InvariantCulture) (@(donut.Total > 0 ? (seg.Value / donut.Total * 100).ToString("F1", CultureInfo.InvariantCulture) : "0")%)</title>
                    </circle>
                }
            </svg>

            @* Center text — note: SVG is rotated -90deg so we use a div overlay *@
            @if (!string.IsNullOrEmpty(CenterLabel) || !string.IsNullOrEmpty(CenterSubLabel))
            {
                <div class="gns-donut-chart__center" style="width: @(Size)px; height: @(Size)px;">
                    @if (!string.IsNullOrEmpty(CenterLabel))
                    {
                        <span class="gns-donut-chart__center-label">@CenterLabel</span>
                    }
                    @if (!string.IsNullOrEmpty(CenterSubLabel))
                    {
                        <span class="gns-donut-chart__center-sublabel">@CenterSubLabel</span>
                    }
                </div>
            }
        </div>

        @if (ShowLegend)
        {
            <ul class="gns-donut-chart__legend" role="list">
                @for (int i = 0; i < Data.Count; i++)
                {
                    var point  = Data[i];
                    var color  = point.Color ?? GetPaletteColor(i);
                    var pct    = donut.Total > 0 ? point.Value / donut.Total * 100 : 0;

                    <li class="gns-donut-chart__legend-item">
                        <span class="gns-donut-chart__legend-dot" style="background-color: @color;" aria-hidden="true"></span>
                        <span class="gns-donut-chart__legend-label">@point.Label</span>
                        <span class="gns-donut-chart__legend-value">@point.Value.ToString("G4", CultureInfo.InvariantCulture)</span>
                        <span class="gns-donut-chart__legend-pct">@pct.ToString("F1", CultureInfo.InvariantCulture)%</span>
                    </li>
                }
            </ul>
        }
    }
    else
    {
        <p class="gns-donut-chart__empty">No data</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ChartDataPoint> Data { get; set; } = [];
    [Parameter] public int Size { get; set; } = 200;
    [Parameter] public int StrokeWidth { get; set; } = 32;
    [Parameter] public string? CenterLabel { get; set; }
    [Parameter] public string? CenterSubLabel { get; set; }
    [Parameter] public bool ShowLegend { get; set; } = true;
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static readonly string[] Palette =
    [
        "var(--gns-primary-500,#3F51B5)",
        "var(--gns-success-500,#4CAF50)",
        "var(--gns-warning-500,#FFC107)",
        "var(--gns-danger-500,#F44336)",
        "var(--gns-info-500,#00BCD4)",
        "var(--gns-violet-500,#9C27B0)",
        "var(--gns-rosa-300,#F06292)",
        "var(--gns-ouro-500,#D4AF37)"
    ];

    private string _cssClass => CssClassBuilder
        .Create("gns-donut-chart")
        .AddClass("gns-donut-chart--animated", IsAnimated)
        .AddClass(AdditionalCssClass)
        .Build();

    private static string GetPaletteColor(int index) => Palette[index % Palette.Length];

    private static string Inv(double value, string format) => value.ToString(format, CultureInfo.InvariantCulture);

    private DonutLayout ComputeDonutLayout()
    {
        var radius        = (Size / 2.0) - StrokeWidth / 2.0;
        var circumference = 2 * Math.PI * radius;
        var cx            = Size / 2.0;
        var cy            = Size / 2.0;
        var total         = Data.Sum(d => d.Value);

        return new DonutLayout(radius, circumference, cx, cy, total);
    }

    private record DonutLayout(double Radius, double Circumference, double Cx, double Cy, double Total);

    private List<DonutSegment> ComputeSegments(DonutLayout donut)
    {
        var result = new List<DonutSegment>();
        double cumulative = 0;
        for (int i = 0; i < Data.Count; i++)
        {
            var point      = Data[i];
            var color      = point.Color ?? GetPaletteColor(i);
            var fraction   = donut.Total > 0 ? point.Value / donut.Total : 0;
            var dashLen    = fraction * donut.Circumference;
            var dashOffset = donut.Total > 0 ? donut.Circumference - cumulative * donut.Circumference / donut.Total : 0;
            var animDelay  = IsAnimated ? $"{i * 80}ms" : "0ms";

            result.Add(new DonutSegment(point.Label, point.Value, color, dashLen, dashOffset, animDelay));
            cumulative += point.Value;
        }
        return result;
    }

    private record DonutSegment(string Label, double Value, string Color, double DashLen, double DashOffset, string AnimDelay);
}
