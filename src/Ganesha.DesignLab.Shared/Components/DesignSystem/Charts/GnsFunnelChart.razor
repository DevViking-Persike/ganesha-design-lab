@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="img" aria-label="Funnel chart">
    @if (Data is { Count: > 0 })
    {
        var maxVal    = Data.Max(d => d.Value);
        var svgWidth  = Width;
        var stepH     = StepHeight;
        var gap       = 4;
        var svgHeight = Data.Count * (stepH + gap) - gap;
        var cx        = svgWidth / 2.0;

        <svg class="gns-funnel__svg"
             width="@svgWidth" height="@svgHeight"
             viewBox="0 0 @svgWidth @svgHeight"
             xmlns="http://www.w3.org/2000/svg">

            <defs>
                @for (int i = 0; i < Data.Count; i++)
                {
                    var color = Data[i].Color ?? GetPaletteColor(i);
                    <linearGradient id="@GetGradientId(i)" x1="0" x2="1" y1="0" y2="0">
                        <stop offset="0%" stop-color="@color" stop-opacity="0.85" />
                        <stop offset="50%" stop-color="@color" stop-opacity="1" />
                        <stop offset="100%" stop-color="@color" stop-opacity="0.85" />
                    </linearGradient>
                }
            </defs>

            @for (int i = 0; i < Data.Count; i++)
            {
                var point     = Data[i];
                var fraction  = maxVal > 0 ? point.Value / maxVal : 0;
                var nextFrac  = (i + 1 < Data.Count && maxVal > 0) ? Data[i + 1].Value / maxVal : fraction * 0.7;
                var topW      = fraction * (svgWidth - 40);
                var botW      = nextFrac * (svgWidth - 40);
                var yTop      = i * (stepH + gap);
                var yBot      = yTop + stepH;
                var animDelay = IsAnimated ? $"{i * 120}ms" : "0ms";

                var x1 = cx - topW / 2;
                var x2 = cx + topW / 2;
                var x3 = cx + botW / 2;
                var x4 = cx - botW / 2;
                var gradientId = GetGradientId(i);

                <g class="gns-funnel__step @(IsAnimated ? "gns-funnel__step--animated" : "")"
                   style="--gns-funnel-delay: @animDelay;">
                    <polygon points="@Inv(x1),@Inv(yTop) @Inv(x2),@Inv(yTop) @Inv(x3),@Inv(yBot) @Inv(x4),@Inv(yBot)"
                             fill="@($"url(#{gradientId})")"
                             class="gns-funnel__shape" />

                    @(SvgText(Inv(cx), Inv(yTop + stepH / 2.0 - 6),
                        @"class=""gns-funnel__title"" text-anchor=""middle"" dominant-baseline=""middle""",
                        point.Label))

                    @(SvgText(Inv(cx), Inv(yTop + stepH / 2.0 + 10),
                        @"class=""gns-funnel__value"" text-anchor=""middle"" dominant-baseline=""middle""",
                        FormatValue(point.Value)))
                </g>
            }
        </svg>
    }
    else
    {
        <p class="gns-funnel__empty">No data</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ChartDataPoint> Data { get; set; } = [];
    [Parameter] public int Width { get; set; } = 400;
    [Parameter] public int StepHeight { get; set; } = 52;
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static readonly string[] Palette =
    [
        "var(--gns-primary-500,#3F51B5)",
        "var(--gns-info-500,#00BCD4)",
        "var(--gns-success-500,#4CAF50)",
        "var(--gns-warning-500,#FFC107)",
        "var(--gns-danger-500,#F44336)",
        "var(--gns-violet-500,#9C27B0)"
    ];

    private string _cssClass => CssClassBuilder
        .Create("gns-funnel")
        .AddClass(AdditionalCssClass)
        .Build();
    private readonly string _chartId = Guid.NewGuid().ToString("N")[..8];

    private static string GetPaletteColor(int index) => Palette[index % Palette.Length];
    private string GetGradientId(int index) => $"gns-funnel-grad-{_chartId}-{index}";
    private static string Inv(double val) => val.ToString("F1", CultureInfo.InvariantCulture);

    private static string FormatValue(double value)
    {
        if (Math.Abs(value) >= 1_000_000)
        {
            return $"{(value / 1_000_000).ToString("0.#", CultureInfo.InvariantCulture)}M";
        }

        if (Math.Abs(value) >= 1_000)
        {
            return $"{(value / 1_000).ToString("0.#", CultureInfo.InvariantCulture)}K";
        }

        return value.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private static MarkupString SvgText(string x, string y, string attrs, string content)
        => new($"<text x=\"{x}\" y=\"{y}\" {attrs}>{System.Net.WebUtility.HtmlEncode(content)}</text>");
}
