@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="img" aria-label="Gauge chart">
    <svg class="gns-gauge__svg"
         width="@Size" height="@HalfSize"
         viewBox="0 0 @Size @HalfSize"
         xmlns="http://www.w3.org/2000/svg">

        @{
            var cx = Size / 2.0;
            var cy = HalfSize - 18;
            var outerRadius = (Size / 2.0) - 10;
            var innerRadius = Math.Max(outerRadius - StrokeWidth, 8);
            var pct = MaxValue > 0 ? Math.Clamp(Value / MaxValue, 0, 1) : 0;
            var fillEndAngle = 180 + (180 * pct);
            var trackPath = BuildBandPath(cx, cy, outerRadius, innerRadius, 180, 360);
            var fillPath = pct > 0
                ? BuildBandPath(cx, cy, outerRadius, innerRadius, 180, fillEndAngle)
                : string.Empty;
            var glossPath = pct > 0
                ? BuildBandPath(cx, cy, outerRadius - 2, Math.Max(innerRadius + (StrokeWidth * 0.45), innerRadius + 2), 180, fillEndAngle)
                : string.Empty;
        }

        <defs>
            <linearGradient id="gns-gauge-bg-@_id" x1="0" x2="1" y1="0" y2="0">
                <stop offset="0%" stop-color="var(--gns-color-surface-raised, #ece7f4)" stop-opacity="0.55" />
                <stop offset="100%" stop-color="var(--gns-color-border-subtle, #d7d0e4)" stop-opacity="0.28" />
            </linearGradient>
            <linearGradient id="gns-gauge-fill-@_id" x1="0" x2="1" y1="0" y2="0">
                <stop offset="0%" stop-color="@StartColor" />
                <stop offset="100%" stop-color="@EndColor" />
            </linearGradient>
            <linearGradient id="gns-gauge-gloss-@_id" x1="0" x2="0" y1="0" y2="1">
                <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.42" />
                <stop offset="35%" stop-color="#FFFFFF" stop-opacity="0.16" />
                <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0" />
            </linearGradient>
            <filter id="gns-gauge-shadow-@_id" x="-20%" y="-20%" width="140%" height="160%">
                <feDropShadow dx="0" dy="6" stdDeviation="10" flood-opacity="0.18" />
            </filter>
        </defs>

        <path class="gns-gauge__track"
              d="@trackPath"
              fill="url(#gns-gauge-bg-@_id)" />

        @if (pct > 0)
        {
            <g class="gns-gauge__fill-group @(IsAnimated ? "gns-gauge__fill-group--animated" : "")">
                <path class="gns-gauge__fill"
                      d="@fillPath"
                      fill="url(#gns-gauge-fill-@_id)"
                      filter="url(#gns-gauge-shadow-@_id)" />

                <path class="gns-gauge__gloss"
                      d="@glossPath"
                      fill="url(#gns-gauge-gloss-@_id)" />

                <path class="gns-gauge__highlight"
                      d="@BuildArcPath(cx, cy, outerRadius - 2, 180, fillEndAngle)"
                      fill="none"
                      stroke="rgba(255,255,255,0.34)"
                      stroke-width="2"
                      stroke-linecap="round" />
            </g>
        }

        @(SvgText(Inv(cx), Inv(cy - (StrokeWidth * 0.6) - 2),
            @"class=""gns-gauge__value"" text-anchor=""middle"" dominant-baseline=""middle""",
            ValueLabel ?? $"{(pct * 100).ToString("F0", CultureInfo.InvariantCulture)}%"))

        @if (!string.IsNullOrEmpty(Label))
        {
            @(SvgText(Inv(cx), Inv(cy + 18),
                @"class=""gns-gauge__label"" text-anchor=""middle"" dominant-baseline=""middle""",
                Label))
        }

        @(SvgText(Inv(12), Inv(cy + 4),
            @"class=""gns-gauge__minmax"" text-anchor=""start"" dominant-baseline=""middle""",
            MinLabel ?? "0"))

        @(SvgText(Inv(Size - 12), Inv(cy + 4),
            @"class=""gns-gauge__minmax"" text-anchor=""end"" dominant-baseline=""middle""",
            MaxLabel ?? MaxValue.ToString("G4", CultureInfo.InvariantCulture)))
    </svg>
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public double MaxValue { get; set; } = 100;
    [Parameter] public int Size { get; set; } = 240;
    [Parameter] public int StrokeWidth { get; set; } = 20;
    [Parameter] public string StartColor { get; set; } = "var(--gns-info-500,#00BCD4)";
    [Parameter] public string EndColor { get; set; } = "var(--gns-success-500,#4CAF50)";
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? ValueLabel { get; set; }
    [Parameter] public string? MinLabel { get; set; }
    [Parameter] public string? MaxLabel { get; set; }
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private int HalfSize => (int)(Size / 2.0) + Math.Max(28, StrokeWidth / 2);
    private readonly string _id = Guid.NewGuid().ToString("N")[..8];

    private string _cssClass => CssClassBuilder
        .Create("gns-gauge")
        .AddClass(AdditionalCssClass)
        .Build();

    private static string Inv(double val) => val.ToString("F2", CultureInfo.InvariantCulture);

    private static MarkupString SvgText(string x, string y, string attrs, string content)
        => new($"<text x=\"{x}\" y=\"{y}\" {attrs}>{System.Net.WebUtility.HtmlEncode(content)}</text>");

    private static string BuildArcPath(double cx, double cy, double r, double startAngle, double endAngle)
    {
        var start = PolarToCartesian(cx, cy, r, startAngle);
        var end = PolarToCartesian(cx, cy, r, endAngle);
        var largeArc = Math.Abs(endAngle - startAngle) > 180 ? 1 : 0;
        return FormattableString.Invariant($"M {start.X:F2},{start.Y:F2} A {r:F2},{r:F2} 0 {largeArc} 1 {end.X:F2},{end.Y:F2}");
    }

    private static string BuildBandPath(double cx, double cy, double outerRadius, double innerRadius, double startAngle, double endAngle)
    {
        var outerStart = PolarToCartesian(cx, cy, outerRadius, startAngle);
        var outerEnd = PolarToCartesian(cx, cy, outerRadius, endAngle);
        var innerEnd = PolarToCartesian(cx, cy, innerRadius, endAngle);
        var innerStart = PolarToCartesian(cx, cy, innerRadius, startAngle);
        var largeArc = Math.Abs(endAngle - startAngle) > 180 ? 1 : 0;

        return FormattableString.Invariant($"M {outerStart.X:F2},{outerStart.Y:F2} A {outerRadius:F2},{outerRadius:F2} 0 {largeArc} 1 {outerEnd.X:F2},{outerEnd.Y:F2} L {innerEnd.X:F2},{innerEnd.Y:F2} A {innerRadius:F2},{innerRadius:F2} 0 {largeArc} 0 {innerStart.X:F2},{innerStart.Y:F2} Z");
    }

    private static (double X, double Y) PolarToCartesian(double cx, double cy, double radius, double angle)
    {
        var radians = angle * Math.PI / 180.0;
        return (cx + radius * Math.Cos(radians), cy + radius * Math.Sin(radians));
    }
}
