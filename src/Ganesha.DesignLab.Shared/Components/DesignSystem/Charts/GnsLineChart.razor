@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="img" aria-label="Line chart">
    @if (Series is { Count: > 0 } && Series.Any(s => s.Values.Count > 0))
    {
        var chartLayout = ComputeLineLayout();

        <svg class="gns-line-chart__svg"
             viewBox="0 0 @chartLayout.ViewW @chartLayout.ViewH"
             xmlns="http://www.w3.org/2000/svg"
             width="@chartLayout.ViewW"
             height="@chartLayout.ViewH">

            @if (ShowAreaGradient)
            {
                <defs>
                @for (int i = 0; i < Series.Count; i++)
                {
                    var gradColor = Series[i].Color ?? GetPaletteColor(i);
                    <linearGradient id="@GetAreaGradientId(i)" x1="0" x2="0" y1="0" y2="1">
                        <stop offset="0%" stop-color="@gradColor" stop-opacity="0.6" />
                        <stop offset="100%" stop-color="@gradColor" stop-opacity="0.0" />
                    </linearGradient>
                }
                </defs>
            }

            @* Y-axis grid lines *@
            @if (ShowGrid)
            {
                @for (int g = 0; g <= chartLayout.GridLines; g++)
                {
                    var frac   = (double)g / chartLayout.GridLines;
                    var gValue = chartLayout.NiceMax - frac * chartLayout.ValueRange;
                    var yPos   = chartLayout.PaddingTop + frac * chartLayout.PlotH;

                    <line class="gns-line-chart__grid-h"
                          x1="@chartLayout.PaddingLeft" y1="@Inv(yPos, "F1")"
                          x2="@(chartLayout.PaddingLeft + chartLayout.PlotW)" y2="@Inv(yPos, "F1")" />

                    @SvgText((chartLayout.PaddingLeft - 8).ToString(CultureInfo.InvariantCulture), Inv(yPos, "F1"),
                        @"class=""gns-line-chart__y-label"" text-anchor=""end"" dominant-baseline=""middle""",
                        FormatGridValue(gValue))
                }
            }

            @* X-axis vertical grid lines *@
            @if (ShowGrid && chartLayout.PointCount > 0)
            {
                @for (int p = 0; p < chartLayout.PointCount; p++)
                {
                    var xPos = chartLayout.PaddingLeft + (chartLayout.PointCount > 1 ? p * chartLayout.StepX : chartLayout.PlotW / 2.0);

                    <line class="gns-line-chart__grid-v"
                          x1="@Inv(xPos, "F1")" y1="@chartLayout.PaddingTop"
                          x2="@Inv(xPos, "F1")" y2="@(chartLayout.PaddingTop + chartLayout.PlotH)" />
                }
            }

            @* Series *@
            @for (int si = 0; si < Series.Count; si++)
            {
                var series    = Series[si];
                var color     = series.Color ?? GetPaletteColor(si);
                var points    = series.Values;
                var animDelay = IsAnimated ? $"{si * 120}ms" : "0ms";

                // Build polyline points string
                var polylinePoints = BuildPolylinePoints(points, chartLayout);

                // Area polygon: polyline + bottom corners
                string areaPoints = "";
                if (ShowArea && points.Count > 0)
                {
                    var firstX  = Inv(chartLayout.PaddingLeft + (points.Count > 1 ? 0 * chartLayout.StepX : chartLayout.PlotW / 2.0), "F1");
                    var lastX   = Inv(chartLayout.PaddingLeft + (points.Count > 1 ? (points.Count - 1) * chartLayout.StepX : chartLayout.PlotW / 2.0), "F1");
                    var bottomY = Inv(chartLayout.PaddingTop + chartLayout.PlotH, "F1");
                    areaPoints  = $"{polylinePoints} {lastX},{bottomY} {firstX},{bottomY}";
                }

                // Estimate total path length for dasharray animation
                var approxLength = points.Count > 1 ? (points.Count - 1) * chartLayout.StepX * 1.2 : chartLayout.PlotW;

                @if (ShowArea)
                {
                    var fillVal = ShowAreaGradient ? $"url(#{GetAreaGradientId(si)})" : color;
                    var fillOpac = ShowAreaGradient ? "1" : "0.12";
                    <polygon class="gns-line-chart__area"
                             points="@areaPoints"
                             fill="@fillVal"
                             fill-opacity="@fillOpac" />
                }

                <polyline class="gns-line-chart__line @(IsAnimated ? "gns-line-chart__line--animated" : "")"
                          points="@polylinePoints"
                          fill="none"
                          stroke="@color"
                          stroke-width="2"
                          stroke-linejoin="round"
                          stroke-linecap="round"
                          style="--gns-line-length: @(approxLength.ToString("F0", CultureInfo.InvariantCulture)); --gns-line-delay: @animDelay;" />

                @* Dots *@
                @if (ShowDots)
                {
                    @for (int p = 0; p < points.Count; p++)
                    {
                        var xp    = chartLayout.PaddingLeft + (points.Count > 1 ? p * chartLayout.StepX : chartLayout.PlotW / 2.0);
                        var yp    = chartLayout.PaddingTop + (chartLayout.ValueRange > 0 ? (chartLayout.NiceMax - points[p]) / chartLayout.ValueRange * chartLayout.PlotH : chartLayout.PlotH / 2.0);
                        var xLabel = HasXLabels && Labels!.Count > p ? Labels[p] : $"Point {p + 1}";

                        <circle class="gns-line-chart__dot"
                                cx="@Inv(xp, "F1")"
                                cy="@Inv(yp, "F1")"
                                r="4"
                                fill="@color"
                                stroke="var(--gns-color-bg-default,#fff)"
                                stroke-width="2">
                            <title>@series.Name — @xLabel: @points[p].ToString("G4", CultureInfo.InvariantCulture)</title>
                        </circle>
                    }
                }
            }

            @* X-axis labels *@
            @if (HasXLabels)
            {
                @for (int p = 0; p < Labels!.Count && p < chartLayout.PointCount; p++)
                {
                    var xp = chartLayout.PaddingLeft + (chartLayout.PointCount > 1 ? p * chartLayout.StepX : chartLayout.PlotW / 2.0);

                    @SvgText(Inv(xp, "F1"), Inv(chartLayout.PaddingTop + chartLayout.PlotH + 22, "F1"),
                        @"class=""gns-line-chart__x-label"" text-anchor=""middle""",
                        TruncateLabel(Labels[p], 8))
                }
            }
        </svg>
    }
    else
    {
        <p class="gns-line-chart__empty">No data</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ChartSeries> Series { get; set; } = [];
    [Parameter] public IReadOnlyList<string>? Labels { get; set; }
    [Parameter] public int Height { get; set; } = 320;
    [Parameter] public bool ShowArea { get; set; } = false;
    [Parameter] public bool ShowAreaGradient { get; set; } = false;
    [Parameter] public bool ShowDots { get; set; } = true;
    [Parameter] public bool ShowGrid { get; set; } = true;
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static readonly string[] Palette =
    [
        "var(--gns-primary-500,#3F51B5)",
        "var(--gns-success-500,#4CAF50)",
        "var(--gns-warning-500,#FFC107)",
        "var(--gns-danger-500,#F44336)",
        "var(--gns-info-500,#00BCD4)",
        "var(--gns-violet-500,#9C27B0)",
        "var(--gns-rosa-300,#F06292)",
        "var(--gns-ouro-500,#D4AF37)"
    ];

    private bool HasXLabels => Labels is { Count: > 0 };
    private readonly string _chartId = Guid.NewGuid().ToString("N")[..8];

    private string _cssClass => CssClassBuilder
        .Create("gns-line-chart")
        .AddClass("gns-line-chart--animated", IsAnimated)
        .AddClass(AdditionalCssClass)
        .Build();

    private static string GetPaletteColor(int index) => Palette[index % Palette.Length];
    private string GetAreaGradientId(int index) => $"gns-line-grad-{_chartId}-{index}";

    private static string Inv(double value, string format) => value.ToString(format, CultureInfo.InvariantCulture);

    private static string FormatGridValue(double value)
    {
        if (value >= 1_000_000) return $"{(value / 1_000_000).ToString("G3", CultureInfo.InvariantCulture)}M";
        if (value >= 1_000) return $"{(value / 1_000).ToString("G3", CultureInfo.InvariantCulture)}K";
        return value.ToString("G4", CultureInfo.InvariantCulture);
    }

    private static string TruncateLabel(string label, int maxLength)
        => label.Length > maxLength ? label[..maxLength] + "\u2026" : label;

    private static MarkupString SvgText(string x, string y, string attrs, string content)
        => new($"<text x=\"{x}\" y=\"{y}\" {attrs}>{System.Net.WebUtility.HtmlEncode(content)}</text>");

    private LineLayout ComputeLineLayout()
    {
        var paddingLeft   = 80;
        var paddingRight  = 24;
        var paddingTop    = 24;
        var paddingBottom = HasXLabels ? 40 : 20;
        var viewW         = 640;
        var viewH         = Height;
        var plotW         = viewW - paddingLeft - paddingRight;
        var plotH         = viewH - paddingTop - paddingBottom;

        var allValues  = Series.SelectMany(s => s.Values).ToList();
        var dataMin    = allValues.Count > 0 ? allValues.Min() : 0;
        var dataMax    = allValues.Count > 0 ? allValues.Max() : 1;
        var niceMax    = dataMax <= 0 ? 1 : dataMax * 1.1;
        var niceMin    = Math.Min(0, dataMin);
        var valueRange = niceMax - niceMin;

        var pointCount = Series.Max(s => s.Values.Count);
        var stepX      = pointCount > 1 ? plotW / (double)(pointCount - 1) : plotW;

        return new LineLayout(paddingLeft, paddingTop, viewW, viewH, plotW, plotH,
            niceMax, valueRange, pointCount, stepX, 5);
    }

    private static string BuildPolylinePoints(IReadOnlyList<double> points, LineLayout layout)
    {
        var ptList = new System.Text.StringBuilder();
        for (int p = 0; p < points.Count; p++)
        {
            var xp = layout.PaddingLeft + (points.Count > 1 ? p * layout.StepX : layout.PlotW / 2.0);
            var yp = layout.PaddingTop + (layout.ValueRange > 0 ? (layout.NiceMax - points[p]) / layout.ValueRange * layout.PlotH : layout.PlotH / 2.0);
            if (p > 0) ptList.Append(' ');
            ptList.Append(FormattableString.Invariant($"{xp:F1},{yp:F1}"));
        }
        return ptList.ToString();
    }

    private record LineLayout(
        int PaddingLeft, int PaddingTop, int ViewW, int ViewH,
        int PlotW, int PlotH, double NiceMax, double ValueRange,
        int PointCount, double StepX, int GridLines);
}
