@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="img" aria-label="Pie chart">
    @if (Data is { Count: > 0 })
    {
        var total = Data.Sum(d => d.Value);
        var size  = Size;
        var cx    = size / 2.0;
        var cy    = size / 2.0;
        var r     = (size / 2.0) - 4;

        <div class="gns-pie-chart__chart-wrap">
            <svg class="gns-pie-chart__svg"
                 width="@size" height="@size"
                 viewBox="0 0 @size @size"
                 xmlns="http://www.w3.org/2000/svg">

                @if (ShowGradient)
                {
                    <defs>
                        @for (int i = 0; i < Data.Count; i++)
                        {
                            var baseColor = Data[i].Color ?? GetPaletteColor(i);
                            <linearGradient id="@GetGradientId(i)" x1="0" x2="1" y1="0" y2="1">
                                <stop offset="0%" stop-color="@baseColor" stop-opacity="1" />
                                <stop offset="100%" stop-color="@baseColor" stop-opacity="0.65" />
                            </linearGradient>
                        }
                    </defs>
                }

                @{
                    double startAngle = -90;
                    for (int i = 0; i < Data.Count; i++)
                    {
                        var point    = Data[i];
                        var color    = ShowGradient ? $"url(#{GetGradientId(i)})" : (point.Color ?? GetPaletteColor(i));
                        var fraction = total > 0 ? point.Value / total : 0;
                        var sweep    = fraction * 360.0;
                        var endAngle = startAngle + sweep;
                        var animDelay = IsAnimated ? $"{i * 100}ms" : "0ms";

                        var path = BuildSlicePath(cx, cy, r, startAngle, endAngle, sweep);

                        <path class="gns-pie-chart__slice @(IsAnimated ? "gns-pie-chart__slice--animated" : "")"
                              d="@path"
                              fill="@color"
                              stroke="var(--gns-color-bg-card, #fff)"
                              stroke-width="2"
                              style="--gns-pie-delay: @animDelay; transform-origin: @(Inv(cx))px @(Inv(cy))px;">
                            <title>@point.Label: @point.Value.ToString("G4", CultureInfo.InvariantCulture) (@((fraction * 100).ToString("F1", CultureInfo.InvariantCulture))%)</title>
                        </path>

                        startAngle = endAngle;
                    }
                }
            </svg>
        </div>

        @if (ShowLegend)
        {
            <ul class="gns-pie-chart__legend" role="list">
                @for (int i = 0; i < Data.Count; i++)
                {
                    var point = Data[i];
                    var color = point.Color ?? GetPaletteColor(i);
                    var pct   = total > 0 ? point.Value / total * 100 : 0;

                    <li class="gns-pie-chart__legend-item">
                        <span class="gns-pie-chart__legend-dot" style="background-color: @color;" aria-hidden="true"></span>
                        <span class="gns-pie-chart__legend-label">@point.Label</span>
                        <span class="gns-pie-chart__legend-pct">@pct.ToString("F1", CultureInfo.InvariantCulture)%</span>
                    </li>
                }
            </ul>
        }
    }
    else
    {
        <p class="gns-pie-chart__empty">No data</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ChartDataPoint> Data { get; set; } = [];
    [Parameter] public int Size { get; set; } = 220;
    [Parameter] public bool ShowLegend { get; set; } = true;
    [Parameter] public bool ShowGradient { get; set; } = true;
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static readonly string[] Palette =
    [
        "var(--gns-primary-500,#3F51B5)",
        "var(--gns-success-500,#4CAF50)",
        "var(--gns-warning-500,#FFC107)",
        "var(--gns-danger-500,#F44336)",
        "var(--gns-info-500,#00BCD4)",
        "var(--gns-violet-500,#9C27B0)",
        "var(--gns-rosa-300,#F06292)",
        "var(--gns-ouro-500,#D4AF37)"
    ];

    private string _cssClass => CssClassBuilder
        .Create("gns-pie-chart")
        .AddClass(AdditionalCssClass)
        .Build();
    private readonly string _chartId = Guid.NewGuid().ToString("N")[..8];

    private static string GetPaletteColor(int index) => Palette[index % Palette.Length];
    private string GetGradientId(int index) => $"gns-pie-grad-{_chartId}-{index}";
    private static string Inv(double val) => val.ToString("F2", CultureInfo.InvariantCulture);

    private static string BuildSlicePath(double cx, double cy, double r, double startAngle, double endAngle, double sweep)
    {
        var startRad = startAngle * Math.PI / 180.0;
        var endRad   = endAngle * Math.PI / 180.0;

        var x1 = cx + r * Math.Cos(startRad);
        var y1 = cy + r * Math.Sin(startRad);
        var x2 = cx + r * Math.Cos(endRad);
        var y2 = cy + r * Math.Sin(endRad);

        var largeArc = sweep > 180 ? 1 : 0;

        return FormattableString.Invariant(
            $"M {cx:F2},{cy:F2} L {x1:F2},{y1:F2} A {r:F2},{r:F2} 0 {largeArc} 1 {x2:F2},{y2:F2} Z");
    }
}
