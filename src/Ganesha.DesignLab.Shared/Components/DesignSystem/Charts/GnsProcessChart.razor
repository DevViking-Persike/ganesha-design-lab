@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="region" aria-label="Process flow chart">
    @for (int i = 0; i < Steps.Count; i++)
    {
        var step = Steps[i];
        var color = step.Color ?? GetPaletteColor(i);
        var animDelay = IsAnimated ? $"{i * 150}ms" : "0ms";

        <div class="gns-process-chart__step @(IsAnimated ? "gns-process-chart__step--animated" : "")" style="--gns-step-delay: @animDelay; --gns-step-color: @color;">
            <div class="gns-process-chart__arrow-container">
                <svg class="gns-process-chart__arrow" viewBox="0 0 100 100" preserveAspectRatio="none">
                    <polygon points="0,0 80,0 100,50 80,100 0,100 20,50" fill="@color" />
                </svg>
                <div class="gns-process-chart__content">
                    <span class="gns-process-chart__title">@step.Title</span>
                    <span class="gns-process-chart__value">@step.Value</span>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(step.Description))
            {
                <p class="gns-process-chart__description">@step.Description</p>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ProcessStep> Steps { get; set; } = [];
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static readonly string[] Palette =
    [
        "var(--gns-primary-500,#3F51B5)",
        "var(--gns-info-500,#00BCD4)",
        "var(--gns-success-500,#4CAF50)",
        "var(--gns-warning-500,#FFC107)",
        "var(--gns-rosa-300,#F06292)",
        "var(--gns-violet-500,#9C27B0)"
    ];

    private string _cssClass => CssClassBuilder
        .Create("gns-process-chart")
        .AddClass(AdditionalCssClass)
        .Build();

    private static string GetPaletteColor(int index) => Palette[index % Palette.Length];
}
