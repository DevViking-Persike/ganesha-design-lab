@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

@{
    var radius       = (Size / 2.0) - StrokeWidth / 2.0 - 2;
    var circumference = 2 * Math.PI * radius;
    var pct          = Math.Clamp(Value, 0, 100);
    var dashOffset   = circumference * (1 - pct / 100.0);
    var cx           = Size / 2.0;
    var cy           = Size / 2.0;
}

<div class="@_cssClass"
     role="progressbar"
     aria-valuenow="@pct"
     aria-valuemin="0"
     aria-valuemax="100"
     aria-label="@(string.IsNullOrEmpty(Label) ? $"{pct.ToString("F0", CultureInfo.InvariantCulture)}% progress" : $"{Label} progress")">

    <svg class="gns-radial-progress__svg"
         width="@Size" height="@Size"
         viewBox="0 0 @Size @Size"
         xmlns="http://www.w3.org/2000/svg">

        @* Track circle *@
        <circle class="gns-radial-progress__track"
                cx="@Inv(cx, "F1")"
                cy="@Inv(cy, "F1")"
                r="@Inv(radius, "F2")"
                stroke-width="@StrokeWidth"
                fill="none"
                stroke-linecap="round" />

        @* Progress arc — rotated -90deg so it starts at top *@
        <circle class="gns-radial-progress__arc @(IsAnimated ? "gns-radial-progress__arc--animated" : "")"
                cx="@Inv(cx, "F1")"
                cy="@Inv(cy, "F1")"
                r="@Inv(radius, "F2")"
                stroke-width="@StrokeWidth"
                fill="none"
                stroke-linecap="round"
                stroke-dasharray="@(Inv(circumference, "F2"))"
                stroke-dashoffset="@(Inv(dashOffset, "F2"))"
                transform="rotate(-90 @(Inv(cx, "F1")) @(Inv(cy, "F1")))"
                style="--gns-radial-circumference: @(circumference.ToString("F2", CultureInfo.InvariantCulture)); --gns-radial-final-offset: @(dashOffset.ToString("F2", CultureInfo.InvariantCulture)); --gns-radial-stroke-color: @_arcColor;" />

        @* Center label *@
        @SvgText(Inv(cx, "F1"), Inv(cy - (string.IsNullOrEmpty(Label) ? 0 : 8), "F1"),
            @"class=""gns-radial-progress__label"" text-anchor=""middle"" dominant-baseline=""central""",
            $"{pct.ToString("F0", CultureInfo.InvariantCulture)}%")
        @if (!string.IsNullOrEmpty(Label))
        {
            @SvgText(Inv(cx, "F1"), Inv(cy + 10, "F1"),
                @"class=""gns-radial-progress__sublabel"" text-anchor=""middle"" dominant-baseline=""central"" style=""font-size: 0.6em; font-weight: 600; fill: var(--gns-color-text-secondary, #6B5D7B);""",
                Label)
        }
    </svg>
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public int Size { get; set; } = 80;
    [Parameter] public int StrokeWidth { get; set; } = 8;
    [Parameter] public string? Label { get; set; }
    [Parameter] public ProgressBarVariant Variant { get; set; } = ProgressBarVariant.Default;
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static string Inv(double value, string format) => value.ToString(format, CultureInfo.InvariantCulture);

    private static MarkupString SvgText(string x, string y, string attrs, string content)
        => new($"<text x=\"{x}\" y=\"{y}\" {attrs}>{System.Net.WebUtility.HtmlEncode(content)}</text>");

    private string _cssClass => CssClassBuilder
        .Create("gns-radial-progress")
        .AddClass("gns-radial-progress--animated", IsAnimated)
        .AddClass(AdditionalCssClass)
        .Build();

    private string _arcColor => Variant switch
    {
        ProgressBarVariant.Success => "var(--gns-success-500,#4CAF50)",
        ProgressBarVariant.Warning => "var(--gns-warning-500,#FFC107)",
        ProgressBarVariant.Danger  => "var(--gns-danger-500,#F44336)",
        ProgressBarVariant.Info    => "var(--gns-info-500,#00BCD4)",
        _                          => "var(--gns-primary-500,#3F51B5)"
    };
}
