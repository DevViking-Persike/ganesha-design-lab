@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="img" aria-label="Stacked bar chart">
    @if (Series is { Count: > 0 } && Labels is { Count: > 0 })
    {
        var chartLayout = ComputeLayout();
        var svgViewBox = FormattableString.Invariant($"0 0 {chartLayout.ChartWidth} {chartLayout.ChartHeight}");

        <svg class="gns-stacked-bar__svg"
             viewBox="@svgViewBox"
             xmlns="http://www.w3.org/2000/svg"
             width="@chartLayout.ChartWidth"
             height="@chartLayout.ChartHeight">

            @* Y-axis grid lines + labels *@
            @for (int g = 0; g <= chartLayout.GridLineCount; g++)
            {
                var fraction  = (double)g / chartLayout.GridLineCount;
                var gridValue = chartLayout.EffectiveMax * (1 - fraction);
                var yPos      = chartLayout.PaddingTop + fraction * chartLayout.PlotHeight;
                var gridLabel = FormatGridValue(gridValue);

                <line class="gns-stacked-bar__grid-line"
                      x1="@chartLayout.PaddingLeft" y1="@Inv(yPos)"
                      x2="@(chartLayout.PaddingLeft + chartLayout.PlotWidth)" y2="@Inv(yPos)" />

                @SvgText((chartLayout.PaddingLeft - 8).ToString(CultureInfo.InvariantCulture), Inv(yPos),
                    @"class=""gns-stacked-bar__y-label"" text-anchor=""end"" dominant-baseline=""middle""",
                    gridLabel)
            }

            @* Stacked bars *@
            @for (int i = 0; i < Labels.Count; i++)
            {
                var xCenter   = chartLayout.PaddingLeft + (i + 0.5) * chartLayout.GroupWidth;
                var xBar      = xCenter - chartLayout.BarWidth / 2;
                double cumY   = 0;

                @for (int si = Series.Count - 1; si >= 0; si--)
                {
                    var series = Series[si];
                    if (i >= series.Values.Count) continue;

                    var val       = series.Values[i];
                    var color     = series.Color ?? GetPaletteColor(si);
                    var ratio     = chartLayout.EffectiveMax > 0 ? Math.Clamp(val / chartLayout.EffectiveMax, 0, 1) : 0;
                    var barH      = ratio * chartLayout.PlotHeight;
                    cumY         += barH;
                    var yBar      = chartLayout.PaddingTop + chartLayout.PlotHeight - cumY;
                    var animDelay = IsAnimated ? $"{(i * Series.Count + si) * 40}ms" : "0ms";
                    var animClass = IsAnimated ? "gns-stacked-bar__bar--animated" : "";

                    <rect class="gns-stacked-bar__bar @animClass"
                          x="@Inv(xBar)" y="@Inv(yBar)"
                          width="@Inv(chartLayout.BarWidth)" height="@Inv(barH)"
                          rx="@(si == Series.Count - 1 ? "3" : "0")"
                          fill="@color"
                          style="transform-origin: @(Inv(xCenter))px @(Inv(chartLayout.PaddingTop + chartLayout.PlotHeight))px; --gns-bar-delay: @animDelay;">
                        <title>@series.Name — @Labels[i]: @val.ToString("G4", CultureInfo.InvariantCulture)</title>
                    </rect>
                }

                @* X-axis label *@
                @if (ShowLabels)
                {
                    @SvgText(Inv(xCenter), Inv(chartLayout.PaddingTop + chartLayout.PlotHeight + 22),
                        @"class=""gns-stacked-bar__x-label"" text-anchor=""middle""",
                        TruncateLabel(Labels[i], 10))
                }
            }

            @* Legend *@
            @if (ShowLegend)
            {
                var legendX = chartLayout.PaddingLeft;
                var legendY = chartLayout.ChartHeight - 8;

                @for (int si = 0; si < Series.Count; si++)
                {
                    var color = Series[si].Color ?? GetPaletteColor(si);
                    var name  = Series[si].Name;
                    var lx    = legendX + si * 120;

                    <rect x="@lx" y="@Inv(legendY - 10)" width="12" height="12" rx="2" fill="@color" />
                    @SvgText((lx + 18).ToString(CultureInfo.InvariantCulture), Inv(legendY),
                        @"class=""gns-stacked-bar__legend-text"" dominant-baseline=""middle""", name)
                }
            }
        </svg>
    }
    else
    {
        <p class="gns-stacked-bar__empty">No data</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ChartSeries> Series { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<string> Labels { get; set; } = [];
    [Parameter] public double? MaxValue { get; set; }
    [Parameter] public int Height { get; set; } = 320;
    [Parameter] public bool ShowLabels { get; set; } = true;
    [Parameter] public bool ShowLegend { get; set; } = true;
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static readonly string[] Palette =
    [
        "var(--gns-primary-500,#3F51B5)",
        "var(--gns-success-500,#4CAF50)",
        "var(--gns-warning-500,#FFC107)",
        "var(--gns-danger-500,#F44336)",
        "var(--gns-info-500,#00BCD4)",
        "var(--gns-violet-500,#9C27B0)"
    ];

    private string _cssClass => CssClassBuilder
        .Create("gns-stacked-bar")
        .AddClass(AdditionalCssClass)
        .Build();

    private static string GetPaletteColor(int index) => Palette[index % Palette.Length];
    private static string Inv(double value) => value.ToString("F1", CultureInfo.InvariantCulture);
    private static string TruncateLabel(string label, int max) => label.Length > max ? label[..max] + "\u2026" : label;

    private static string FormatGridValue(double value)
    {
        if (value >= 1_000_000) return $"{(value / 1_000_000).ToString("G3", CultureInfo.InvariantCulture)}M";
        if (value >= 1_000) return $"{(value / 1_000).ToString("G3", CultureInfo.InvariantCulture)}K";
        return value.ToString("G4", CultureInfo.InvariantCulture);
    }

    private static MarkupString SvgText(string x, string y, string attrs, string content)
        => new($"<text x=\"{x}\" y=\"{y}\" {attrs}>{System.Net.WebUtility.HtmlEncode(content)}</text>");

    private StackedBarLayout ComputeLayout()
    {
        var paddingLeft   = 80;
        var paddingRight  = 24;
        var paddingTop    = 24;
        var paddingBottom = ShowLabels ? (ShowLegend ? 60 : 40) : (ShowLegend ? 40 : 20);
        var chartWidth    = 640;
        var chartHeight   = Height;
        var plotWidth      = chartWidth - paddingLeft - paddingRight;
        var plotHeight     = chartHeight - paddingTop - paddingBottom;

        // Max is the max stack total
        double effectiveMax;
        if (MaxValue.HasValue)
        {
            effectiveMax = MaxValue.Value;
        }
        else
        {
            effectiveMax = 0;
            for (int i = 0; i < Labels.Count; i++)
            {
                double stackTotal = 0;
                foreach (var s in Series)
                {
                    if (i < s.Values.Count) stackTotal += s.Values[i];
                }
                if (stackTotal > effectiveMax) effectiveMax = stackTotal;
            }
        }
        if (effectiveMax <= 0) effectiveMax = 1;

        var groupWidth = plotWidth / (double)Labels.Count;
        var barWidth   = Math.Max(4, groupWidth * 0.6);

        return new StackedBarLayout(effectiveMax, paddingLeft, paddingTop, chartWidth, chartHeight,
            plotWidth, plotHeight, groupWidth, barWidth, 5);
    }

    private record StackedBarLayout(
        double EffectiveMax, int PaddingLeft, int PaddingTop,
        int ChartWidth, int ChartHeight,
        int PlotWidth, int PlotHeight,
        double GroupWidth, double BarWidth, int GridLineCount);
}
