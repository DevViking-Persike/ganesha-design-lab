@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="img" aria-label="Horizontal bar chart">
    @if (Data is { Count: > 0 })
    {
        var effectiveMax = ComputeEffectiveMax();

        <div class="gns-hbar-chart__list">
            @for (int i = 0; i < Data.Count; i++)
            {
                var point     = Data[i];
                var barColor  = point.Color ?? GetPaletteColor(i);
                var pct       = effectiveMax > 0 ? Math.Clamp(point.Value / effectiveMax * 100, 0, 100) : 0;
                var animDelay = IsAnimated ? $"{i * 60}ms" : "0ms";
                var animClass = IsAnimated ? "gns-hbar-chart__fill--animated" : "";
                var barStyle  = $"width: {pct.ToString("F2", CultureInfo.InvariantCulture)}%; background-color: {barColor}; --gns-hbar-target-width: {pct.ToString("F2", CultureInfo.InvariantCulture)}%; --gns-hbar-delay: {animDelay};";

                <div class="gns-hbar-chart__row">
                    <span class="gns-hbar-chart__label" title="@point.Label">@TruncateLabel(point.Label, 20)</span>

                    <div class="gns-hbar-chart__track" style="height: @(BarHeight)px;">
                        <div class="gns-hbar-chart__fill @animClass"
                             style="@barStyle"
                             role="progressbar"
                             aria-valuenow="@point.Value.ToString("G4", CultureInfo.InvariantCulture)"
                             aria-valuemin="0"
                             aria-valuemax="@effectiveMax.ToString("G4", CultureInfo.InvariantCulture)"
                             aria-label="@point.Label: @point.Value.ToString("G4", CultureInfo.InvariantCulture)">
                        </div>
                    </div>

                    @if (ShowValues)
                    {
                        <span class="gns-hbar-chart__value">@FormatValue(point.Value)</span>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <p class="gns-hbar-chart__empty">No data</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ChartDataPoint> Data { get; set; } = [];
    [Parameter] public double? MaxValue { get; set; }
    [Parameter] public int BarHeight { get; set; } = 32;
    [Parameter] public bool ShowValues { get; set; } = true;
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private static readonly string[] Palette =
    [
        "var(--gns-primary-500,#3F51B5)",
        "var(--gns-success-500,#4CAF50)",
        "var(--gns-warning-500,#FFC107)",
        "var(--gns-danger-500,#F44336)",
        "var(--gns-info-500,#00BCD4)",
        "var(--gns-violet-500,#9C27B0)",
        "var(--gns-rosa-300,#F06292)",
        "var(--gns-ouro-500,#D4AF37)"
    ];

    private string _cssClass => CssClassBuilder
        .Create("gns-hbar-chart")
        .AddClass("gns-hbar-chart--animated", IsAnimated)
        .AddClass(AdditionalCssClass)
        .Build();

    private static string GetPaletteColor(int index) => Palette[index % Palette.Length];

    private static string Inv(double value, string format) => value.ToString(format, CultureInfo.InvariantCulture);

    private double ComputeEffectiveMax() => MaxValue ?? Data.Max(d => d.Value);

    private static string FormatValue(double value)
    {
        if (value >= 1_000_000) return $"{(value / 1_000_000).ToString("G3", CultureInfo.InvariantCulture)}M";
        if (value >= 1_000) return $"{(value / 1_000).ToString("G3", CultureInfo.InvariantCulture)}K";
        return value.ToString("G4", CultureInfo.InvariantCulture);
    }

    private static string TruncateLabel(string label, int maxLength)
        => label.Length > maxLength ? label[..maxLength] + "\u2026" : label;
}
