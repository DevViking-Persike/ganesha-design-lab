@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_wrapperClass">
    @if (!string.IsNullOrEmpty(Label) || ShowValue)
    {
        <div class="gns-progress-bar__header">
            @if (!string.IsNullOrEmpty(Label))
            {
                <span class="gns-progress-bar__label">@Label</span>
            }
            @if (ShowValue)
            {
                <span class="gns-progress-bar__value">@(_pct.ToString("F0", CultureInfo.InvariantCulture))%</span>
            }
        </div>
    }

    <div class="gns-progress-bar__track"
         role="progressbar"
         aria-valuenow="@Value"
         aria-valuemin="0"
         aria-valuemax="@(Max ?? 100)"
         aria-label="@(Label ?? "Progress")">

        <div class="@_fillClass"
             style="width: @(_pct.ToString("F2", CultureInfo.InvariantCulture))%; --gns-pbar-target-width: @(_pct.ToString("F2", CultureInfo.InvariantCulture))%;">
        </div>
    </div>
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public double? Max { get; set; } = 100;
    [Parameter] public string? Label { get; set; }
    [Parameter] public bool ShowValue { get; set; } = true;
    [Parameter] public ProgressBarVariant Variant { get; set; } = ProgressBarVariant.Default;
    [Parameter] public ProgressBarSize Size { get; set; } = ProgressBarSize.Medium;
    [Parameter] public bool IsAnimated { get; set; } = true;
    [Parameter] public bool IsStriped { get; set; } = false;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private double _pct => Max.HasValue && Max.Value > 0
        ? Math.Clamp(Value / Max.Value * 100, 0, 100)
        : Math.Clamp(Value, 0, 100);

    private string _wrapperClass => CssClassBuilder
        .Create("gns-progress-bar")
        .AddClass(AdditionalCssClass)
        .Build();

    private string _fillClass => CssClassBuilder
        .Create("gns-progress-bar__fill")
        .AddClass("gns-progress-bar__fill--default",  Variant == ProgressBarVariant.Default)
        .AddClass("gns-progress-bar__fill--success",  Variant == ProgressBarVariant.Success)
        .AddClass("gns-progress-bar__fill--warning",  Variant == ProgressBarVariant.Warning)
        .AddClass("gns-progress-bar__fill--danger",   Variant == ProgressBarVariant.Danger)
        .AddClass("gns-progress-bar__fill--info",     Variant == ProgressBarVariant.Info)
        .AddClass("gns-progress-bar__fill--sm",       Size == ProgressBarSize.Small)
        .AddClass("gns-progress-bar__fill--md",       Size == ProgressBarSize.Medium)
        .AddClass("gns-progress-bar__fill--lg",       Size == ProgressBarSize.Large)
        .AddClass("gns-progress-bar__fill--striped",  IsStriped)
        .AddClass("gns-progress-bar__fill--animated", IsAnimated)
        .Build();
}
