@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Charts
@using System.Globalization
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" aria-hidden="true">
    @if (Values is { Count: > 1 })
    {
        var spark = ComputeSparkLayout();

        <svg class="gns-sparkline__svg"
             width="@Width" height="@Height"
             viewBox="0 0 @Width @Height"
             xmlns="http://www.w3.org/2000/svg"
             preserveAspectRatio="none">

            @if (ShowArea)
            {
                <path class="gns-sparkline__area"
                      d="@spark.AreaPath"
                      fill="@Color"
                      fill-opacity="0.15"
                      stroke="none" />
            }

            <path class="gns-sparkline__line"
                  d="@spark.Path"
                  fill="none"
                  stroke="@Color"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round" />
        </svg>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<double> Values { get; set; } = [];
    [Parameter] public int Width { get; set; } = 120;
    [Parameter] public int Height { get; set; } = 32;
    [Parameter] public string Color { get; set; } = "var(--gns-primary-500,#4F46E5)";
    [Parameter] public bool ShowArea { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-sparkline")
        .AddClass(AdditionalCssClass)
        .Build();

    private static string Inv(double value, string format) => value.ToString(format, CultureInfo.InvariantCulture);

    private SparkLayout ComputeSparkLayout()
    {
        var min    = Values.Min();
        var max    = Values.Max();
        var range  = max - min;
        var padV   = 2.0;
        var plotH  = Height - padV * 2;
        var stepX  = (double)(Width - 2) / (Values.Count - 1);

        var path = BuildPath(Values, min, range, plotH, padV, stepX);

        var firstX = 1.0;
        var lastX  = 1.0 + (Values.Count - 1) * stepX;
        var areaPath = FormattableString.Invariant($"{path} L{lastX:F1},{Height - padV:F1} L{firstX:F1},{Height - padV:F1} Z");

        return new SparkLayout(path, areaPath);
    }

    private record SparkLayout(string Path, string AreaPath);

    private static string BuildPath(
        IReadOnlyList<double> values,
        double min, double range,
        double plotH, double padV, double stepX)
    {
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < values.Count; i++)
        {
            var x = 1.0 + i * stepX;
            var y = padV + (range > 0 ? (1 - (values[i] - min) / range) * plotH : plotH / 2.0);

            if (i == 0)
            {
                sb.Append(FormattableString.Invariant($"M{x:F1},{y:F1}"));
            }
            else
            {
                var prevX   = 1.0 + (i - 1) * stepX;
                var prevY   = padV + (range > 0 ? (1 - (values[i - 1] - min) / range) * plotH : plotH / 2.0);
                var cp1x    = prevX + stepX * 0.5;
                var cp2x    = x - stepX * 0.5;
                sb.Append(FormattableString.Invariant($" C{cp1x:F1},{prevY:F1} {cp2x:F1},{y:F1} {x:F1},{y:F1}"));
            }
        }
        return sb.ToString();
    }
}
