@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.DataDisplay
@using Ganesha.DesignLab.Shared.Extensions

<header class="@_cssClass">
    <div class="gns-section-header__text">
        <h2 class="gns-section-header__title">@Title</h2>
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <p class="gns-section-header__subtitle">@Subtitle</p>
        }
    </div>

    @if (Actions is not null)
    {
        <div class="gns-section-header__actions">
            @Actions
        </div>
    }
</header>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-section-header")
        .AddClass("gns-section-header--with-actions", Actions is not null)
        .AddClass(AdditionalCssClass)
        .Build();
}
