@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.DataDisplay
@using Ganesha.DesignLab.Shared.Extensions
@typeparam TItem

<div class="@_wrapperClass">
    @if (IsLoading)
    {
        <div class="gns-table__loading-overlay" role="status" aria-label="Loading data">
            <div class="gns-table__spinner" aria-hidden="true"></div>
            <span class="gns-sr-only">Loading…</span>
        </div>
    }

    <div class="gns-table__scroll-container">
        <table class="@_tableClass" aria-busy="@IsLoading.ToString().ToLower()">
            @if (HeaderTemplate is not null)
            {
                <thead class="gns-table__head">
                    <tr class="gns-table__head-row">
                        @HeaderTemplate
                    </tr>
                </thead>
            }

            <tbody class="gns-table__body">
                @if (Items is not null && Items.Count > 0)
                {
                    @foreach (var item in Items)
                    {
                        @RowTemplate(item)
                    }
                }
                else if (!IsLoading)
                {
                    <tr class="gns-table__empty-row">
                        <td class="gns-table__empty-cell" colspan="999">
                            @if (EmptyTemplate is not null)
                            {
                                @EmptyTemplate
                            }
                            else
                            {
                                <span class="gns-table__empty-default">No data available.</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<TItem> Items { get; set; } = [];
    [Parameter, EditorRequired] public RenderFragment<TItem> RowTemplate { get; set; } = default!;
    [Parameter] public RenderFragment? HeaderTemplate { get; set; }
    [Parameter] public RenderFragment? EmptyTemplate { get; set; }
    [Parameter] public bool IsStriped { get; set; } = false;
    [Parameter] public bool IsHoverable { get; set; } = true;
    [Parameter] public bool IsCompact { get; set; } = false;
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _wrapperClass => CssClassBuilder
        .Create("gns-table-wrapper")
        .AddClass("gns-table-wrapper--loading", IsLoading)
        .AddClass(AdditionalCssClass)
        .Build();

    private string _tableClass => CssClassBuilder
        .Create("gns-table")
        .AddClass("gns-table--striped",   IsStriped)
        .AddClass("gns-table--hoverable", IsHoverable)
        .AddClass("gns-table--compact",   IsCompact)
        .Build();
}
