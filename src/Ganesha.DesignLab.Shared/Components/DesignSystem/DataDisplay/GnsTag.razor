@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.DataDisplay
@using Ganesha.DesignLab.Shared.Extensions

<span class="@_cssClass">
    <span class="gns-tag__label">@Label</span>
    @if (IsRemovable)
    {
        <button
            type="button"
            class="gns-tag__remove"
            aria-label="Remove @Label"
            @onclick="HandleRemove">
            <svg class="gns-tag__remove-icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
        </button>
    }
</span>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public TagVariant Variant { get; set; } = TagVariant.Default;
    [Parameter] public bool IsRemovable { get; set; } = false;
    [Parameter] public EventCallback OnRemove { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-tag")
        .AddClass("gns-tag--default",  Variant == TagVariant.Default)
        .AddClass("gns-tag--primary",  Variant == TagVariant.Primary)
        .AddClass("gns-tag--success",  Variant == TagVariant.Success)
        .AddClass("gns-tag--warning",  Variant == TagVariant.Warning)
        .AddClass("gns-tag--danger",   Variant == TagVariant.Danger)
        .AddClass("gns-tag--info",     Variant == TagVariant.Info)
        .AddClass("gns-tag--outline",  Variant == TagVariant.Outline)
        .AddClass("gns-tag--removable", IsRemovable)
        .AddClass(AdditionalCssClass)
        .Build();

    private async Task HandleRemove()
    {
        if (OnRemove.HasDelegate)
            await OnRemove.InvokeAsync();
    }
}
