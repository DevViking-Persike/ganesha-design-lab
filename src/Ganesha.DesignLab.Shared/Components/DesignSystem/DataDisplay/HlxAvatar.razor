@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.DataDisplay
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="img" aria-label="@_ariaLabel" title="@_ariaLabel">
    @if (!string.IsNullOrEmpty(Src) && !_imgError)
    {
        <img
            class="gns-avatar__img"
            src="@Src"
            alt="@(Alt ?? string.Empty)"
            @onerror="HandleImageError" />
    }
    else if (!string.IsNullOrEmpty(Initials))
    {
        <span class="gns-avatar__initials" aria-hidden="true">@_truncatedInitials</span>
    }
    else
    {
        <svg class="gns-avatar__fallback-icon" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 12C14.7614 12 17 9.76142 17 7C17 4.23858 14.7614 2 12 2C9.23858 2 7 4.23858 7 7C7 9.76142 9.23858 12 12 12Z"/>
            <path d="M12 14C6.47715 14 2 17.1863 2 21C2 21.5523 2.44772 22 3 22H21C21.5523 22 22 21.5523 22 21C22 17.1863 17.5228 14 12 14Z"/>
        </svg>
    }
</div>

@code {
    [Parameter] public string? Src { get; set; }
    [Parameter] public string? Alt { get; set; }
    [Parameter] public string? Initials { get; set; }
    [Parameter] public AvatarSize Size { get; set; } = AvatarSize.Medium;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private bool _imgError = false;

    private string _truncatedInitials => string.IsNullOrEmpty(Initials)
        ? string.Empty
        : Initials.Length > 2 ? Initials[..2].ToUpperInvariant() : Initials.ToUpperInvariant();

    private string _ariaLabel => Alt ?? Initials ?? "User avatar";

    private string _cssClass => CssClassBuilder
        .Create("gns-avatar")
        .AddClass("gns-avatar--sm",     Size == AvatarSize.Small)
        .AddClass("gns-avatar--md",     Size == AvatarSize.Medium)
        .AddClass("gns-avatar--lg",     Size == AvatarSize.Large)
        .AddClass("gns-avatar--xl",     Size == AvatarSize.XLarge)
        .AddClass("gns-avatar--image",  !string.IsNullOrEmpty(Src) && !_imgError)
        .AddClass("gns-avatar--initials", (string.IsNullOrEmpty(Src) || _imgError) && !string.IsNullOrEmpty(Initials))
        .AddClass(AdditionalCssClass)
        .Build();

    private void HandleImageError()
    {
        _imgError = true;
    }
}
