@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.DataDisplay
@using Ganesha.DesignLab.Shared.Extensions

<article class="@_cssClass" aria-label="@Title statistic">
    <div class="gns-stat-card__header">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <span class="gns-stat-card__icon @Icon" aria-hidden="true"></span>
        }
        <span class="gns-stat-card__title">@Title</span>
    </div>

    <div class="gns-stat-card__body">
        <span class="gns-stat-card__value">@Value</span>

        @if (!string.IsNullOrEmpty(Trend))
        {
            <span class="@_trendClass" aria-label="Trend: @Trend">
                @if (TrendDirection == TrendDirection.Up)
                {
                    <svg class="gns-stat-card__trend-icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8 3L13 8H9.5V13H6.5V8H3L8 3Z" fill="currentColor"/>
                    </svg>
                }
                else if (TrendDirection == TrendDirection.Down)
                {
                    <svg class="gns-stat-card__trend-icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8 13L3 8H6.5V3H9.5V8H13L8 13Z" fill="currentColor"/>
                    </svg>
                }
                else
                {
                    <svg class="gns-stat-card__trend-icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M2 8H14M10 4L14 8L10 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                }
                <span class="gns-stat-card__trend-value">@Trend</span>
            </span>
        }
    </div>

    @if (!string.IsNullOrEmpty(Description))
    {
        <p class="gns-stat-card__description">@Description</p>
    }
</article>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Trend { get; set; }
    [Parameter] public TrendDirection TrendDirection { get; set; } = TrendDirection.Neutral;
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-stat-card")
        .AddClass(AdditionalCssClass)
        .Build();

    private string _trendClass => CssClassBuilder
        .Create("gns-stat-card__trend")
        .AddClass("gns-stat-card__trend--up",      TrendDirection == TrendDirection.Up)
        .AddClass("gns-stat-card__trend--down",    TrendDirection == TrendDirection.Down)
        .AddClass("gns-stat-card__trend--neutral", TrendDirection == TrendDirection.Neutral)
        .Build();
}
