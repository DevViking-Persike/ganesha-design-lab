@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Feedback
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="status" aria-label="@(Label ?? "Loading")">
    <span class="gns-svg-loader__art" aria-hidden="true" style="aspect-ratio: @AspectRatio;">
        <span class="gns-svg-loader__bg" style="@_maskStyle"></span>
        <span class="gns-svg-loader__fill" style="@_maskStyle"></span>
    </span>
    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="gns-svg-loader__label">@Label</span>
    }
    <span class="gns-sr-only">@(Label ?? "Loading…")</span>
</div>

@code {
    [Parameter] public LoaderSize Size { get; set; } = LoaderSize.Medium;
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }
    [Parameter] public string AssetPath { get; set; } = "_content/Ganesha.DesignLab.Shared/assets/loaders/loader-ganesha-a.svg";
    [Parameter] public string AspectRatio { get; set; } = "2816 / 1536";

    private string _cssClass => CssClassBuilder
        .Create("gns-svg-loader")
        .AddClass("gns-svg-loader--sm", Size == LoaderSize.Small)
        .AddClass("gns-svg-loader--md", Size == LoaderSize.Medium)
        .AddClass("gns-svg-loader--lg", Size == LoaderSize.Large)
        .AddClass(AdditionalCssClass)
        .Build();

    private string _maskStyle =>
        $"-webkit-mask-image:url('{AssetPath}');mask-image:url('{AssetPath}');-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;-webkit-mask-position:center;mask-position:center;-webkit-mask-size:contain;mask-size:contain;";
}
