@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Feedback
@using Ganesha.DesignLab.Shared.Abstractions.Services
@using Ganesha.DesignLab.Shared.Models.Feedback
@using Ganesha.DesignLab.Shared.Extensions
@inject IToastService ToastService
@implements IDisposable

<div class="@_containerClass" aria-label="Notifications" aria-live="polite">
    @foreach (var toast in _toasts)
    {
        <GnsToastItem
            key="@toast.Id"
            Toast="@toast"
            OnDismiss="HandleDismiss" />
    }
</div>

@code {
    [Parameter] public ToastPosition Position { get; set; } = ToastPosition.TopRight;

    private List<ToastMessage> _toasts = [];

    private string _containerClass => CssClassBuilder
        .Create("gns-toast-container")
        .AddClass("gns-toast-container--top-right",     Position == ToastPosition.TopRight)
        .AddClass("gns-toast-container--top-left",      Position == ToastPosition.TopLeft)
        .AddClass("gns-toast-container--bottom-right",  Position == ToastPosition.BottomRight)
        .AddClass("gns-toast-container--bottom-left",   Position == ToastPosition.BottomLeft)
        .AddClass("gns-toast-container--top-center",    Position == ToastPosition.TopCenter)
        .AddClass("gns-toast-container--bottom-center", Position == ToastPosition.BottomCenter)
        .Build();

    protected override void OnInitialized()
    {
        ToastService.OnToastAdded += HandleToastAdded;
        _toasts = [.. ToastService.GetActiveToasts()];
    }

    private void HandleToastAdded(ToastMessage toast)
    {
        InvokeAsync(() =>
        {
            _toasts.Insert(0, toast);
            StateHasChanged();

            if (toast.DurationMs > 0)
            {
                _ = Task.Delay(toast.DurationMs).ContinueWith(_ =>
                {
                    InvokeAsync(() =>
                    {
                        RemoveToast(toast.Id);
                        StateHasChanged();
                    });
                });
            }
        });
    }

    private async Task HandleDismiss(Guid toastId)
    {
        ToastService.DismissToast(toastId);
        RemoveToast(toastId);
        await Task.CompletedTask;
    }

    private void RemoveToast(Guid toastId)
    {
        var toast = _toasts.FirstOrDefault(t => t.Id == toastId);
        if (toast is not null)
            _toasts.Remove(toast);
    }

    public void Dispose()
    {
        ToastService.OnToastAdded -= HandleToastAdded;
    }
}
