@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Feedback
@using Ganesha.DesignLab.Shared.Extensions
@using Ganesha.DesignLab.Shared.Models.Feedback

<div class="@_cssClass" role="alert" aria-live="assertive" aria-atomic="true">
    <span class="gns-toast-item__icon" aria-hidden="true">
        @if (Toast.Severity == ToastSeverity.Success)
        {
            <svg viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
            </svg>
        }
        else if (Toast.Severity == ToastSeverity.Warning)
        {
            <svg viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
            </svg>
        }
        else if (Toast.Severity == ToastSeverity.Error)
        {
            <svg viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/>
            </svg>
        }
        else
        {
            <svg viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd"/>
            </svg>
        }
    </span>

    <div class="gns-toast-item__content">
        @if (!string.IsNullOrEmpty(Toast.Title))
        {
            <p class="gns-toast-item__title">@Toast.Title</p>
        }
        <p class="gns-toast-item__message">@Toast.Message</p>
    </div>

    <button
        type="button"
        class="gns-toast-item__dismiss"
        aria-label="Dismiss notification"
        @onclick="HandleDismiss">
        <svg aria-hidden="true" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
    </button>

    @if (Toast.DurationMs > 0)
    {
        <div
            class="gns-toast-item__progress"
            style="animation-duration: @(Toast.DurationMs)ms"
            aria-hidden="true">
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public ToastMessage Toast { get; set; } = default!;
    [Parameter] public EventCallback<Guid> OnDismiss { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-toast-item")
        .AddClass("gns-toast-item--success", Toast.Severity == ToastSeverity.Success)
        .AddClass("gns-toast-item--warning", Toast.Severity == ToastSeverity.Warning)
        .AddClass("gns-toast-item--error",   Toast.Severity == ToastSeverity.Error)
        .AddClass("gns-toast-item--info",    Toast.Severity == ToastSeverity.Info)
        .Build();

    private async Task HandleDismiss()
    {
        if (OnDismiss.HasDelegate)
            await OnDismiss.InvokeAsync(Toast.Id);
    }
}
