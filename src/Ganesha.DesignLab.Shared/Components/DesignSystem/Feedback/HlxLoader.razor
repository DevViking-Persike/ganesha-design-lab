@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Feedback
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" role="status" aria-label="@(Label ?? "Loading")">
    <span class="gns-loader__spinner" aria-hidden="true"></span>
    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="gns-loader__label">@Label</span>
    }
    <span class="gns-sr-only">@(Label ?? "Loading…")</span>
</div>

@code {
    [Parameter] public LoaderSize Size { get; set; } = LoaderSize.Medium;
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-loader")
        .AddClass("gns-loader--sm", Size == LoaderSize.Small)
        .AddClass("gns-loader--md", Size == LoaderSize.Medium)
        .AddClass("gns-loader--lg", Size == LoaderSize.Large)
        .AddClass(AdditionalCssClass)
        .Build();
}
