@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Form
@using Ganesha.DesignLab.Shared.Extensions

<label class="@_cssClass">
    <span class="gns-radio-option__control">
        <input
            type="radio"
            class="gns-radio-option__input"
            name="@_groupName"
            value="@Value"
            checked="@_isChecked"
            disabled="@_isDisabled"
            aria-checked="@_isChecked.ToString().ToLower()"
            aria-disabled="@_isDisabled.ToString().ToLower()"
            @onchange="HandleChange" />
        <span class="gns-radio-option__circle" aria-hidden="true">
            <span class="gns-radio-option__dot"></span>
        </span>
    </span>

    <span class="gns-radio-option__label">@Label</span>
</label>

@code {
    [CascadingParameter] private GnsRadioGroup? Group { get; set; }

    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public bool IsDisabled { get; set; } = false;

    private bool _isChecked   => Group?.Value == Value;
    private bool _isDisabled  => IsDisabled || (Group?.IsDisabled ?? false);
    private string _groupName => Group?.Name ?? $"gns-radio-ungrouped-{Value}";

    private string _cssClass => CssClassBuilder
        .Create("gns-radio-option")
        .AddClass("gns-radio-option--checked",  _isChecked)
        .AddClass("gns-radio-option--disabled", _isDisabled)
        .Build();

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (_isDisabled) return;
        if (Group is not null)
            await Group.SelectOption(Value);
    }
}
