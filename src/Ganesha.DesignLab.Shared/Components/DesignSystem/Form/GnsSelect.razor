@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Form
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_wrapperClass">

    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="gns-select__label" for="@_selectId">
            @Label
            @if (IsRequired)
            {
                <span class="gns-select__required" aria-hidden="true">*</span>
            }
        </label>
    }

    <div class="gns-select__control">
        <select
            id="@_selectId"
            class="@_selectClass"
            value="@Value"
            disabled="@IsDisabled"
            required="@IsRequired"
            aria-required="@IsRequired.ToString().ToLower()"
            aria-invalid="@(!string.IsNullOrEmpty(ErrorMessage)).ToString().ToLower()"
            aria-describedby="@_describedBy"
            @onchange="HandleChange">

            @if (!string.IsNullOrEmpty(Placeholder))
            {
                <option value="" disabled selected="@(string.IsNullOrEmpty(Value))">@Placeholder</option>
            }

            @ChildContent
        </select>

        <span class="gns-select__chevron" aria-hidden="true">
            <span class="gns-select__chevron-icon"></span>
        </span>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <span id="@_errorId" class="gns-select__error" role="alert">
            @ErrorMessage
        </span>
    }
    else if (!string.IsNullOrEmpty(HelperText))
    {
        <span id="@_helperId" class="gns-select__helper">
            @HelperText
        </span>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public bool IsRequired { get; set; } = false;
    [Parameter] public bool IsDisabled { get; set; } = false;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private readonly string _selectId = $"gns-select-{Guid.NewGuid():N}";
    private string _errorId  => $"{_selectId}-error";
    private string _helperId => $"{_selectId}-helper";

    private string? _describedBy
    {
        get
        {
            if (!string.IsNullOrEmpty(ErrorMessage)) return _errorId;
            if (!string.IsNullOrEmpty(HelperText))   return _helperId;
            return null;
        }
    }

    private bool HasError => !string.IsNullOrEmpty(ErrorMessage);

    private string _wrapperClass => CssClassBuilder
        .Create("gns-select")
        .AddClass("gns-select--error",    HasError)
        .AddClass("gns-select--disabled", IsDisabled)
        .AddClass(AdditionalCssClass)
        .Build();

    private string _selectClass => CssClassBuilder
        .Create("gns-select__field")
        .AddClass("gns-select__field--error", HasError)
        .Build();

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (IsDisabled) return;
        await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }
}
