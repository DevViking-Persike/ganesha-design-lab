@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Form
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_wrapperClass">

    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="gns-textarea__label" for="@_textareaId">
            @Label
            @if (IsRequired)
            {
                <span class="gns-textarea__required" aria-hidden="true">*</span>
            }
        </label>
    }

    <textarea
        id="@_textareaId"
        class="@_textareaClass"
        rows="@Rows"
        placeholder="@Placeholder"
        disabled="@IsDisabled"
        required="@IsRequired"
        aria-required="@IsRequired.ToString().ToLower()"
        aria-invalid="@(!string.IsNullOrEmpty(ErrorMessage)).ToString().ToLower()"
        aria-describedby="@_describedBy"
        @oninput="HandleInput">@Value</textarea>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <span id="@_errorId" class="gns-textarea__error" role="alert">
            @ErrorMessage
        </span>
    }
    else if (!string.IsNullOrEmpty(HelperText))
    {
        <span id="@_helperId" class="gns-textarea__helper">
            @HelperText
        </span>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public int Rows { get; set; } = 3;
    [Parameter] public bool IsRequired { get; set; } = false;
    [Parameter] public bool IsDisabled { get; set; } = false;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private readonly string _textareaId = $"gns-textarea-{Guid.NewGuid():N}";
    private string _errorId  => $"{_textareaId}-error";
    private string _helperId => $"{_textareaId}-helper";

    private string? _describedBy
    {
        get
        {
            if (!string.IsNullOrEmpty(ErrorMessage)) return _errorId;
            if (!string.IsNullOrEmpty(HelperText))   return _helperId;
            return null;
        }
    }

    private bool HasError => !string.IsNullOrEmpty(ErrorMessage);

    private string _wrapperClass => CssClassBuilder
        .Create("gns-textarea")
        .AddClass("gns-textarea--error",    HasError)
        .AddClass("gns-textarea--disabled", IsDisabled)
        .AddClass(AdditionalCssClass)
        .Build();

    private string _textareaClass => CssClassBuilder
        .Create("gns-textarea__field")
        .AddClass("gns-textarea__field--error", HasError)
        .Build();

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (IsDisabled) return;
        await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }
}
