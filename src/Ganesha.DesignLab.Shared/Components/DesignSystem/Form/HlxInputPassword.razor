@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Form
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_wrapperClass">

    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="gns-input-password__label" for="@_inputId">
            @Label
            @if (IsRequired)
            {
                <span class="gns-input-password__required" aria-hidden="true">*</span>
            }
        </label>
    }

    <div class="gns-input-password__control">
        @if (!string.IsNullOrEmpty(IconLeft))
        {
            <span class="gns-input-password__icon gns-input-password__icon--left @IconLeft" aria-hidden="true"></span>
        }

        <input
            id="@_inputId"
            type="@_inputType"
            class="@_inputClass"
            value="@Value"
            placeholder="@Placeholder"
            disabled="@IsDisabled"
            readonly="@IsReadOnly"
            required="@IsRequired"
            aria-required="@IsRequired.ToString().ToLower()"
            aria-invalid="@(!string.IsNullOrEmpty(ErrorMessage)).ToString().ToLower()"
            aria-describedby="@_describedBy"
            @oninput="HandleInput" />

        @if (ShowToggle)
        {
            <button
                type="button"
                class="gns-input-password__toggle"
                tabindex="@(IsDisabled ? -1 : 0)"
                aria-label="@(_isVisible ? "Hide password" : "Show password")"
                aria-pressed="@_isVisible.ToString().ToLower()"
                disabled="@IsDisabled"
                @onclick="ToggleVisibility">
                <span class="@_toggleIconClass" aria-hidden="true"></span>
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <span id="@_errorId" class="gns-input-password__error" role="alert">
            @ErrorMessage
        </span>
    }
    else if (!string.IsNullOrEmpty(HelperText))
    {
        <span id="@_helperId" class="gns-input-password__helper">
            @HelperText
        </span>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public bool IsRequired { get; set; } = false;
    [Parameter] public bool IsDisabled { get; set; } = false;
    [Parameter] public bool IsReadOnly { get; set; } = false;
    [Parameter] public InputSize Size { get; set; } = InputSize.Medium;
    [Parameter] public string? IconLeft { get; set; }
    [Parameter] public bool ShowToggle { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private bool _isVisible = false;

    private readonly string _inputId = $"gns-input-pw-{Guid.NewGuid():N}";
    private string _errorId  => $"{_inputId}-error";
    private string _helperId => $"{_inputId}-helper";

    private string _inputType => _isVisible ? "text" : "password";

    private string? _describedBy
    {
        get
        {
            if (!string.IsNullOrEmpty(ErrorMessage)) return _errorId;
            if (!string.IsNullOrEmpty(HelperText))   return _helperId;
            return null;
        }
    }

    private bool HasError => !string.IsNullOrEmpty(ErrorMessage);

    private string _wrapperClass => CssClassBuilder
        .Create("gns-input-password")
        .AddClass("gns-input-password--sm",        Size == InputSize.Small)
        .AddClass("gns-input-password--md",        Size == InputSize.Medium)
        .AddClass("gns-input-password--lg",        Size == InputSize.Large)
        .AddClass("gns-input-password--error",     HasError)
        .AddClass("gns-input-password--disabled",  IsDisabled)
        .AddClass("gns-input-password--readonly",  IsReadOnly)
        .AddClass("gns-input-password--icon-left", !string.IsNullOrEmpty(IconLeft))
        .AddClass(AdditionalCssClass)
        .Build();

    private string _inputClass => CssClassBuilder
        .Create("gns-input-password__field")
        .AddClass("gns-input-password__field--error", HasError)
        .AddClass("gns-input-password__field--has-toggle", ShowToggle)
        .Build();

    // Shows an eye icon (using a unicode fallback — projects will swap with icon font classes)
    private string _toggleIconClass => _isVisible
        ? "gns-input-password__toggle-icon gns-input-password__toggle-icon--hide"
        : "gns-input-password__toggle-icon gns-input-password__toggle-icon--show";

    private void ToggleVisibility()
    {
        if (!IsDisabled) _isVisible = !_isVisible;
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (IsDisabled || IsReadOnly) return;
        await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }
}
