@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Form
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_wrapperClass">

    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="gns-input-text__label" for="@_inputId">
            @Label
            @if (IsRequired)
            {
                <span class="gns-input-text__required" aria-hidden="true">*</span>
            }
        </label>
    }

    <div class="gns-input-text__control">
        @if (!string.IsNullOrEmpty(IconLeft))
        {
            <span class="gns-input-text__icon gns-input-text__icon--left @IconLeft" aria-hidden="true"></span>
        }

        <input
            id="@_inputId"
            type="@Type"
            class="@_inputClass"
            value="@Value"
            placeholder="@Placeholder"
            disabled="@IsDisabled"
            readonly="@IsReadOnly"
            required="@IsRequired"
            aria-required="@IsRequired.ToString().ToLower()"
            aria-invalid="@(!string.IsNullOrEmpty(ErrorMessage)).ToString().ToLower()"
            aria-describedby="@_describedBy"
            @oninput="HandleInput" />
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <span id="@_errorId" class="gns-input-text__error" role="alert">
            @ErrorMessage
        </span>
    }
    else if (!string.IsNullOrEmpty(HelperText))
    {
        <span id="@_helperId" class="gns-input-text__helper">
            @HelperText
        </span>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public bool IsRequired { get; set; } = false;
    [Parameter] public bool IsDisabled { get; set; } = false;
    [Parameter] public bool IsReadOnly { get; set; } = false;
    [Parameter] public InputSize Size { get; set; } = InputSize.Medium;
    [Parameter] public string? IconLeft { get; set; }
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public string? AdditionalCssClass { get; set; }

    private readonly string _inputId   = $"gns-input-{Guid.NewGuid():N}";
    private string _errorId   => $"{_inputId}-error";
    private string _helperId  => $"{_inputId}-helper";

    private string? _describedBy
    {
        get
        {
            if (!string.IsNullOrEmpty(ErrorMessage))  return _errorId;
            if (!string.IsNullOrEmpty(HelperText))    return _helperId;
            return null;
        }
    }

    private bool HasError => !string.IsNullOrEmpty(ErrorMessage);

    private string _wrapperClass => CssClassBuilder
        .Create("gns-input-text")
        .AddClass("gns-input-text--sm",       Size == InputSize.Small)
        .AddClass("gns-input-text--md",       Size == InputSize.Medium)
        .AddClass("gns-input-text--lg",       Size == InputSize.Large)
        .AddClass("gns-input-text--error",    HasError)
        .AddClass("gns-input-text--disabled", IsDisabled)
        .AddClass("gns-input-text--readonly", IsReadOnly)
        .AddClass("gns-input-text--icon-left", !string.IsNullOrEmpty(IconLeft))
        .AddClass(AdditionalCssClass)
        .Build();

    private string _inputClass => CssClassBuilder
        .Create("gns-input-text__field")
        .AddClass("gns-input-text__field--error", HasError)
        .Build();

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (IsDisabled || IsReadOnly) return;
        await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }
}
