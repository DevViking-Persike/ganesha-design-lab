@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Layout
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass" style="@_style">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public int Columns { get; set; } = 12;
    [Parameter] public string Gap { get; set; } = "4";
    [Parameter] public string? TemplateColumns { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-grid")
        .AddClass(AdditionalCssClass)
        .Build();

    private string _style
    {
        get
        {
            var gridTemplate = !string.IsNullOrEmpty(TemplateColumns)
                ? TemplateColumns
                : $"repeat({Columns}, minmax(0, 1fr))";

            return $"grid-template-columns: {gridTemplate}; gap: var(--gns-space-{Gap});";
        }
    }
}
