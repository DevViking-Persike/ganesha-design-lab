@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Layout
@using Ganesha.DesignLab.Shared.Extensions
@using Ganesha.DesignLab.Shared.Models.Layout

<div class="@_cssClass" style="@_style">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public StackDirection Direction { get; set; } = StackDirection.Vertical;
    [Parameter] public string Gap { get; set; } = "4";
    [Parameter] public ContentAlignment Align { get; set; } = ContentAlignment.Stretch;
    [Parameter] public bool Wrap { get; set; } = false;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private string _cssClass => CssClassBuilder
        .Create("gns-stack")
        .AddClass("gns-stack--horizontal", Direction == StackDirection.Horizontal)
        .AddClass("gns-stack--vertical",   Direction == StackDirection.Vertical)
        .AddClass("gns-stack--wrap",       Wrap)
        .AddClass($"gns-stack--align-{AlignClass}", true)
        .AddClass(AdditionalCssClass)
        .Build();

    private string AlignClass => Align switch
    {
        ContentAlignment.Start        => "start",
        ContentAlignment.Center       => "center",
        ContentAlignment.End          => "end",
        ContentAlignment.SpaceBetween => "between",
        _                             => "stretch"
    };

    private string _style => $"gap: var(--gns-space-{Gap});";
}
