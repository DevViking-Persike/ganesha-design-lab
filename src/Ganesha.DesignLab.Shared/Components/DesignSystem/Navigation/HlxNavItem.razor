@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Navigation
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass">
    @if (!string.IsNullOrEmpty(Href) && !HasChildren)
    {
        <a class="gns-nav-item__trigger" href="@Href" aria-current="@(IsActive ? "page" : null)">
            @RenderTriggerContent()
        </a>
    }
    else
    {
        <button
            type="button"
            class="gns-nav-item__trigger"
            aria-expanded="@(HasChildren ? _expanded.ToString().ToLower() : null)"
            aria-current="@(IsActive ? "page" : null)"
            @onclick="HandleClick">
            @RenderTriggerContent()
        </button>
    }

    @if (HasChildren && _expanded)
    {
        <div class="gns-nav-item__children" role="group">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public bool IsActive { get; set; } = false;
    [Parameter] public bool IsExpanded { get; set; } = false;
    [Parameter] public string? Badge { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private bool _expanded;

    private bool HasChildren => ChildContent is not null;

    protected override void OnParametersSet()
    {
        _expanded = IsExpanded;
    }

    private string _cssClass => CssClassBuilder
        .Create("gns-nav-item")
        .AddClass("gns-nav-item--active", IsActive)
        .AddClass("gns-nav-item--expanded", HasChildren && _expanded)
        .AddClass("gns-nav-item--has-children", HasChildren)
        .AddClass(AdditionalCssClass)
        .Build();

    private async Task HandleClick()
    {
        if (HasChildren)
            _expanded = !_expanded;

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync();
    }

    private RenderFragment RenderTriggerContent() => __builder =>
    {
        if (!string.IsNullOrEmpty(Icon))
        {
            __builder.OpenElement(0, "span");
            __builder.AddAttribute(1, "class", $"gns-nav-item__icon {Icon}");
            __builder.AddAttribute(2, "aria-hidden", "true");
            __builder.CloseElement();
        }

        __builder.OpenElement(3, "span");
        __builder.AddAttribute(4, "class", "gns-nav-item__label");
        __builder.AddContent(5, Label);
        __builder.CloseElement();

        if (!string.IsNullOrEmpty(Badge))
        {
            __builder.OpenElement(6, "span");
            __builder.AddAttribute(7, "class", "gns-nav-item__badge");
            __builder.AddContent(8, Badge);
            __builder.CloseElement();
        }

        if (HasChildren)
        {
            __builder.OpenElement(9, "span");
            __builder.AddAttribute(10, "class", "gns-nav-item__chevron");
            __builder.AddAttribute(11, "aria-hidden", "true");
            __builder.CloseElement();
        }
    };
}
