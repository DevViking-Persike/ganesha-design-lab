@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Navigation
@using Ganesha.DesignLab.Shared.Extensions

<nav class="@_cssClass" aria-label="Pagination">
    <ul class="gns-pagination__list">

        @if (ShowFirstLast)
        {
            <li class="gns-pagination__item">
                <button
                    type="button"
                    class="@GetPageButtonClass("first")"
                    disabled="@(CurrentPage <= 1)"
                    aria-label="First page"
                    @onclick="() => GoToPage(1)">
                    <span aria-hidden="true">&laquo;</span>
                </button>
            </li>
        }

        <li class="gns-pagination__item">
            <button
                type="button"
                class="@GetPageButtonClass("prev")"
                disabled="@(CurrentPage <= 1)"
                aria-label="Previous page"
                @onclick="() => GoToPage(CurrentPage - 1)">
                <span aria-hidden="true">&lsaquo;</span>
            </button>
        </li>

        @foreach (var page in _visiblePages)
        {
            @if (page == -1)
            {
                <li class="gns-pagination__item gns-pagination__item--ellipsis" aria-hidden="true">
                    <span class="gns-pagination__ellipsis">&hellip;</span>
                </li>
            }
            else
            {
                <li class="gns-pagination__item">
                    <button
                        type="button"
                        class="@GetNumberButtonClass(page)"
                        aria-label="@($"Page {page}")"
                        aria-current="@(page == CurrentPage ? "page" : null)"
                        @onclick="() => GoToPage(page)">
                        @(page)
                    </button>
                </li>
            }
        }

        <li class="gns-pagination__item">
            <button
                type="button"
                class="@GetPageButtonClass("next")"
                disabled="@(CurrentPage >= TotalPages)"
                aria-label="Next page"
                @onclick="() => GoToPage(CurrentPage + 1)">
                <span aria-hidden="true">&rsaquo;</span>
            </button>
        </li>

        @if (ShowFirstLast)
        {
            <li class="gns-pagination__item">
                <button
                    type="button"
                    class="@GetPageButtonClass("last")"
                    disabled="@(CurrentPage >= TotalPages)"
                    aria-label="Last page"
                    @onclick="() => GoToPage(TotalPages)">
                    <span aria-hidden="true">&raquo;</span>
                </button>
            </li>
        }
    </ul>
</nav>

@code {
    [Parameter] public int CurrentPage { get; set; }
    [Parameter] public int TotalPages { get; set; }
    [Parameter] public EventCallback<int> CurrentPageChanged { get; set; }
    [Parameter] public int MaxVisiblePages { get; set; } = 5;
    [Parameter] public bool ShowFirstLast { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private IEnumerable<int> _visiblePages => BuildVisiblePages();

    private string _cssClass => CssClassBuilder
        .Create("gns-pagination")
        .AddClass(AdditionalCssClass)
        .Build();

    private IEnumerable<int> BuildVisiblePages()
    {
        if (TotalPages <= MaxVisiblePages)
            return Enumerable.Range(1, TotalPages);

        var pages = new List<int>();
        var half = MaxVisiblePages / 2;
        var start = Math.Max(1, CurrentPage - half);
        var end = Math.Min(TotalPages, start + MaxVisiblePages - 1);

        if (end == TotalPages)
            start = Math.Max(1, end - MaxVisiblePages + 1);

        if (start > 1)
        {
            pages.Add(1);
            if (start > 2) pages.Add(-1);
        }

        for (var i = start; i <= end; i++)
            pages.Add(i);

        if (end < TotalPages)
        {
            if (end < TotalPages - 1) pages.Add(-1);
            pages.Add(TotalPages);
        }

        return pages;
    }

    private string GetPageButtonClass(string type) => CssClassBuilder
        .Create("gns-pagination__btn")
        .AddClass($"gns-pagination__btn--{type}")
        .Build();

    private string GetNumberButtonClass(int page) => CssClassBuilder
        .Create("gns-pagination__btn")
        .AddClass("gns-pagination__btn--number")
        .AddClass("gns-pagination__btn--active", page == CurrentPage)
        .Build();

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > TotalPages || page == CurrentPage) return;
        await CurrentPageChanged.InvokeAsync(page);
    }
}
