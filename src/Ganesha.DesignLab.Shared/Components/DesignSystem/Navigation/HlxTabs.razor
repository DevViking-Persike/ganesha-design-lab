@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Navigation
@using Ganesha.DesignLab.Shared.Extensions

<CascadingValue Value="this">
    <div class="@_cssClass">
        @* Render ChildContent first to collect tab registrations *@
        <div style="display:none" aria-hidden="true">@ChildContent</div>

        <div class="gns-tabs__strip" role="tablist" aria-label="Tabs">
            @foreach (var tab in _tabs)
            {
                <button
                    type="button"
                    class="@GetTabClass(tab)"
                    role="tab"
                    aria-selected="@(IsTabActive(tab).ToString().ToLower())"
                    aria-disabled="@(tab.IsDisabled.ToString().ToLower())"
                    tabindex="@(IsTabActive(tab) ? 0 : -1)"
                    disabled="@(tab.IsDisabled ? true : (object?)null)"
                    @onclick="() => HandleTabClick(tab)">

                    @if (!string.IsNullOrEmpty(tab.Icon))
                    {
                        <span class="gns-tab__icon @tab.Icon" aria-hidden="true"></span>
                    }
                    <span class="gns-tab__title">@tab.Title</span>
                </button>
            }
        </div>

        <div class="gns-tabs__panels">
            @foreach (var tab in _tabs)
            {
                @if (IsTabActive(tab))
                {
                    <div class="gns-tab__panel" role="tabpanel">
                        @tab.ChildContent
                    </div>
                }
            }
        </div>
    </div>
</CascadingValue>

@code {
    [Parameter] public int ActiveIndex { get; set; } = 0;
    [Parameter] public EventCallback<int> ActiveIndexChanged { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private readonly List<HlxTab> _tabs = [];

    private string _cssClass => CssClassBuilder
        .Create("gns-tabs")
        .AddClass(AdditionalCssClass)
        .Build();

    private bool IsTabActive(HlxTab tab) => _tabs.IndexOf(tab) == ActiveIndex;

    private string GetTabClass(HlxTab tab) => CssClassBuilder
        .Create("gns-tab")
        .AddClass("gns-tab--active",   IsTabActive(tab))
        .AddClass("gns-tab--disabled", tab.IsDisabled)
        .Build();

    internal void RegisterTab(HlxTab tab)
    {
        if (!_tabs.Contains(tab))
        {
            _tabs.Add(tab);
            StateHasChanged();
        }
    }

    internal async Task SetActiveIndex(int index)
    {
        ActiveIndex = index;
        await ActiveIndexChanged.InvokeAsync(index);
        StateHasChanged();
    }

    private async Task HandleTabClick(HlxTab tab)
    {
        if (!tab.IsDisabled)
            await SetActiveIndex(_tabs.IndexOf(tab));
    }
}
