@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Overlay
@using Ganesha.DesignLab.Shared.Extensions
@using Ganesha.DesignLab.Shared.Models.Feedback

@if (IsOpen)
{
    <div
        class="gns-drawer-backdrop"
        role="presentation"
        @onclick="HandleBackdropClick"
        aria-hidden="true">
    </div>

    <div
        class="@_cssClass"
        style="@_widthStyle"
        role="dialog"
        aria-modal="true"
        aria-labelledby="@_titleId"
        tabindex="-1">

        @if (!string.IsNullOrEmpty(Title) || ShowCloseButton)
        {
            <div class="gns-drawer__header">
                @if (!string.IsNullOrEmpty(Title))
                {
                    <h2 class="gns-drawer__title" id="@_titleId">@Title</h2>
                }
                @if (ShowCloseButton)
                {
                    <button
                        type="button"
                        class="gns-drawer__close"
                        aria-label="Close panel"
                        @onclick="CloseDrawer">
                        <span aria-hidden="true">&times;</span>
                    </button>
                }
            </div>
        }

        <div class="gns-drawer__body">
            @ChildContent
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public DrawerPosition Position { get; set; } = DrawerPosition.Right;
    [Parameter] public string Width { get; set; } = "400px";
    [Parameter] public bool ShowCloseButton { get; set; } = true;
    [Parameter] public bool CloseOnBackdropClick { get; set; } = true;
    [Parameter] public string? AdditionalCssClass { get; set; }

    private readonly string _titleId = $"drawer-title-{Guid.NewGuid():N}";

    private string _cssClass => CssClassBuilder
        .Create("gns-drawer")
        .AddClass("gns-drawer--left",  Position == DrawerPosition.Left)
        .AddClass("gns-drawer--right", Position == DrawerPosition.Right)
        .AddClass(AdditionalCssClass)
        .Build();

    private string _widthStyle => Position switch
    {
        DrawerPosition.Left  => $"width: {Width}; max-width: 100vw;",
        DrawerPosition.Right => $"width: {Width}; max-width: 100vw;",
        _ => $"width: {Width}; max-width: 100vw;"
    };

    private async Task CloseDrawer()
    {
        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task HandleBackdropClick()
    {
        if (CloseOnBackdropClick)
            await CloseDrawer();
    }
}
