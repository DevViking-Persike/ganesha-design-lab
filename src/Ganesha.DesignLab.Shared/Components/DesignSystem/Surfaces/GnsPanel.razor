@namespace Ganesha.DesignLab.Shared.Components.DesignSystem.Surfaces
@using Ganesha.DesignLab.Shared.Extensions

<div class="@_cssClass">
    @if (!string.IsNullOrEmpty(Title) || Actions is not null || IsCollapsible)
    {
        <div class="gns-panel__header">
            <div class="gns-panel__header-left">
                @if (IsCollapsible)
                {
                    <button
                        type="button"
                        class="gns-panel__toggle"
                        aria-expanded="@((!_collapsed).ToString().ToLower())"
                        aria-label="@(_collapsed ? "Expand panel" : "Collapse panel")"
                        @onclick="ToggleCollapse">
                        <span class="gns-panel__chevron" aria-hidden="true"></span>
                    </button>
                }
                @if (!string.IsNullOrEmpty(Title))
                {
                    <span class="gns-panel__title">@Title</span>
                }
            </div>
            @if (Actions is not null)
            {
                <div class="gns-panel__actions">
                    @Actions
                </div>
            }
        </div>
    }

    <div class="@_bodyClass">
        <div class="gns-panel__body-inner">
            @ChildContent
        </div>
    </div>
</div>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public bool IsCollapsible { get; set; } = false;
    [Parameter] public bool IsCollapsed { get; set; } = false;
    [Parameter] public EventCallback<bool> IsCollapsedChanged { get; set; }
    [Parameter] public string? AdditionalCssClass { get; set; }

    private bool _collapsed;

    protected override void OnParametersSet()
    {
        _collapsed = IsCollapsed;
    }

    private string _cssClass => CssClassBuilder
        .Create("gns-panel")
        .AddClass("gns-panel--collapsible", IsCollapsible)
        .AddClass("gns-panel--collapsed", IsCollapsible && _collapsed)
        .AddClass(AdditionalCssClass)
        .Build();

    private string _bodyClass => CssClassBuilder
        .Create("gns-panel__body")
        .AddClass("gns-panel__body--hidden", IsCollapsible && _collapsed)
        .Build();

    private async Task ToggleCollapse()
    {
        _collapsed = !_collapsed;
        await IsCollapsedChanged.InvokeAsync(_collapsed);
    }
}
