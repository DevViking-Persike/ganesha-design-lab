@namespace Ganesha.DesignLab.Shared.Components.Infrastructure
@using Ganesha.DesignLab.Shared.Abstractions.Services
@inject IThemeService ThemeService
@implements IDisposable

<div data-theme="@_currentTheme" class="gns-theme-provider">
    @ChildContent
</div>

@code {
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }

    private string _currentTheme = string.Empty;

    protected override void OnInitialized()
    {
        // Capture initial theme into local state so Blazor can diff the attribute.
        _currentTheme = ThemeService.CurrentTheme;
        ThemeService.OnThemeChanged += HandleThemeChanged;
    }

    private void HandleThemeChanged()
    {
        _currentTheme = ThemeService.CurrentTheme;
        // InvokeAsync marshals back to the Blazor sync context from any thread.
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= HandleThemeChanged;
    }
}
