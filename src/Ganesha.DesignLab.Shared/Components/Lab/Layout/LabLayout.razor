@namespace Ganesha.DesignLab.Shared.Components.Lab.Layout
@inherits LayoutComponentBase
@inject IThemeService ThemeService
@implements IDisposable

<GnsThemeProvider>
    <div class="gns-lab-layout">
        <div class="gns-lab-layout__topbar">
            <span style="font-family: var(--gns-font-display); font-size: var(--gns-text-xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary); letter-spacing: var(--gns-tracking-wide);">
                <span style="color: var(--gns-ouro-500);">&#x0950;</span> Ganesha Design Lab
            </span>
            <div style="margin-left: auto; display: flex; align-items: center; gap: var(--gns-space-3);">
                <span style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">
                    @(ThemeService.CurrentTheme == "dark" ? "Dark" : "Light")
                </span>
                <GnsSwitch Value="@_isDarkTheme" ValueChanged="HandleThemeToggle" />
            </div>
        </div>

        <div class="gns-lab-layout__sidebar">
            @* Home *@
            <div class="gns-lab-nav__group">
                <a class="gns-lab-nav__item" href="/lab">Home</a>
            </div>

            @* Foundations *@
            <div class="gns-lab-nav__group">
                <div class="gns-lab-nav__group-label">Foundations</div>
                <a class="gns-lab-nav__item" href="/lab/colors">Colors</a>
                <a class="gns-lab-nav__item" href="/lab/typography">Typography</a>
                <a class="gns-lab-nav__item" href="/lab/spacing">Spacing</a>
                <a class="gns-lab-nav__item" href="/lab/shadows">Shadows</a>
            </div>

            @* Components *@
            <div class="gns-lab-nav__group">
                <div class="gns-lab-nav__group-label">Components</div>
                <a class="gns-lab-nav__item" href="/lab/buttons">Buttons</a>
                <a class="gns-lab-nav__item" href="/lab/forms">Forms</a>
                <a class="gns-lab-nav__item" href="/lab/data-display">Data Display</a>
                <a class="gns-lab-nav__item" href="/lab/feedback">Feedback</a>
                <a class="gns-lab-nav__item" href="/lab/navigation">Navigation</a>
                <a class="gns-lab-nav__item" href="/lab/surfaces">Surfaces</a>
                <a class="gns-lab-nav__item" href="/lab/overlays">Overlays</a>
                <a class="gns-lab-nav__item" href="/lab/charts">Charts</a>
                <a class="gns-lab-nav__item" href="/lab/grid">Grid & Layout</a>
            </div>

            @* Patterns *@
            <div class="gns-lab-nav__group">
                <div class="gns-lab-nav__group-label">Patterns</div>
                <a class="gns-lab-nav__item" href="/lab/dashboard">Dashboard</a>
                <a class="gns-lab-nav__item" href="/lab/table-page">Table Page</a>
                <a class="gns-lab-nav__item" href="/lab/form-page">Form Page</a>
                <a class="gns-lab-nav__item" href="/lab/profile">Profile Page</a>
                <a class="gns-lab-nav__item" href="/lab/auth">Auth Page</a>
            </div>
        </div>

        <div class="gns-lab-layout__content">
            @Body
        </div>
    </div>
</GnsThemeProvider>

<GnsToastContainer />

@code {
    private bool _isDarkTheme;

    protected override void OnInitialized()
    {
        _isDarkTheme = ThemeService.CurrentTheme == "dark";
        ThemeService.OnThemeChanged += HandleThemeChanged;
    }

    private void HandleThemeToggle(bool isDark)
    {
        ThemeService.SetTheme(isDark ? "dark" : "light");
    }

    private void HandleThemeChanged()
    {
        _isDarkTheme = ThemeService.CurrentTheme == "dark";
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= HandleThemeChanged;
    }
}
