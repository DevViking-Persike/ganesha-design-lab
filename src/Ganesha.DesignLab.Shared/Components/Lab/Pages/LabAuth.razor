@page "/lab/auth"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div style="min-height: calc(100vh - var(--gns-size-topbar-height)); display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--gns-primary-600) 0%, var(--gns-primary-900) 100%); padding: var(--gns-space-8);">

    <div style="width: 100%; max-width: 24rem;">
        <GnsCard>
            <div style="padding: var(--gns-space-8);">

                @* Brand/Logo *@
                <div style="text-align: center; margin-bottom: var(--gns-space-8);">
                    <div style="display: inline-flex; align-items: center; justify-content: center; width: 3rem; height: 3rem; border-radius: var(--gns-radius-xl); background: var(--gns-primary-600); margin-bottom: var(--gns-space-3);">
                        <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M7 14L13 20L21 8" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    <h1 style="font-size: var(--gns-text-2xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary); margin-bottom: var(--gns-space-1);">Welcome back</h1>
                    <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">Sign in to your Ganesha account</p>
                </div>

                @* Login Form *@
                <div style="display: flex; flex-direction: column; gap: var(--gns-space-5);">
                    <GnsInputText Label="Email address" Placeholder="you@example.com" Type="email" @bind-Value="_authEmail" />
                    <GnsInputPassword Label="Password" Placeholder="Enter your password" @bind-Value="_authPassword" />

                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <GnsCheckbox Label="Remember me" @bind-Value="_rememberMe" />
                        <a href="lab/auth" style="font-size: var(--gns-text-sm); color: var(--gns-color-text-link); text-decoration: none;">Forgot password?</a>
                    </div>

                    <GnsButton Label="Sign In" Variant="ButtonVariant.Primary" Size="ButtonSize.Large" AdditionalCssClass="gns-w-full" />
                </div>

                @* Divider *@
                <div style="display: flex; align-items: center; gap: var(--gns-space-3); margin: var(--gns-space-6) 0;">
                    <div style="flex: 1; height: 1px; background: var(--gns-color-border-default);"></div>
                    <span style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary); text-transform: uppercase; letter-spacing: var(--gns-tracking-wider);">or continue with</span>
                    <div style="flex: 1; height: 1px; background: var(--gns-color-border-default);"></div>
                </div>

                @* Social Login Buttons *@
                <div style="display: flex; gap: var(--gns-space-3);">
                    <GnsButton Label="Google" Variant="ButtonVariant.Outline" AdditionalCssClass="gns-w-full" />
                    <GnsButton Label="GitHub" Variant="ButtonVariant.Outline" AdditionalCssClass="gns-w-full" />
                </div>

                @* Sign Up Link *@
                <p style="text-align: center; margin-top: var(--gns-space-6); font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">
                    Don't have an account?
                    <a href="lab/auth" style="color: var(--gns-color-text-link); text-decoration: none; font-weight: var(--gns-font-weight-medium);">Sign up</a>
                </p>

            </div>
        </GnsCard>
    </div>

</div>

@code {
    private string _authEmail = "";
    private string _authPassword = "";
    private bool _rememberMe = false;
}
