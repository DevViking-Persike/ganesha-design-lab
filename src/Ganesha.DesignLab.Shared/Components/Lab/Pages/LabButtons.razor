@page "/lab/buttons"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <GnsPageHeader Title="Buttons"
                   Eyebrow="Components"
                   Description="Interactive elements for triggering actions. Available in multiple variants, sizes, and states." />

    <GnsSection Title="Variants" Subtitle="Five visual variants for different emphasis levels.">
        <div class="gns-preview">
            <div class="gns-preview__canvas gns-preview__canvas--row">
                <GnsButton Label="Primary" Variant="ButtonVariant.Primary" />
                <GnsButton Label="Secondary" Variant="ButtonVariant.Secondary" />
                <GnsButton Label="Outline" Variant="ButtonVariant.Outline" />
                <GnsButton Label="Ghost" Variant="ButtonVariant.Ghost" />
                <GnsButton Label="Danger" Variant="ButtonVariant.Danger" />
            </div>
        </div>
    </GnsSection>

    <GnsSection Title="Sizes" Subtitle="Small, medium (default), and large.">
        <div class="gns-preview">
            <div class="gns-preview__canvas gns-preview__canvas--row" style="align-items: center;">
                <GnsButton Label="Small" Size="ButtonSize.Small" />
                <GnsButton Label="Medium" Size="ButtonSize.Medium" />
                <GnsButton Label="Large" Size="ButtonSize.Large" />
            </div>
        </div>
    </GnsSection>

    <GnsSection Title="With Icons" Subtitle="Buttons can include icons on the left or right.">
        <div class="gns-preview">
            <div class="gns-preview__canvas gns-preview__canvas--row">
                <GnsButton Label="Save" IconLeft="gns-icon-check" />
                <GnsButton Label="Next" IconRight="gns-icon-arrow-right" Variant="ButtonVariant.Secondary" />
                <GnsButton IconLeft="gns-icon-plus" Variant="ButtonVariant.Outline" />
            </div>
        </div>
    </GnsSection>

    <GnsSection Title="Loading States" Subtitle="Indicates an ongoing action. Disables interaction.">
        <div class="gns-preview">
            <div class="gns-preview__canvas gns-preview__canvas--row">
                <GnsButton Label="Saving..." IsLoading="true" Variant="ButtonVariant.Primary" />
                <GnsButton Label="Processing..." IsLoading="true" Variant="ButtonVariant.Secondary" />
                <GnsButton Label="Deleting..." IsLoading="true" Variant="ButtonVariant.Danger" />
            </div>
        </div>
    </GnsSection>

    <GnsSection Title="SVG Loading Buttons" Subtitle="Buttons with animated SVG fill loaders instead of the default spinner.">
        <div class="gns-preview">
            <div class="gns-preview__toolbar"><span class="gns-preview__toolbar-title">Mark A</span></div>
            <div class="gns-preview__canvas gns-preview__canvas--row">
                <GnsButton Label="Saving..." IsLoading="true" Variant="ButtonVariant.Primary"
                           LoadingAssetPath="_content/Ganesha.DesignLab.Shared/assets/loaders/loader-ganesha-a.svg"
                           LoadingAspectRatio="2816 / 1536" />
                <GnsButton Label="Processing..." IsLoading="true" Variant="ButtonVariant.Secondary"
                           LoadingAssetPath="_content/Ganesha.DesignLab.Shared/assets/loaders/loader-ganesha-a.svg"
                           LoadingAspectRatio="2816 / 1536" />
                <GnsButton Label="Deleting..." IsLoading="true" Variant="ButtonVariant.Danger"
                           LoadingAssetPath="_content/Ganesha.DesignLab.Shared/assets/loaders/loader-ganesha-a.svg"
                           LoadingAspectRatio="2816 / 1536" />
            </div>
        </div>
        <div class="gns-preview" style="margin-top: var(--gns-space-4);">
            <div class="gns-preview__toolbar"><span class="gns-preview__toolbar-title">Mark B</span></div>
            <div class="gns-preview__canvas gns-preview__canvas--row">
                <GnsButton Label="Saving..." IsLoading="true" Variant="ButtonVariant.Primary"
                           LoadingAssetPath="_content/Ganesha.DesignLab.Shared/assets/loaders/loader-ganesha-b.svg"
                           LoadingAspectRatio="1664 / 2514" />
                <GnsButton Label="Processing..." IsLoading="true" Variant="ButtonVariant.Secondary"
                           LoadingAssetPath="_content/Ganesha.DesignLab.Shared/assets/loaders/loader-ganesha-b.svg"
                           LoadingAspectRatio="1664 / 2514" />
                <GnsButton Label="Deleting..." IsLoading="true" Variant="ButtonVariant.Danger"
                           LoadingAssetPath="_content/Ganesha.DesignLab.Shared/assets/loaders/loader-ganesha-b.svg"
                           LoadingAspectRatio="1664 / 2514" />
            </div>
        </div>
        <div class="gns-preview" style="margin-top: var(--gns-space-4);">
            <div class="gns-preview__toolbar"><span class="gns-preview__toolbar-title">Mark C</span></div>
            <div class="gns-preview__canvas gns-preview__canvas--row">
                <GnsButton Label="Saving..." IsLoading="true" Variant="ButtonVariant.Primary"
                           LoadingAssetPath="_content/Ganesha.DesignLab.Shared/assets/loaders/loader-ganesha-c.svg"
                           LoadingAspectRatio="2816 / 1536" />
                <GnsButton Label="Processing..." IsLoading="true" Variant="ButtonVariant.Secondary"
                           LoadingAssetPath="_content/Ganesha.DesignLab.Shared/assets/loaders/loader-ganesha-c.svg"
                           LoadingAspectRatio="2816 / 1536" />
                <GnsButton Label="Deleting..." IsLoading="true" Variant="ButtonVariant.Danger"
                           LoadingAssetPath="_content/Ganesha.DesignLab.Shared/assets/loaders/loader-ganesha-c.svg"
                           LoadingAspectRatio="2816 / 1536" />
            </div>
        </div>
    </GnsSection>

    <GnsSection Title="Disabled States" Subtitle="Non-interactive state for unavailable actions.">
        <div class="gns-preview">
            <div class="gns-preview__canvas gns-preview__canvas--row">
                <GnsButton Label="Primary" Variant="ButtonVariant.Primary" IsDisabled="true" />
                <GnsButton Label="Secondary" Variant="ButtonVariant.Secondary" IsDisabled="true" />
                <GnsButton Label="Outline" Variant="ButtonVariant.Outline" IsDisabled="true" />
                <GnsButton Label="Ghost" Variant="ButtonVariant.Ghost" IsDisabled="true" />
                <GnsButton Label="Danger" Variant="ButtonVariant.Danger" IsDisabled="true" />
            </div>
        </div>
    </GnsSection>

    <GnsSection Title="Button Group" Subtitle="Common button grouping patterns.">
        <div class="gns-preview">
            <div class="gns-preview__canvas" style="flex-direction: column; align-items: flex-start; gap: var(--gns-space-6);">
                <div style="display: flex; gap: var(--gns-space-3);">
                    <GnsButton Label="Cancel" Variant="ButtonVariant.Ghost" />
                    <GnsButton Label="Save Draft" Variant="ButtonVariant.Outline" />
                    <GnsButton Label="Publish" Variant="ButtonVariant.Primary" />
                </div>
                <div style="display: flex; gap: var(--gns-space-3);">
                    <GnsButton Label="Delete" Variant="ButtonVariant.Danger" />
                    <GnsButton Label="Cancel" Variant="ButtonVariant.Ghost" />
                </div>
            </div>
        </div>
    </GnsSection>

    <GnsSection Title="Size Matrix" Subtitle="Every variant at every size.">
        <div class="gns-preview">
            <div class="gns-preview__canvas" style="flex-direction: column; gap: var(--gns-space-4); align-items: flex-start;">
                @foreach (var variant in Enum.GetValues<ButtonVariant>())
                {
                    <div style="display: flex; gap: var(--gns-space-3); align-items: center;">
                        <span style="width: 5rem; font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-tertiary); text-transform: uppercase;">@variant</span>
                        <GnsButton Label="Small" Variant="@variant" Size="ButtonSize.Small" />
                        <GnsButton Label="Medium" Variant="@variant" Size="ButtonSize.Medium" />
                        <GnsButton Label="Large" Variant="@variant" Size="ButtonSize.Large" />
                    </div>
                }
            </div>
        </div>
    </GnsSection>

</div>
