@page "/lab/charts"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout
@using Ganesha.DesignLab.Shared.Components.DesignSystem.Charts

<div class="gns-lab-page">

    <GnsPageHeader Title="Charts"
                   Eyebrow="Components"
                   Description="Data visualization components for Blazor: bar charts, line charts, donut charts, sparklines, and progress indicators." />

    @* ─────────────────────────────────────────────────────────────────
       Section 1 — Bar Charts
       ───────────────────────────────────────────────────────────────── *@
    <GnsSection Title="Bar Charts" Subtitle="Vertical and horizontal bar charts for categorical comparisons.">

        <GnsGrid Columns="2" Gap="6">

            @* Vertical Bar Chart *@
            <GnsCard>
                <Header>
                    <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle);">
                        <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Monthly Revenue</div>
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Jan – Jun 2026</div>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-5);">
                        <GnsBarChart Data="_monthlyRevenue"
                                     Height="300"
                                     ShowLabels="true"
                                     ShowValues="true" />
                    </div>
                </ChildContent>
            </GnsCard>

            @* Horizontal Bar Chart *@
            <GnsCard>
                <Header>
                    <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle);">
                        <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Top 5 Products by Sales</div>
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Units sold, current quarter</div>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-5);">
                        <GnsHorizontalBarChart Data="_topProducts"
                                               BarHeight="32"
                                               ShowValues="true" />
                    </div>
                </ChildContent>
            </GnsCard>

        </GnsGrid>

    </GnsSection>

    @* ─────────────────────────────────────────────────────────────────
       Section 2 — Line Charts & Sparklines
       ───────────────────────────────────────────────────────────────── *@
    <GnsSection Title="Line Charts" Subtitle="Trend lines and area charts for time-series data.">

        <GnsGrid Columns="2" Gap="6">

            @* Single-series line *@
            <GnsCard>
                <Header>
                    <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle);">
                        <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Weekly Visitors</div>
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Unique visitors over 8 weeks</div>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-5);">
                        <GnsLineChart Series="_weeklyVisitorsSeries"
                                      Labels="_weekLabels"
                                      Height="300"
                                      ShowArea="true"
                                      ShowDots="true"
                                      ShowGrid="true" />
                    </div>
                </ChildContent>
            </GnsCard>

            @* Multi-series line with area *@
            <GnsCard>
                <Header>
                    <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle);">
                        <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Revenue vs Expenses</div>
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">6-month comparison ($ thousands)</div>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-5);">
                        <GnsLineChart Series="_revenueVsExpenses"
                                      Labels="_monthLabels"
                                      Height="300"
                                      ShowArea="true"
                                      ShowDots="true"
                                      ShowGrid="true" />
                    </div>
                </ChildContent>
            </GnsCard>

        </GnsGrid>

        @* Sparkline Stat Cards *@
        <div style="margin-top: var(--gns-space-6);">
            <GnsGrid Columns="4" Gap="4">

                <GnsCard>
                    <ChildContent>
                        <div style="padding: var(--gns-space-4);">
                            <div style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-secondary); text-transform: uppercase; letter-spacing: var(--gns-tracking-wide); margin-bottom: var(--gns-space-1);">Revenue</div>
                            <div style="font-size: var(--gns-text-2xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary);">$84.2K</div>
                            <div style="font-size: var(--gns-text-xs); color: var(--gns-success-600); margin-bottom: var(--gns-space-3);">+12.4% vs last month</div>
                            <GnsSparkline Values="_sparkRevenue"
                                          Width="180"
                                          Height="40"
                                          Color="var(--gns-success-500)"
                                          ShowArea="true" />
                        </div>
                    </ChildContent>
                </GnsCard>

                <GnsCard>
                    <ChildContent>
                        <div style="padding: var(--gns-space-4);">
                            <div style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-secondary); text-transform: uppercase; letter-spacing: var(--gns-tracking-wide); margin-bottom: var(--gns-space-1);">Users</div>
                            <div style="font-size: var(--gns-text-2xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary);">12,847</div>
                            <div style="font-size: var(--gns-text-xs); color: var(--gns-success-600); margin-bottom: var(--gns-space-3);">+8.1% vs last month</div>
                            <GnsSparkline Values="_sparkUsers"
                                          Width="180"
                                          Height="40"
                                          Color="var(--gns-primary-500)"
                                          ShowArea="true" />
                        </div>
                    </ChildContent>
                </GnsCard>

                <GnsCard>
                    <ChildContent>
                        <div style="padding: var(--gns-space-4);">
                            <div style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-secondary); text-transform: uppercase; letter-spacing: var(--gns-tracking-wide); margin-bottom: var(--gns-space-1);">Orders</div>
                            <div style="font-size: var(--gns-text-2xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary);">3,421</div>
                            <div style="font-size: var(--gns-text-xs); color: var(--gns-danger-600); margin-bottom: var(--gns-space-3);">-2.3% vs last month</div>
                            <GnsSparkline Values="_sparkOrders"
                                          Width="180"
                                          Height="40"
                                          Color="var(--gns-warning-500)"
                                          ShowArea="true" />
                        </div>
                    </ChildContent>
                </GnsCard>

                <GnsCard>
                    <ChildContent>
                        <div style="padding: var(--gns-space-4);">
                            <div style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-secondary); text-transform: uppercase; letter-spacing: var(--gns-tracking-wide); margin-bottom: var(--gns-space-1);">Conversion</div>
                            <div style="font-size: var(--gns-text-2xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary);">4.82%</div>
                            <div style="font-size: var(--gns-text-xs); color: var(--gns-success-600); margin-bottom: var(--gns-space-3);">+0.6% vs last month</div>
                            <GnsSparkline Values="_sparkConversion"
                                          Width="180"
                                          Height="40"
                                          Color="var(--gns-info-500)"
                                          ShowArea="true" />
                        </div>
                    </ChildContent>
                </GnsCard>

            </GnsGrid>
        </div>

    </GnsSection>

    @* ─────────────────────────────────────────────────────────────────
       Section 3 — Donut Charts
       ───────────────────────────────────────────────────────────────── *@
    <GnsSection Title="Donut Charts" Subtitle="Ring charts for part-to-whole relationships.">

        <GnsGrid Columns="2" Gap="6">

            @* Budget Allocation *@
            <GnsCard>
                <Header>
                    <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle);">
                        <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Budget Allocation</div>
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Annual budget by department</div>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-5); display: flex; justify-content: center;">
                        <GnsDonutChart Data="_budgetAllocation"
                                       Size="240"
                                       StrokeWidth="36"
                                       CenterLabel="$4.2M"
                                       CenterSubLabel="Total"
                                       ShowLegend="true" />
                    </div>
                </ChildContent>
            </GnsCard>

            @* Task Status *@
            <GnsCard>
                <Header>
                    <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle);">
                        <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Task Status</div>
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Sprint progress breakdown</div>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-5); display: flex; justify-content: center;">
                        <GnsDonutChart Data="_taskStatus"
                                       Size="240"
                                       StrokeWidth="36"
                                       CenterLabel="148"
                                       CenterSubLabel="Total Tasks"
                                       ShowLegend="true" />
                    </div>
                </ChildContent>
            </GnsCard>

        </GnsGrid>

    </GnsSection>

    @* ─────────────────────────────────────────────────────────────────
       Section 4 — Progress Indicators
       ───────────────────────────────────────────────────────────────── *@
    <GnsSection Title="Progress Indicators" Subtitle="Linear and radial progress components with variants and sizes.">

        <GnsGrid Columns="2" Gap="6">

            @* Linear Progress — Variants *@
            <GnsCard>
                <Header>
                    <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle);">
                        <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Variants</div>
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Default, Success, Warning, Danger, Info</div>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-5); display: flex; flex-direction: column; gap: var(--gns-space-4);">
                        <GnsProgressBar Value="64" Label="Storage Used" ShowValue="true" Variant="ProgressBarVariant.Default" Size="ProgressBarSize.Medium" IsStriped="false" />
                        <GnsProgressBar Value="87" Label="Sales Goal" ShowValue="true" Variant="ProgressBarVariant.Success" Size="ProgressBarSize.Medium" IsStriped="false" />
                        <GnsProgressBar Value="51" Label="Budget Remaining" ShowValue="true" Variant="ProgressBarVariant.Warning" Size="ProgressBarSize.Medium" IsStriped="false" />
                        <GnsProgressBar Value="93" Label="Error Rate" ShowValue="true" Variant="ProgressBarVariant.Danger" Size="ProgressBarSize.Medium" IsStriped="false" />
                        <GnsProgressBar Value="38" Label="Bandwidth" ShowValue="true" Variant="ProgressBarVariant.Info" Size="ProgressBarSize.Medium" IsStriped="false" />
                    </div>
                </ChildContent>
            </GnsCard>

            @* Sizes + Striped *@
            <GnsCard>
                <Header>
                    <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle);">
                        <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Sizes & Striped</div>
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Small, Medium, Large — with striped example</div>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-5); display: flex; flex-direction: column; gap: var(--gns-space-4);">
                        <GnsProgressBar Value="45" Label="Small" ShowValue="true" Variant="ProgressBarVariant.Default" Size="ProgressBarSize.Small" IsStriped="false" />
                        <GnsProgressBar Value="62" Label="Medium" ShowValue="true" Variant="ProgressBarVariant.Default" Size="ProgressBarSize.Medium" IsStriped="false" />
                        <GnsProgressBar Value="78" Label="Large" ShowValue="true" Variant="ProgressBarVariant.Default" Size="ProgressBarSize.Large" IsStriped="false" />
                        <div style="margin-top: var(--gns-space-2);">
                            <div style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-secondary); text-transform: uppercase; letter-spacing: var(--gns-tracking-wide); margin-bottom: var(--gns-space-3);">Striped</div>
                            <GnsProgressBar Value="55" Label="Uploading Files" ShowValue="true" Variant="ProgressBarVariant.Info" Size="ProgressBarSize.Medium" IsStriped="true" />
                        </div>
                        <GnsProgressBar Value="72" Label="Processing" ShowValue="true" Variant="ProgressBarVariant.Success" Size="ProgressBarSize.Large" IsStriped="true" />
                    </div>
                </ChildContent>
            </GnsCard>

        </GnsGrid>

        @* Radial Progress *@
        <div style="margin-top: var(--gns-space-6);">
            <GnsCard>
                <Header>
                    <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle);">
                        <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Radial Progress</div>
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Server resource utilization</div>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-6); display: flex; justify-content: space-around; align-items: center; flex-wrap: wrap; gap: var(--gns-space-6);">
                        <div style="display: flex; flex-direction: column; align-items: center; gap: var(--gns-space-3);">
                            <GnsRadialProgress Value="72"
                                               Size="100"
                                               StrokeWidth="10"
                                               Label="CPU"
                                               Variant="ProgressBarVariant.Warning" />
                        </div>
                        <div style="display: flex; flex-direction: column; align-items: center; gap: var(--gns-space-3);">
                            <GnsRadialProgress Value="45"
                                               Size="100"
                                               StrokeWidth="10"
                                               Label="Memory"
                                               Variant="ProgressBarVariant.Success" />
                        </div>
                        <div style="display: flex; flex-direction: column; align-items: center; gap: var(--gns-space-3);">
                            <GnsRadialProgress Value="88"
                                               Size="100"
                                               StrokeWidth="10"
                                               Label="Disk"
                                               Variant="ProgressBarVariant.Danger" />
                        </div>
                        <div style="display: flex; flex-direction: column; align-items: center; gap: var(--gns-space-3);">
                            <GnsRadialProgress Value="23"
                                               Size="100"
                                               StrokeWidth="10"
                                               Label="Network"
                                               Variant="ProgressBarVariant.Info" />
                        </div>
                    </div>
                </ChildContent>
            </GnsCard>
        </div>

    </GnsSection>

    @* ─────────────────────────────────────────────────────────────────
       Section 5 — Dashboard Composition
       ───────────────────────────────────────────────────────────────── *@
    <GnsSection Title="Dashboard Composition" Subtitle="A realistic mini-dashboard combining multiple chart types in a cohesive layout.">

        @* Top row — 4 stat cards with sparklines *@
        <GnsGrid Columns="4" Gap="4">

            <GnsCard>
                <ChildContent>
                    <div style="padding: var(--gns-space-4);">
                        <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: var(--gns-space-3);">
                            <div>
                                <div style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-secondary); text-transform: uppercase; letter-spacing: var(--gns-tracking-wide);">Total Revenue</div>
                                <div style="font-size: var(--gns-text-xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary); margin-top: var(--gns-space-1);">$128.4K</div>
                            </div>
                            <span style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-success-600); background: var(--gns-success-50); padding: var(--gns-space-1) var(--gns-space-2); border-radius: var(--gns-radius-full);">+14.2%</span>
                        </div>
                        <GnsSparkline Values="_dashSparkRevenue" Width="160" Height="36" Color="var(--gns-success-500)" ShowArea="true" />
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary); margin-top: var(--gns-space-2);">vs $112.4K last month</div>
                    </div>
                </ChildContent>
            </GnsCard>

            <GnsCard>
                <ChildContent>
                    <div style="padding: var(--gns-space-4);">
                        <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: var(--gns-space-3);">
                            <div>
                                <div style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-secondary); text-transform: uppercase; letter-spacing: var(--gns-tracking-wide);">Active Users</div>
                                <div style="font-size: var(--gns-text-xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary); margin-top: var(--gns-space-1);">24,391</div>
                            </div>
                            <span style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-success-600); background: var(--gns-success-50); padding: var(--gns-space-1) var(--gns-space-2); border-radius: var(--gns-radius-full);">+5.8%</span>
                        </div>
                        <GnsSparkline Values="_dashSparkUsers" Width="160" Height="36" Color="var(--gns-primary-500)" ShowArea="true" />
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary); margin-top: var(--gns-space-2);">342 online right now</div>
                    </div>
                </ChildContent>
            </GnsCard>

            <GnsCard>
                <ChildContent>
                    <div style="padding: var(--gns-space-4);">
                        <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: var(--gns-space-3);">
                            <div>
                                <div style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-secondary); text-transform: uppercase; letter-spacing: var(--gns-tracking-wide);">New Orders</div>
                                <div style="font-size: var(--gns-text-xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary); margin-top: var(--gns-space-1);">3,847</div>
                            </div>
                            <span style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-danger-600); background: var(--gns-danger-50); padding: var(--gns-space-1) var(--gns-space-2); border-radius: var(--gns-radius-full);">-2.3%</span>
                        </div>
                        <GnsSparkline Values="_dashSparkOrders" Width="160" Height="36" Color="var(--gns-warning-500)" ShowArea="true" />
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary); margin-top: var(--gns-space-2);">vs 3,937 last month</div>
                    </div>
                </ChildContent>
            </GnsCard>

            <GnsCard>
                <ChildContent>
                    <div style="padding: var(--gns-space-4);">
                        <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: var(--gns-space-3);">
                            <div>
                                <div style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-secondary); text-transform: uppercase; letter-spacing: var(--gns-tracking-wide);">Conversion</div>
                                <div style="font-size: var(--gns-text-xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary); margin-top: var(--gns-space-1);">4.62%</div>
                            </div>
                            <span style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-success-600); background: var(--gns-success-50); padding: var(--gns-space-1) var(--gns-space-2); border-radius: var(--gns-radius-full);">+0.8%</span>
                        </div>
                        <GnsSparkline Values="_dashSparkConversion" Width="160" Height="36" Color="var(--gns-info-500)" ShowArea="true" />
                        <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary); margin-top: var(--gns-space-2);">Goal: 5.0%</div>
                    </div>
                </ChildContent>
            </GnsCard>

        </GnsGrid>

        @* Middle row — Line chart (2/3) + Donut chart (1/3) *@
        <div style="margin-top: var(--gns-space-5);">
            <GnsGrid TemplateColumns="2fr 1fr" Gap="5">

                <GnsCard>
                    <Header>
                        <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle); display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Revenue Trend</div>
                                <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Monthly revenue vs target ($ thousands)</div>
                            </div>
                            <div style="display: flex; gap: var(--gns-space-4); font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary);">
                                <span style="display: flex; align-items: center; gap: var(--gns-space-1);">
                                    <span style="width: 12px; height: 3px; background: var(--gns-primary-500); border-radius: 2px; display: inline-block;"></span>
                                    Actual
                                </span>
                                <span style="display: flex; align-items: center; gap: var(--gns-space-1);">
                                    <span style="width: 12px; height: 3px; background: var(--gns-color-border-default); border-radius: 2px; display: inline-block;"></span>
                                    Target
                                </span>
                            </div>
                        </div>
                    </Header>
                    <ChildContent>
                        <div style="padding: var(--gns-space-5);">
                            <GnsLineChart Series="_dashRevenueSeries"
                                          Labels="_dashMonthLabels"
                                          Height="300"
                                          ShowArea="true"
                                          ShowDots="true"
                                          ShowGrid="true" />
                        </div>
                    </ChildContent>
                </GnsCard>

                <GnsCard>
                    <Header>
                        <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle);">
                            <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Traffic Sources</div>
                            <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Acquisition channels</div>
                        </div>
                    </Header>
                    <ChildContent>
                        <div style="padding: var(--gns-space-5); display: flex; justify-content: center;">
                            <GnsDonutChart Data="_trafficSources"
                                           Size="200"
                                           StrokeWidth="32"
                                           CenterLabel="100%"
                                           CenterSubLabel="Traffic"
                                           ShowLegend="true" />
                        </div>
                    </ChildContent>
                </GnsCard>

            </GnsGrid>
        </div>

        @* Bottom row — Horizontal bar chart *@
        <div style="margin-top: var(--gns-space-5);">
            <GnsCard>
                <Header>
                    <div style="padding: var(--gns-space-4) var(--gns-space-5); border-bottom: 1px solid var(--gns-color-border-subtle); display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-primary);">Top Revenue Sources</div>
                            <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-top: var(--gns-space-1);">Revenue by product line, current quarter ($ thousands)</div>
                        </div>
                        <GnsButton Label="Full Report" Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" />
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-5);">
                        <GnsHorizontalBarChart Data="_dashProductRevenue"
                                               BarHeight="30"
                                               ShowValues="true" />
                    </div>
                </ChildContent>
            </GnsCard>
        </div>

    </GnsSection>

</div>

