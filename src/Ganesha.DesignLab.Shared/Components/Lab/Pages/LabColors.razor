@page "/lab/colors"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <GnsPageHeader Title="Colors"
                   Eyebrow="Foundations"
                   Description="Primitive color scales and semantic aliases that form the visual identity of the design system." />

    @* Primary Scale *@
    <GnsSection Title="Primary Scale" Subtitle="The brand color scale from 50 to 950.">
        <div class="gns-swatch-grid">
            @foreach (var swatch in _primarySwatches)
            {
                <div class="gns-swatch">
                    <div class="gns-swatch__color" style="background-color: var(--gns-primary-@swatch.Step);"></div>
                    <div class="gns-swatch__info">
                        <div class="gns-swatch__name">Primary @swatch.Step</div>
                        <div class="gns-swatch__value">@swatch.Hex</div>
                        <div class="gns-swatch__token">--gns-primary-@swatch.Step</div>
                    </div>
                </div>
            }
        </div>
    </GnsSection>

    @* Gray Scale *@
    <GnsSection Title="Gray Scale" Subtitle="Neutral palette with a cool blue-gray undertone.">
        <div class="gns-swatch-grid">
            @foreach (var swatch in _graySwatches)
            {
                <div class="gns-swatch">
                    <div class="gns-swatch__color" style="background-color: var(--gns-gray-@swatch.Step);"></div>
                    <div class="gns-swatch__info">
                        <div class="gns-swatch__name">Gray @swatch.Step</div>
                        <div class="gns-swatch__value">@swatch.Hex</div>
                        <div class="gns-swatch__token">--gns-gray-@swatch.Step</div>
                    </div>
                </div>
            }
        </div>
    </GnsSection>

    @* Semantic Colors *@
    <GnsSection Title="Semantic Colors" Subtitle="Status and feedback color scales.">
        <h3 style="font-size: var(--gns-text-lg); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-4); color: var(--gns-color-text-primary);">Success</h3>
        <div class="gns-swatch-grid" style="margin-bottom: var(--gns-space-8);">
            @foreach (var swatch in _successSwatches)
            {
                <div class="gns-swatch">
                    <div class="gns-swatch__color" style="background-color: var(--gns-success-@swatch.Step);"></div>
                    <div class="gns-swatch__info">
                        <div class="gns-swatch__name">Success @swatch.Step</div>
                        <div class="gns-swatch__value">@swatch.Hex</div>
                    </div>
                </div>
            }
        </div>

        <h3 style="font-size: var(--gns-text-lg); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-4); color: var(--gns-color-text-primary);">Warning</h3>
        <div class="gns-swatch-grid" style="margin-bottom: var(--gns-space-8);">
            @foreach (var swatch in _warningSwatches)
            {
                <div class="gns-swatch">
                    <div class="gns-swatch__color" style="background-color: var(--gns-warning-@swatch.Step);"></div>
                    <div class="gns-swatch__info">
                        <div class="gns-swatch__name">Warning @swatch.Step</div>
                        <div class="gns-swatch__value">@swatch.Hex</div>
                    </div>
                </div>
            }
        </div>

        <h3 style="font-size: var(--gns-text-lg); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-4); color: var(--gns-color-text-primary);">Danger</h3>
        <div class="gns-swatch-grid" style="margin-bottom: var(--gns-space-8);">
            @foreach (var swatch in _dangerSwatches)
            {
                <div class="gns-swatch">
                    <div class="gns-swatch__color" style="background-color: var(--gns-danger-@swatch.Step);"></div>
                    <div class="gns-swatch__info">
                        <div class="gns-swatch__name">Danger @swatch.Step</div>
                        <div class="gns-swatch__value">@swatch.Hex</div>
                    </div>
                </div>
            }
        </div>

        <h3 style="font-size: var(--gns-text-lg); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-4); color: var(--gns-color-text-primary);">Info</h3>
        <div class="gns-swatch-grid">
            @foreach (var swatch in _infoSwatches)
            {
                <div class="gns-swatch">
                    <div class="gns-swatch__color" style="background-color: var(--gns-info-@swatch.Step);"></div>
                    <div class="gns-swatch__info">
                        <div class="gns-swatch__name">Info @swatch.Step</div>
                        <div class="gns-swatch__value">@swatch.Hex</div>
                    </div>
                </div>
            }
        </div>
    </GnsSection>

    @* Semantic Surface/Text Tokens *@
    <GnsSection Title="Semantic Tokens" Subtitle="Context-aware tokens for backgrounds, surfaces, text, and borders.">
        <table class="gns-token-table">
            <thead>
                <tr>
                    <th>Preview</th>
                    <th>Token</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var token in _semanticTokens)
                {
                    <tr>
                        <td><div class="gns-token-table__color-dot" style="background-color: var(@token.Token);"></div></td>
                        <td class="gns-token-table__name">@token.Token</td>
                        <td class="gns-token-table__description">@token.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    </GnsSection>

</div>

@code {
    private record ColorSwatch(string Step, string Hex);
    private record SemanticToken(string Token, string Description);

    private static readonly ColorSwatch[] _primarySwatches =
    [
        new("50", "#EEEEFF"), new("100", "#E0E0FF"), new("200", "#C6C4FF"),
        new("300", "#A5A1FC"), new("400", "#8178F8"), new("500", "#6358F2"),
        new("600", "#4F46E5"), new("700", "#4238C8"), new("800", "#3530A0"),
        new("900", "#29277B"), new("950", "#161550")
    ];

    private static readonly ColorSwatch[] _graySwatches =
    [
        new("50", "#F8F9FB"), new("100", "#F1F3F7"), new("200", "#E4E7EF"),
        new("300", "#CDD2E0"), new("400", "#A8B0C4"), new("500", "#7E8799"),
        new("600", "#5C6478"), new("700", "#434A5C"), new("800", "#2C3142"),
        new("900", "#1A1E2E"), new("950", "#0F1118")
    ];

    private static readonly ColorSwatch[] _successSwatches =
    [
        new("50", "#ECFDF5"), new("100", "#D1FAE5"), new("200", "#A7F3D0"),
        new("300", "#6EE7B7"), new("400", "#34D399"), new("500", "#10B981"),
        new("600", "#059669"), new("700", "#047857"), new("800", "#065F46"),
        new("900", "#064E3B"), new("950", "#022C22")
    ];

    private static readonly ColorSwatch[] _warningSwatches =
    [
        new("50", "#FFFBEB"), new("100", "#FEF3C7"), new("200", "#FDE68A"),
        new("300", "#FCD34D"), new("400", "#FBBF24"), new("500", "#F59E0B"),
        new("600", "#D97706"), new("700", "#B45309"), new("800", "#92400E"),
        new("900", "#78350F"), new("950", "#451A03")
    ];

    private static readonly ColorSwatch[] _dangerSwatches =
    [
        new("50", "#FFF1F2"), new("100", "#FFE4E6"), new("200", "#FECDD3"),
        new("300", "#FDA4AF"), new("400", "#FB7185"), new("500", "#F43F5E"),
        new("600", "#E11D48"), new("700", "#BE123C"), new("800", "#9F1239"),
        new("900", "#881337"), new("950", "#4C0519")
    ];

    private static readonly ColorSwatch[] _infoSwatches =
    [
        new("50", "#F0F9FF"), new("100", "#E0F2FE"), new("200", "#BAE6FD"),
        new("300", "#7DD3FC"), new("400", "#38BDF8"), new("500", "#0EA5E9"),
        new("600", "#0284C7"), new("700", "#0369A1"), new("800", "#075985"),
        new("900", "#0C4A6E"), new("950", "#082F49")
    ];

    private static readonly SemanticToken[] _semanticTokens =
    [
        new("--gns-color-bg-page", "Main page background"),
        new("--gns-color-bg-subtle", "Subtle background for secondary areas"),
        new("--gns-color-bg-muted", "Muted background for grouped content"),
        new("--gns-color-surface-default", "Default card/panel surface"),
        new("--gns-color-surface-raised", "Elevated surface (modals, popovers)"),
        new("--gns-color-surface-sunken", "Recessed/inset surface"),
        new("--gns-color-text-primary", "Primary text color"),
        new("--gns-color-text-secondary", "Secondary/supporting text"),
        new("--gns-color-text-tertiary", "Tertiary/caption text"),
        new("--gns-color-text-disabled", "Disabled text"),
        new("--gns-color-text-link", "Link text color"),
        new("--gns-color-border-default", "Default border"),
        new("--gns-color-border-subtle", "Subtle/light border"),
        new("--gns-color-border-strong", "Emphasized border"),
        new("--gns-color-border-focus", "Focus ring border")
    ];
}
