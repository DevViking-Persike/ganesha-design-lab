@page "/lab/dashboard"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <GnsPageHeader Title="Dashboard" Eyebrow="Patterns" Description="A realistic dashboard layout with metrics, data tables, and notification panels.">
        <Actions>
            <GnsSelect @bind-Value="_dateRange">
                <option value="7d">Last 7 days</option>
                <option value="30d">Last 30 days</option>
                <option value="90d">Last 90 days</option>
                <option value="1y">Last year</option>
            </GnsSelect>
        </Actions>
    </GnsPageHeader>

    @* Metric Cards *@
    <GnsSection>
        <GnsGrid Columns="4" Gap="4">
            <GnsStatCard Title="Revenue" Value="$128,430" Trend="+14.2%" TrendDirection="TrendDirection.Up" Description="vs previous period" />
            <GnsStatCard Title="Active Users" Value="8,492" Trend="+5.8%" TrendDirection="TrendDirection.Up" Description="currently online: 342" />
            <GnsStatCard Title="Orders" Value="3,847" Trend="-2.3%" TrendDirection="TrendDirection.Down" Description="vs previous period" />
            <GnsStatCard Title="Conversion" Value="4.62%" Trend="+0.8%" TrendDirection="TrendDirection.Up" Description="goal: 5.0%" />
        </GnsGrid>
    </GnsSection>

    @* Recent Orders Table *@
    <GnsSection Title="Recent Orders" Subtitle="Latest orders placed by customers.">
        <Actions>
            <GnsButton Label="Export" Variant="ButtonVariant.Outline" Size="ButtonSize.Small" />
            <GnsButton Label="View All" Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" />
        </Actions>
        <ChildContent>
            <GnsTable TItem="OrderRecord" Items="_orders" IsHoverable="true">
                <HeaderTemplate>
                    <th class="gns-table__head-cell">Order ID</th>
                    <th class="gns-table__head-cell">Customer</th>
                    <th class="gns-table__head-cell">Product</th>
                    <th class="gns-table__head-cell">Amount</th>
                    <th class="gns-table__head-cell">Status</th>
                    <th class="gns-table__head-cell">Date</th>
                </HeaderTemplate>
                <RowTemplate Context="order">
                    <tr class="gns-table__body-row">
                        <td class="gns-table__body-cell" style="font-family: var(--gns-font-mono); font-size: var(--gns-text-xs);">@order.Id</td>
                        <td class="gns-table__body-cell">
                            <div style="display: flex; align-items: center; gap: var(--gns-space-2);">
                                <GnsAvatar Initials="@order.CustomerInitials" Size="AvatarSize.Small" />
                                <span>@order.Customer</span>
                            </div>
                        </td>
                        <td class="gns-table__body-cell">@order.Product</td>
                        <td class="gns-table__body-cell" style="font-weight: var(--gns-font-weight-medium);">@order.Amount.ToString("C")</td>
                        <td class="gns-table__body-cell">
                            <GnsBadge Severity="@order.StatusSeverity" Size="BadgeSize.Small">@order.Status</GnsBadge>
                        </td>
                        <td class="gns-table__body-cell" style="color: var(--gns-color-text-secondary);">@order.Date</td>
                    </tr>
                </RowTemplate>
            </GnsTable>
        </ChildContent>
    </GnsSection>

    @* Notifications *@
    <GnsSection Title="Notifications" Subtitle="Recent system alerts and updates.">
        <div style="display: flex; flex-direction: column; gap: var(--gns-space-3);">
            <GnsAlert Severity="AlertSeverity.Warning" IsDismissible="true" Title="Server Load Warning">
                CPU usage has exceeded 85% on production server us-east-1. Consider scaling up.
            </GnsAlert>
            <GnsAlert Severity="AlertSeverity.Success" IsDismissible="true">
                Deployment v2.4.1 completed successfully across all regions.
            </GnsAlert>
            <GnsAlert Severity="AlertSeverity.Info" IsDismissible="true">
                Scheduled maintenance window: Saturday 2:00 AM - 4:00 AM UTC.
            </GnsAlert>
        </div>
    </GnsSection>

</div>

@code {
    private string _dateRange = "30d";

    private record OrderRecord(string Id, string Customer, string CustomerInitials, string Product, decimal Amount, string Status, BadgeSeverity StatusSeverity, string Date);

    private static readonly IReadOnlyList<OrderRecord> _orders =
    [
        new("ORD-7842", "Sarah Johnson", "SJ", "Pro Subscription", 299.00m, "Completed", BadgeSeverity.Success, "Mar 28, 2026"),
        new("ORD-7841", "Michael Chen", "MC", "Team License", 899.00m, "Processing", BadgeSeverity.Warning, "Mar 28, 2026"),
        new("ORD-7840", "Emily Davis", "ED", "Enterprise Plan", 2499.00m, "Completed", BadgeSeverity.Success, "Mar 27, 2026"),
        new("ORD-7839", "James Wilson", "JW", "Pro Subscription", 299.00m, "Refunded", BadgeSeverity.Danger, "Mar 27, 2026"),
        new("ORD-7838", "Lisa Park", "LP", "Starter Pack", 49.00m, "Completed", BadgeSeverity.Success, "Mar 26, 2026"),
        new("ORD-7837", "Robert Kim", "RK", "Team License", 899.00m, "Processing", BadgeSeverity.Warning, "Mar 26, 2026"),
        new("ORD-7836", "Anna Martinez", "AM", "Pro Subscription", 299.00m, "Completed", BadgeSeverity.Success, "Mar 25, 2026"),
        new("ORD-7835", "David Brown", "DB", "Enterprise Plan", 2499.00m, "Pending", BadgeSeverity.Info, "Mar 25, 2026"),
