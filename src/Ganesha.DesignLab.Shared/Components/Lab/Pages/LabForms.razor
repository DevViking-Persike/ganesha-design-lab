@page "/lab/forms"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <HlxPageHeader Title="Forms"
                   Eyebrow="Components"
                   Description="Form controls including text inputs, selects, checkboxes, radios, textareas, and switches." />

    <HlxSection Title="Text Input" Subtitle="Single-line text input with label, helper, and error states.">
        <div class="gns-preview">
            <div class="gns-preview__canvas" style="flex-direction: column; gap: var(--gns-space-6); max-width: 24rem; width: 100%;">
                <HlxInputText Label="Full Name" Placeholder="Enter your name" @bind-Value="_name" />
                <HlxInputText Label="Email" Placeholder="you@example.com" HelperText="We'll never share your email." @bind-Value="_email" />
                <HlxInputText Label="Username" Placeholder="Choose a username" ErrorMessage="This username is already taken." Value="john_doe" />
                <HlxInputText Label="Read Only" Value="This field is read-only" IsReadOnly="true" />
                <HlxInputText Label="Disabled" Placeholder="Can't type here" IsDisabled="true" />
            </div>
        </div>
    </HlxSection>

    <HlxSection Title="Input Sizes" Subtitle="Three size variants for different contexts.">
        <div class="gns-preview">
            <div class="gns-preview__canvas" style="flex-direction: column; gap: var(--gns-space-4); max-width: 24rem; width: 100%;">
                <HlxInputText Label="Small" Placeholder="Small input" Size="InputSize.Small" @bind-Value="_sizeSm" />
                <HlxInputText Label="Medium" Placeholder="Medium input" Size="InputSize.Medium" @bind-Value="_sizeMd" />
                <HlxInputText Label="Large" Placeholder="Large input" Size="InputSize.Large" @bind-Value="_sizeLg" />
            </div>
        </div>
    </HlxSection>

    <HlxSection Title="Password Input" Subtitle="Password field with visibility toggle.">
        <div class="gns-preview">
            <div class="gns-preview__canvas" style="max-width: 24rem; width: 100%;">
                <HlxInputPassword Label="Password" Placeholder="Enter password" @bind-Value="_password" />
            </div>
        </div>
    </HlxSection>

    <HlxSection Title="Select" Subtitle="Dropdown select for choosing from predefined options.">
        <div class="gns-preview">
            <div class="gns-preview__canvas" style="flex-direction: column; gap: var(--gns-space-4); max-width: 24rem; width: 100%;">
                <HlxSelect Label="Country" Placeholder="Select a country" @bind-Value="_country">
                    <option value="us">United States</option>
                    <option value="uk">United Kingdom</option>
                    <option value="ca">Canada</option>
                    <option value="au">Australia</option>
                    <option value="br">Brazil</option>
                </HlxSelect>
                <HlxSelect Label="Status" Placeholder="Choose status" ErrorMessage="Please select a status." @bind-Value="_status">
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </HlxSelect>
            </div>
        </div>
    </HlxSection>

    <HlxSection Title="Checkbox" Subtitle="Boolean toggle with optional label.">
        <div class="gns-preview">
            <div class="gns-preview__canvas" style="flex-direction: column; gap: var(--gns-space-3); align-items: flex-start;">
                <HlxCheckbox Label="Accept terms and conditions" @bind-Value="_terms" />
                <HlxCheckbox Label="Subscribe to newsletter" @bind-Value="_newsletter" />
                <HlxCheckbox Label="Disabled option" IsDisabled="true" Value="true" />
            </div>
        </div>
    </HlxSection>

    <HlxSection Title="Radio Group" Subtitle="Single selection from multiple options.">
        <div class="gns-preview">
            <div class="gns-preview__canvas" style="max-width: 24rem; width: 100%;">
                <HlxRadioGroup Label="Notification Preference" @bind-Value="_radioValue">
                    <HlxRadioOption Value="email" Label="Email notifications" />
                    <HlxRadioOption Value="sms" Label="SMS notifications" />
                    <HlxRadioOption Value="push" Label="Push notifications" />
                    <HlxRadioOption Value="none" Label="No notifications" IsDisabled="true" />
                </HlxRadioGroup>
            </div>
        </div>
    </HlxSection>

    <HlxSection Title="Textarea" Subtitle="Multi-line text input for longer content.">
        <div class="gns-preview">
            <div class="gns-preview__canvas" style="flex-direction: column; gap: var(--gns-space-4); max-width: 24rem; width: 100%;">
                <HlxTextarea Label="Bio" Placeholder="Tell us about yourself..." Rows="4" HelperText="Max 500 characters." @bind-Value="_bio" />
                <HlxTextarea Label="Notes" Placeholder="Add notes..." ErrorMessage="Notes cannot be empty." @bind-Value="_notes" />
            </div>
        </div>
    </HlxSection>

    <HlxSection Title="Switch" Subtitle="Toggle for binary settings.">
        <div class="gns-preview">
            <div class="gns-preview__canvas" style="flex-direction: column; gap: var(--gns-space-3); align-items: flex-start;">
                <HlxSwitch Label="Enable notifications" @bind-Value="_switchNotif" />
                <HlxSwitch Label="Dark mode" @bind-Value="_switchDark" />
                <HlxSwitch Label="Disabled toggle" IsDisabled="true" Value="true" />
            </div>
        </div>
    </HlxSection>

    <HlxSection Title="Complete Form Example" Subtitle="A realistic form combining multiple input types.">
        <HlxCard>
            <div style="padding: var(--gns-space-6); display: flex; flex-direction: column; gap: var(--gns-space-5); max-width: 32rem;">
                <h3 style="font-size: var(--gns-text-lg); font-weight: var(--gns-font-weight-semibold);">Create Account</h3>
                <HlxGrid TemplateColumns="1fr 1fr" Gap="4">
                    <HlxInputText Label="First Name" Placeholder="John" IsRequired="true" @bind-Value="_firstName" />
                    <HlxInputText Label="Last Name" Placeholder="Doe" IsRequired="true" @bind-Value="_lastName" />
                </HlxGrid>
                <HlxInputText Label="Email" Placeholder="john@example.com" IsRequired="true" Type="email" @bind-Value="_formEmail" />
                <HlxInputPassword Label="Password" Placeholder="At least 8 characters" IsRequired="true" @bind-Value="_formPassword" />
                <HlxSelect Label="Role" Placeholder="Select a role" IsRequired="true" @bind-Value="_formRole">
                    <option value="developer">Developer</option>
                    <option value="designer">Designer</option>
                    <option value="manager">Manager</option>
                    <option value="admin">Admin</option>
                </HlxSelect>
                <HlxTextarea Label="Bio" Placeholder="A short bio..." Rows="3" @bind-Value="_formBio" />
                <HlxCheckbox Label="I agree to the Terms of Service and Privacy Policy" @bind-Value="_formTerms" />
                <div style="display: flex; gap: var(--gns-space-3); justify-content: flex-end;">
                    <HlxButton Label="Cancel" Variant="ButtonVariant.Ghost" />
                    <HlxButton Label="Create Account" Variant="ButtonVariant.Primary" />
                </div>
            </div>
        </HlxCard>
    </HlxSection>

</div>

@code {
    private string _name = "";
    private string _email = "";
    private string _password = "";
    private string _country = "";
    private string _status = "";
    private string _sizeSm = "";
    private string _sizeMd = "";
    private string _sizeLg = "";
    private bool _terms = false;
    private bool _newsletter = true;
    private string _radioValue = "email";
    private string _bio = "";
    private string _notes = "";
    private bool _switchNotif = true;
    private bool _switchDark = false;
    private string _firstName = "";
    private string _lastName = "";
    private string _formEmail = "";
    private string _formPassword = "";
    private string _formRole = "";
    private string _formBio = "";
    private bool _formTerms = false;
}
