        new("Theming",       "Light, dark, and custom themes with CSS variables.",    "var(--gns-danger-500)",   "◑"),
        new("Responsive",    "Mobile-first layouts that adapt to any screen size.",   "var(--gns-primary-400)",  "⬠"),
        new("Motion",        "Subtle, purposeful animations that respect preferences.", "var(--gns-primary-300)", "◉"),
        new("Icons",         "Consistent icon set aligned to the design language.",   "var(--gns-info-500)",     "⬡"),
    ];

    private record FormField(string Label, string Placeholder);

