@page "/lab/grid"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

@using Ganesha.DesignLab.Shared.Components.DesignSystem.Layout

<div class="gns-lab-page">

    <GnsPageHeader Title="Grid &amp; Layout"
                   Eyebrow="Foundations"
                   Description="Layout primitives for building structured, responsive interfaces: CSS grid, flex stacks, containers, and sections." />

    @* ─────────────────────────────────────────────────────── *@
    @* Section 1 — Grid System                                 *@
    @* ─────────────────────────────────────────────────────── *@

    <GnsSection Title="Grid System" Subtitle="GnsGrid with standard column counts using equal-width fr columns.">

        <div style="display: flex; flex-direction: column; gap: var(--gns-space-6);">

            @* 12 columns *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Columns=&quot;12&quot; — each box spans 1 col</p>
                <GnsGrid Columns="12" Gap="2">
                    @for (int i = 0; i < 12; i++)
                    {
                        <div style="@BoxStyle("var(--gns-primary-500)")">1</div>
                    }
                </GnsGrid>
            </div>

            @* 6 columns *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Columns=&quot;6&quot; — each box spans 2 effective cols</p>
                <GnsGrid Columns="6" Gap="2">
                    @for (int i = 0; i < 6; i++)
                    {
                        <div style="@BoxStyle("var(--gns-primary-400)")">2</div>
                    }
                </GnsGrid>
            </div>

            @* 4 columns *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Columns=&quot;4&quot; — each box spans 3 effective cols</p>
                <GnsGrid Columns="4" Gap="2">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div style="@BoxStyle("var(--gns-primary-300)", "5rem")">3</div>
                    }
                </GnsGrid>
            </div>

            @* 3 columns *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Columns=&quot;3&quot; — each box spans 4 effective cols</p>
                <GnsGrid Columns="3" Gap="2">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div style="@BoxStyle("var(--gns-info-500)", "5rem")">4</div>
                    }
                </GnsGrid>
            </div>

            @* 2 columns *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Columns=&quot;2&quot; — each box spans 6 effective cols</p>
                <GnsGrid Columns="2" Gap="2">
                    @for (int i = 0; i < 2; i++)
                    {
                        <div style="@BoxStyle("var(--gns-success-500)", "5rem")">6</div>
                    }
                </GnsGrid>
            </div>

            @* 1 column *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Columns=&quot;1&quot; — full width, spans 12 effective cols</p>
                <GnsGrid Columns="1" Gap="2">
                    <div style="@BoxStyle("var(--gns-warning-500)", "5rem")">12</div>
                </GnsGrid>
            </div>

        </div>
    </GnsSection>

    @* ─────────────────────────────────────────────────────── *@
    @* Section 2 — Custom Grid Templates                       *@
    @* ─────────────────────────────────────────────────────── *@

    <GnsSection Title="Custom Grid Templates" Subtitle="Using the TemplateColumns parameter for asymmetric layouts.">

        <div style="display: flex; flex-direction: column; gap: var(--gns-space-8);">

            @* Sidebar + Content *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">TemplateColumns=&quot;280px 1fr&quot; — Sidebar + Content</p>
                <GnsGrid TemplateColumns="280px 1fr" Gap="4">
                    <div style="@BoxStyle("var(--gns-primary-500)", "6rem")">280px sidebar</div>
                    <div style="@BoxStyle("var(--gns-primary-300)", "6rem")">1fr content area</div>
                </GnsGrid>
            </div>

            @* Content + Sidebar *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">TemplateColumns=&quot;1fr 300px&quot; — Content + Sidebar</p>
                <GnsGrid TemplateColumns="1fr 300px" Gap="4">
                    <div style="@BoxStyle("var(--gns-info-500)", "6rem")">1fr content area</div>
                    <div style="@BoxStyle("var(--gns-primary-500)", "6rem")">300px sidebar</div>
                </GnsGrid>
            </div>

            @* Holy Grail *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">TemplateColumns=&quot;200px 1fr 200px&quot; — Holy Grail (left · main · right)</p>
                <GnsGrid TemplateColumns="200px 1fr 200px" Gap="4">
                    <div style="@BoxStyle("var(--gns-primary-500)", "6rem")">200px left</div>
                    <div style="@BoxStyle("var(--gns-success-500)", "6rem")">1fr main</div>
                    <div style="@BoxStyle("var(--gns-primary-500)", "6rem")">200px right</div>
                </GnsGrid>
            </div>

            @* Dashboard 2fr 1fr *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">TemplateColumns=&quot;2fr 1fr&quot; — Dashboard (2/3 + 1/3)</p>
                <GnsGrid TemplateColumns="2fr 1fr" Gap="4">
                    <div style="@BoxStyle("var(--gns-warning-500)", "6rem")">2fr main panel</div>
                    <div style="@BoxStyle("var(--gns-danger-500)", "6rem")">1fr side panel</div>
                </GnsGrid>
            </div>

            @* Equal thirds with large gap *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Columns=&quot;3&quot; Gap=&quot;6&quot; — Equal thirds with wide gap</p>
                <GnsGrid Columns="3" Gap="6">
                    <div style="@BoxStyle("var(--gns-primary-400)", "6rem")">1fr</div>
                    <div style="@BoxStyle("var(--gns-primary-400)", "6rem")">1fr</div>
                    <div style="@BoxStyle("var(--gns-primary-400)", "6rem")">1fr</div>
                </GnsGrid>
            </div>

        </div>
    </GnsSection>

    @* ─────────────────────────────────────────────────────── *@
    @* Section 3 — Stack (Flex)                                *@
    @* ─────────────────────────────────────────────────────── *@

    <GnsSection Title="Stack (Flex)" Subtitle="GnsStack for flex-based horizontal and vertical arrangements.">

        <div style="display: flex; flex-direction: column; gap: var(--gns-space-8);">

            @* Horizontal *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Direction=Horizontal Gap=&quot;4&quot;</p>
                <GnsStack Direction="StackDirection.Horizontal" Gap="4">
                    <div style="@BoxStyle("var(--gns-primary-500)") flex: 1;">Item 1</div>
                    <div style="@BoxStyle("var(--gns-primary-400)") flex: 1;">Item 2</div>
                    <div style="@BoxStyle("var(--gns-primary-300)") flex: 1;">Item 3</div>
                    <div style="@BoxStyle("var(--gns-info-500)") flex: 1;">Item 4</div>
                    <div style="@BoxStyle("var(--gns-success-500)") flex: 1;">Item 5</div>
                </GnsStack>
            </div>

            @* Vertical *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Direction=Vertical Gap=&quot;3&quot;</p>
                <GnsStack Direction="StackDirection.Vertical" Gap="3">
                    <div style="@BoxStyle("var(--gns-primary-500)")">Item 1</div>
                    <div style="@BoxStyle("var(--gns-primary-400)")">Item 2</div>
                    <div style="@BoxStyle("var(--gns-primary-300)")">Item 3</div>
                    <div style="@BoxStyle("var(--gns-info-500)")">Item 4</div>
                    <div style="@BoxStyle("var(--gns-success-500)")">Item 5</div>
                </GnsStack>
            </div>

            @* Alignment variants *@
            <div>
                <p style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-4);">Alignment Variants (Horizontal)</p>
                <div style="display: flex; flex-direction: column; gap: var(--gns-space-4);">

                    <div>
                        <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Align=Start</p>
                        <div style="border: 1px dashed var(--gns-color-border-default); border-radius: var(--gns-radius-md); padding: var(--gns-space-3);">
                            <GnsStack Direction="StackDirection.Horizontal" Gap="3" Align="ContentAlignment.Start">
                                <div style="@BoxStyle("var(--gns-primary-500)", "3rem") width: 5rem;">A</div>
                                <div style="@BoxStyle("var(--gns-primary-400)", "3rem") width: 5rem;">B</div>
                                <div style="@BoxStyle("var(--gns-primary-300)", "3rem") width: 5rem;">C</div>
                            </GnsStack>
                        </div>
                    </div>

                    <div>
                        <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Align=Center</p>
                        <div style="border: 1px dashed var(--gns-color-border-default); border-radius: var(--gns-radius-md); padding: var(--gns-space-3);">
                            <GnsStack Direction="StackDirection.Horizontal" Gap="3" Align="ContentAlignment.Center">
                                <div style="@BoxStyle("var(--gns-info-500)", "3rem") width: 5rem;">A</div>
                                <div style="@BoxStyle("var(--gns-info-500)", "3rem") width: 5rem;">B</div>
                                <div style="@BoxStyle("var(--gns-info-500)", "3rem") width: 5rem;">C</div>
                            </GnsStack>
                        </div>
                    </div>

                    <div>
                        <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Align=End</p>
                        <div style="border: 1px dashed var(--gns-color-border-default); border-radius: var(--gns-radius-md); padding: var(--gns-space-3);">
                            <GnsStack Direction="StackDirection.Horizontal" Gap="3" Align="ContentAlignment.End">
                                <div style="@BoxStyle("var(--gns-success-500)", "3rem") width: 5rem;">A</div>
                                <div style="@BoxStyle("var(--gns-success-500)", "3rem") width: 5rem;">B</div>
                                <div style="@BoxStyle("var(--gns-success-500)", "3rem") width: 5rem;">C</div>
                            </GnsStack>
                        </div>
                    </div>

                    <div>
                        <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Align=SpaceBetween</p>
                        <div style="border: 1px dashed var(--gns-color-border-default); border-radius: var(--gns-radius-md); padding: var(--gns-space-3);">
                            <GnsStack Direction="StackDirection.Horizontal" Gap="3" Align="ContentAlignment.SpaceBetween">
                                <div style="@BoxStyle("var(--gns-warning-500)", "3rem") width: 5rem;">A</div>
                                <div style="@BoxStyle("var(--gns-warning-500)", "3rem") width: 5rem;">B</div>
                                <div style="@BoxStyle("var(--gns-warning-500)", "3rem") width: 5rem;">C</div>
                            </GnsStack>
                        </div>
                    </div>

                </div>
            </div>

            @* Wrapping *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Direction=Horizontal Wrap=&quot;true&quot; — items wrap onto new lines</p>
                <GnsStack Direction="StackDirection.Horizontal" Gap="3" Wrap="true">
                    @foreach (var label in new[] { "Alpha", "Beta", "Gamma", "Delta", "Epsilon", "Zeta", "Eta", "Theta", "Iota", "Kappa", "Lambda", "Mu", "Nu", "Xi" })
                    {
                        <div style="@BoxStyle("var(--gns-primary-400)", "3rem") width: 6rem;">@label</div>
                    }
                </GnsStack>
            </div>

            @* Nested stacks *@
            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Nested — horizontal stack containing two vertical stacks</p>
                <GnsStack Direction="StackDirection.Horizontal" Gap="6">
                    <div style="flex: 1;">
                        <p style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Left column</p>
                        <GnsStack Direction="StackDirection.Vertical" Gap="2">
                            <div style="@BoxStyle("var(--gns-primary-500)")">L1</div>
                            <div style="@BoxStyle("var(--gns-primary-400)")">L2</div>
                            <div style="@BoxStyle("var(--gns-primary-300)")">L3</div>
                        </GnsStack>
                    </div>
                    <div style="flex: 1;">
                        <p style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Right column</p>
                        <GnsStack Direction="StackDirection.Vertical" Gap="2">
                            <div style="@BoxStyle("var(--gns-success-500)")">R1</div>
                            <div style="@BoxStyle("var(--gns-success-500)", "3rem")">R2 (taller)</div>
                            <div style="@BoxStyle("var(--gns-success-500)")">R3</div>
                        </GnsStack>
                    </div>
                </GnsStack>
            </div>

        </div>
    </GnsSection>

    @* ─────────────────────────────────────────────────────── *@
    @* Section 4 — Container Sizes                             *@
    @* ─────────────────────────────────────────────────────── *@

    <GnsSection Title="Container Sizes" Subtitle="GnsContainer centers content with a max-width constraint. Each box below fills the container width.">

        <div style="display: flex; flex-direction: column; gap: var(--gns-space-6);">

            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Size=Sm — max-width 640px</p>
                <GnsContainer Size="ContainerSize.Sm">
                    <div style="@BoxStyle("var(--gns-primary-500)", "3.5rem")">Sm · 640px</div>
                </GnsContainer>
            </div>

            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Size=Md — max-width 768px</p>
                <GnsContainer Size="ContainerSize.Md">
                    <div style="@BoxStyle("var(--gns-primary-400)", "3.5rem")">Md · 768px</div>
                </GnsContainer>
            </div>

            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Size=Lg — max-width 1024px</p>
                <GnsContainer Size="ContainerSize.Lg">
                    <div style="@BoxStyle("var(--gns-primary-300)", "3.5rem")">Lg · 1024px</div>
                </GnsContainer>
            </div>

            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Size=Default — max-width 1280px</p>
                <GnsContainer Size="ContainerSize.Default">
                    <div style="@BoxStyle("var(--gns-info-500)", "3.5rem")">Default · 1280px</div>
                </GnsContainer>
            </div>

            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Size=Xl — max-width 1440px</p>
                <GnsContainer Size="ContainerSize.Xl">
                    <div style="@BoxStyle("var(--gns-success-500)", "3.5rem")">Xl · 1440px</div>
                </GnsContainer>
            </div>

            <div>
                <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Size=Full — max-width 100%</p>
                <GnsContainer Size="ContainerSize.Full">
                    <div style="@BoxStyle("var(--gns-warning-500)", "3.5rem")">Full · 100%</div>
                </GnsContainer>
            </div>

        </div>
    </GnsSection>

    @* ─────────────────────────────────────────────────────── *@
    @* Section 5 — Composition Examples                        *@
    @* ─────────────────────────────────────────────────────── *@

    <GnsSection Title="Composition Examples" Subtitle="Real-world layout patterns built from grid and stack primitives.">

        <div style="display: flex; flex-direction: column; gap: var(--gns-space-10);">

            @* Dashboard Layout *@
            <div>
                <p style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-1);">Dashboard Layout</p>
                <p style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-bottom: var(--gns-space-3);">Main chart on the left, summary cards stacked on the right.</p>
                <GnsGrid TemplateColumns="2fr 1fr" Gap="4">
                    <GnsCard>
                        <div style="padding: var(--gns-space-4);">
                            <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-3);">Revenue Overview</div>
                            <div style="@BoxStyle("var(--gns-primary-300)", "10rem")">Chart placeholder</div>
                        </div>
                    </GnsCard>
                    <GnsStack Direction="StackDirection.Vertical" Gap="3">
                        <GnsCard>
                            <div style="padding: var(--gns-space-4);">
                                <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-bottom: var(--gns-space-1);">Total Users</div>
                                <div style="font-size: var(--gns-text-2xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-primary-500);">24,891</div>
                            </div>
                        </GnsCard>
                        <GnsCard>
                            <div style="padding: var(--gns-space-4);">
                                <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-bottom: var(--gns-space-1);">Monthly Revenue</div>
                                <div style="font-size: var(--gns-text-2xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-success-600);">$142,500</div>
                            </div>
                        </GnsCard>
                        <GnsCard>
                            <div style="padding: var(--gns-space-4);">
                                <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-bottom: var(--gns-space-1);">Pending Orders</div>
                                <div style="font-size: var(--gns-text-2xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-warning-600);">318</div>
                            </div>
                        </GnsCard>
                    </GnsStack>
                </GnsGrid>
            </div>

            @* Card Grid *@
            <div>
                <p style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-1);">Card Grid</p>
                <p style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-bottom: var(--gns-space-3);">4-column grid of uniform cards — good for product listings or feature blocks.</p>
                <GnsGrid Columns="4" Gap="4">
                    @foreach (var item in _featureCards)
                    {
                        <GnsCard IsHoverable="true">
                            <div style="padding: var(--gns-space-4);">
                                <div style="@BoxStyle(item.Color, "2.5rem") margin-bottom: var(--gns-space-3); border-radius: var(--gns-radius-sm);">@item.Icon</div>
                                <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-1);">@item.Title</div>
                                <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); line-height: var(--gns-leading-relaxed);">@item.Description</div>
                            </div>
                        </GnsCard>
                    }
                </GnsGrid>
            </div>

            @* Form Layout *@
            <div>
                <p style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-1);">Form Layout</p>
                <p style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-bottom: var(--gns-space-3);">2-column grid for label/field pairs — labels on left, inputs on right.</p>
                <GnsCard>
                    <div style="padding: var(--gns-space-5);">
                        <GnsStack Direction="StackDirection.Vertical" Gap="4">
                            @foreach (var field in _formFields)
                            {
                                <GnsGrid Columns="2" Gap="4">
                                    <div style="display: flex; align-items: center; justify-content: flex-end; padding-right: var(--gns-space-2);">
                                        <span style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-medium); color: var(--gns-color-text-secondary);">@field.Label</span>
                                    </div>
                                    <div style="height: 2.5rem; border: 1px solid var(--gns-color-border-default); border-radius: var(--gns-radius-md); background: var(--gns-color-surface-raised); display: flex; align-items: center; padding: 0 var(--gns-space-3);">
                                        <span style="font-size: var(--gns-text-sm); color: var(--gns-color-text-tertiary);">@field.Placeholder</span>
                                    </div>
                                </GnsGrid>
                            }
                            <div style="display: flex; justify-content: flex-end; gap: var(--gns-space-2); padding-top: var(--gns-space-2);">
                                <GnsButton Label="Cancel" Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" />
                                <GnsButton Label="Save Changes" Variant="ButtonVariant.Primary" Size="ButtonSize.Small" />
                            </div>
                        </GnsStack>
                    </div>
                </GnsCard>
            </div>

            @* Sidebar Layout *@
            <div>
                <p style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-1);">Sidebar Layout</p>
                <p style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); margin-bottom: var(--gns-space-3);">Fixed nav on the left, scrollable content on the right.</p>
                <GnsGrid TemplateColumns="240px 1fr" Gap="4">
                    <GnsCard>
                        <div style="padding: var(--gns-space-3);">
                            <div style="font-size: var(--gns-text-xs); font-weight: var(--gns-font-weight-semibold); color: var(--gns-color-text-tertiary); text-transform: uppercase; letter-spacing: 0.05em; padding: var(--gns-space-2) var(--gns-space-3); margin-bottom: var(--gns-space-1);">Navigation</div>
                            @foreach (var navItem in _navItems)
                            {
                                <div style="padding: var(--gns-space-2) var(--gns-space-3); border-radius: var(--gns-radius-md); font-size: var(--gns-text-sm); cursor: pointer; @(navItem.Active ? "background: var(--gns-primary-50); color: var(--gns-primary-700); font-weight: var(--gns-font-weight-medium);" : "color: var(--gns-color-text-secondary);")">
                                    @navItem.Label
                                </div>
                            }
                        </div>
                    </GnsCard>
                    <GnsCard>
                        <div style="padding: var(--gns-space-5);">
                            <div style="font-size: var(--gns-text-lg); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-4);">General Settings</div>
                            <GnsStack Direction="StackDirection.Vertical" Gap="4">
                                <div style="height: 2rem; background: var(--gns-color-surface-subtle); border-radius: var(--gns-radius-md); width: 60%;"></div>
                                <div style="height: 2rem; background: var(--gns-color-surface-subtle); border-radius: var(--gns-radius-md); width: 80%;"></div>
                                <div style="height: 2rem; background: var(--gns-color-surface-subtle); border-radius: var(--gns-radius-md); width: 45%;"></div>
                                <div style="height: 2rem; background: var(--gns-color-surface-subtle); border-radius: var(--gns-radius-md); width: 70%;"></div>
                            </GnsStack>
                        </div>
                    </GnsCard>
                </GnsGrid>
            </div>

        </div>
    </GnsSection>

    @* ─────────────────────────────────────────────────────── *@
    @* Section 6 — Gap Scale                                   *@
    @* ─────────────────────────────────────────────────────── *@

    <GnsSection Title="Gap Scale" Subtitle="The same 4-column grid with different gap values. Shows the visual impact of spacing tokens.">

        <div style="display: flex; flex-direction: column; gap: var(--gns-space-8);">
            @foreach (var gap in _gapValues)
            {
                <div>
                    <p style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary); margin-bottom: var(--gns-space-2);">Gap=&quot;@gap&quot; — --gns-space-@gap</p>
                    <GnsGrid Columns="4" Gap="@gap">
                        <div style="@BoxStyle("var(--gns-primary-500)", "3.5rem")">A</div>
                        <div style="@BoxStyle("var(--gns-primary-400)", "3.5rem")">B</div>
                        <div style="@BoxStyle("var(--gns-primary-300)", "3.5rem")">C</div>
                        <div style="@BoxStyle("var(--gns-info-500)", "3.5rem")">D</div>
                    </GnsGrid>
                </div>
            }
        </div>
    </GnsSection>

</div>

@code {
    // ── Helpers ──────────────────────────────────────────────────────────────

    private static string BoxStyle(string color, string height = "4rem") =>
        $"background: {color}; border-radius: var(--gns-radius-md); height: {height}; display: flex; align-items: center; justify-content: center; color: white; font-weight: var(--gns-font-weight-semibold); font-size: var(--gns-text-sm);";

    // ── Data ─────────────────────────────────────────────────────────────────

    private static readonly string[] _gapValues = ["1", "2", "4", "6", "8"];

    private record FeatureCard(string Title, string Description, string Color, string Icon);

    private static readonly FeatureCard[] _featureCards =
