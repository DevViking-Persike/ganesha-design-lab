@page "/lab"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    @* Hero Section *@
    <GnsSection>
        <div style="text-align: center; padding: var(--gns-space-12) 0 var(--gns-space-8);">
            <h1 style="font-family: var(--gns-font-display); font-size: var(--gns-text-5xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary); margin-bottom: var(--gns-space-4); letter-spacing: var(--gns-tracking-wide);">
                <span style="color: var(--gns-ouro-500); font-size: 1.2em;">&#x0950;</span> Ganesha Design System
            </h1>
            <p style="font-size: var(--gns-text-xl); color: var(--gns-color-text-secondary); max-width: 60ch; margin: 0 auto var(--gns-space-8); line-height: var(--gns-leading-relaxed);">
                A spiritual, token-driven design system inspired by the Ganesha Supremo palette.
                Built with mystical tokens, accessible components, and divine patterns.
            </p>
            <div style="display: flex; gap: var(--gns-space-3); justify-content: center; flex-wrap: wrap;">
                <GnsButton Label="Browse Components" Variant="ButtonVariant.Primary" Size="ButtonSize.Large" />
                <GnsButton Label="View Tokens" Variant="ButtonVariant.Outline" Size="ButtonSize.Large" />
            </div>
        </div>
    </GnsSection>

    @* Foundations Section *@
    <GnsSection Title="Foundations" Subtitle="Design tokens and visual primitives that form the base of every component.">
        <GnsGrid Columns="4" Gap="4">
            <GnsCard IsHoverable="true">
                <Header><div style="padding: var(--gns-space-3) var(--gns-space-4); font-weight: var(--gns-font-weight-semibold); font-size: var(--gns-text-sm);">Colors</div></Header>
                <ChildContent>
                    <div style="display: flex; gap: var(--gns-space-1); padding: 0 var(--gns-space-1) var(--gns-space-1);">
                        <span style="flex:1; height: 2rem; background: var(--gns-primary-500); border-radius: var(--gns-radius-sm);"></span>
                        <span style="flex:1; height: 2rem; background: var(--gns-success-500); border-radius: var(--gns-radius-sm);"></span>
                        <span style="flex:1; height: 2rem; background: var(--gns-warning-500); border-radius: var(--gns-radius-sm);"></span>
                        <span style="flex:1; height: 2rem; background: var(--gns-danger-500); border-radius: var(--gns-radius-sm);"></span>
                    </div>
                    <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary); padding: var(--gns-space-2) var(--gns-space-4);">
                        Primitive and semantic color tokens for consistent theming.
                    </p>
                </ChildContent>
                <Footer><a href="lab/colors" style="font-size: var(--gns-text-sm); color: var(--gns-color-text-link); padding: var(--gns-space-3) var(--gns-space-4); display: block;">Explore Colors &rarr;</a></Footer>
            </GnsCard>

            <GnsCard IsHoverable="true">
                <Header><div style="padding: var(--gns-space-3) var(--gns-space-4); font-weight: var(--gns-font-weight-semibold); font-size: var(--gns-text-sm);">Typography</div></Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-2) var(--gns-space-4);">
                        <div style="font-size: var(--gns-text-2xl); font-weight: var(--gns-font-weight-bold); color: var(--gns-color-text-primary);">Aa</div>
                        <div style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">Inter - System UI</div>
                    </div>
                    <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary); padding: var(--gns-space-2) var(--gns-space-4);">
                        Type scale, weights, line heights, and tracking.
                    </p>
                </ChildContent>
                <Footer><a href="lab/typography" style="font-size: var(--gns-text-sm); color: var(--gns-color-text-link); padding: var(--gns-space-3) var(--gns-space-4); display: block;">Explore Typography &rarr;</a></Footer>
            </GnsCard>

            <GnsCard IsHoverable="true">
                <Header><div style="padding: var(--gns-space-3) var(--gns-space-4); font-weight: var(--gns-font-weight-semibold); font-size: var(--gns-text-sm);">Spacing</div></Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-2) var(--gns-space-4);">
                        <div style="display: flex; gap: var(--gns-space-1); align-items: flex-end;">
                            <span style="width: 4px; height: 8px; background: var(--gns-primary-400); border-radius: 1px;"></span>
                            <span style="width: 4px; height: 16px; background: var(--gns-primary-400); border-radius: 1px;"></span>
                            <span style="width: 4px; height: 24px; background: var(--gns-primary-500); border-radius: 1px;"></span>
                            <span style="width: 4px; height: 32px; background: var(--gns-primary-500); border-radius: 1px;"></span>
                            <span style="width: 4px; height: 40px; background: var(--gns-primary-600); border-radius: 1px;"></span>
                        </div>
                    </div>
                    <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary); padding: var(--gns-space-2) var(--gns-space-4);">
                        Consistent spacing scale from 0 to 96.
                    </p>
                </ChildContent>
                <Footer><a href="lab/spacing" style="font-size: var(--gns-text-sm); color: var(--gns-color-text-link); padding: var(--gns-space-3) var(--gns-space-4); display: block;">Explore Spacing &rarr;</a></Footer>
            </GnsCard>

            <GnsCard IsHoverable="true">
                <Header><div style="padding: var(--gns-space-3) var(--gns-space-4); font-weight: var(--gns-font-weight-semibold); font-size: var(--gns-text-sm);">Shadows</div></Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-4); display: flex; justify-content: center;">
                        <div style="width: 3rem; height: 3rem; background: var(--gns-color-surface-default); border-radius: var(--gns-radius-lg); box-shadow: var(--gns-shadow-lg);"></div>
                    </div>
                    <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary); padding: var(--gns-space-2) var(--gns-space-4);">
                        Elevation scale from subtle to dramatic.
                    </p>
                </ChildContent>
                <Footer><a href="lab/shadows" style="font-size: var(--gns-text-sm); color: var(--gns-color-text-link); padding: var(--gns-space-3) var(--gns-space-4); display: block;">Explore Shadows &rarr;</a></Footer>
            </GnsCard>
        </GnsGrid>
    </GnsSection>

    @* Components Section *@
    <GnsSection Title="Components" Subtitle="Reusable UI building blocks designed for accessibility and composability.">
        <GnsGrid Columns="3" Gap="4">
            @foreach (var item in _componentItems)
            {
                <GnsCard IsHoverable="true">
                    <div style="padding: var(--gns-space-4);">
                        <h3 style="font-size: var(--gns-text-base); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-2);">@item.Title</h3>
                        <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary); margin-bottom: var(--gns-space-3);">@item.Description</p>
                        <a href="@item.Href" style="font-size: var(--gns-text-sm); color: var(--gns-color-text-link);">View &rarr;</a>
                    </div>
                </GnsCard>
            }
        </GnsGrid>
    </GnsSection>

    @* Patterns Section *@
    <GnsSection Title="Patterns" Subtitle="Full-page compositions showing how components work together in real applications.">
        <GnsGrid Columns="3" Gap="4">
            @foreach (var item in _patternItems)
            {
                <GnsCard IsHoverable="true">
                    <div style="padding: var(--gns-space-4);">
                        <h3 style="font-size: var(--gns-text-base); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-2);">@item.Title</h3>
                        <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary); margin-bottom: var(--gns-space-3);">@item.Description</p>
                        <a href="@item.Href" style="font-size: var(--gns-text-sm); color: var(--gns-color-text-link);">View &rarr;</a>
                    </div>
                </GnsCard>
            }
        </GnsGrid>
    </GnsSection>

</div>

@code {
    private record NavItem(string Title, string Description, string Href);

    private static readonly NavItem[] _componentItems =
    [
        new("Buttons", "Primary, secondary, ghost, danger, and outline variants.", "/lab/buttons"),
        new("Forms", "Inputs, selects, checkboxes, radios, textareas, and switches.", "/lab/forms"),
        new("Data Display", "Badges, tags, avatars, stat cards, tables, and more.", "/lab/data-display"),
        new("Feedback", "Alerts, toasts, loaders, and empty states.", "/lab/feedback"),
        new("Navigation", "Tabs, breadcrumbs, pagination, and nav items.", "/lab/navigation"),
        new("Surfaces & Overlays", "Cards, panels, modals, and drawers.", "/lab/surfaces"),
    ];

    private static readonly NavItem[] _patternItems =
    [
        new("Dashboard", "Metrics, charts, tables, and notifications.", "/lab/dashboard"),
        new("Table Page", "Data table with search, filters, and pagination.", "/lab/table-page"),
        new("Form Page", "Registration and edit forms with validation.", "/lab/form-page"),
        new("Profile Page", "User profile with stats and activity feed.", "/lab/profile"),
        new("Auth Page", "Clean, modern login experience.", "/lab/auth"),
    ];
}
