@page "/lab/overlays"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <HlxPageHeader Title="Overlays"
                   Eyebrow="Components"
                   Description="Overlay components that appear above the main content: modals and drawers." />

    <HlxSection Title="Modal" Subtitle="Dialog windows for focused interactions. Available in multiple sizes.">
        <div class="gns-preview">
            <div class="gns-preview__canvas gns-preview__canvas--row">
                <HlxButton Label="Small Modal" Variant="ButtonVariant.Outline" OnClick="@(() => _showSmallModal = true)" />
                <HlxButton Label="Medium Modal" Variant="ButtonVariant.Primary" OnClick="@(() => _showMediumModal = true)" />
                <HlxButton Label="Large Modal" Variant="ButtonVariant.Secondary" OnClick="@(() => _showLargeModal = true)" />
            </div>
        </div>
    </HlxSection>

    <HlxModal IsOpen="@_showSmallModal" IsOpenChanged="@(v => _showSmallModal = v)" Title="Confirm Action" Size="sm">
        <ChildContent>
            <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">Are you sure you want to proceed with this action? This cannot be undone.</p>
        </ChildContent>
        <Footer>
            <div style="display: flex; gap: var(--gns-space-3); justify-content: flex-end; padding: var(--gns-space-2) 0;">
                <HlxButton Label="Cancel" Variant="ButtonVariant.Ghost" OnClick="@(() => _showSmallModal = false)" />
                <HlxButton Label="Confirm" Variant="ButtonVariant.Primary" OnClick="@(() => _showSmallModal = false)" />
            </div>
        </Footer>
    </HlxModal>

    <HlxModal IsOpen="@_showMediumModal" IsOpenChanged="@(v => _showMediumModal = v)" Title="Edit Profile" Size="md">
        <ChildContent>
            <div style="display: flex; flex-direction: column; gap: var(--gns-space-4);">
                <HlxInputText Label="Full Name" Placeholder="Enter name" @bind-Value="_modalName" />
                <HlxInputText Label="Email" Placeholder="email@example.com" @bind-Value="_modalEmail" />
                <HlxTextarea Label="Bio" Placeholder="Tell us about yourself" Rows="3" @bind-Value="_modalBio" />
            </div>
        </ChildContent>
        <Footer>
            <div style="display: flex; gap: var(--gns-space-3); justify-content: flex-end; padding: var(--gns-space-2) 0;">
                <HlxButton Label="Cancel" Variant="ButtonVariant.Ghost" OnClick="@(() => _showMediumModal = false)" />
                <HlxButton Label="Save Changes" Variant="ButtonVariant.Primary" OnClick="@(() => _showMediumModal = false)" />
            </div>
        </Footer>
    </HlxModal>

    <HlxModal IsOpen="@_showLargeModal" IsOpenChanged="@(v => _showLargeModal = v)" Title="Application Details" Size="lg">
        <ChildContent>
            <div style="display: flex; flex-direction: column; gap: var(--gns-space-4);">
                <HlxAlert Severity="AlertSeverity.Info">
                    Please review all information before submitting.
                </HlxAlert>
                <HlxGrid TemplateColumns="1fr 1fr" Gap="4">
                    <HlxInputText Label="First Name" Placeholder="John" @bind-Value="_lgFirst" />
                    <HlxInputText Label="Last Name" Placeholder="Doe" @bind-Value="_lgLast" />
                </HlxGrid>
                <HlxInputText Label="Email" Placeholder="john@example.com" @bind-Value="_lgEmail" />
                <HlxSelect Label="Department" Placeholder="Select..." @bind-Value="_lgDept">
                    <option value="eng">Engineering</option>
                    <option value="design">Design</option>
                    <option value="product">Product</option>
                    <option value="marketing">Marketing</option>
                </HlxSelect>
                <HlxTextarea Label="Cover Letter" Placeholder="Write a brief cover letter..." Rows="4" @bind-Value="_lgCover" />
            </div>
        </ChildContent>
        <Footer>
            <div style="display: flex; gap: var(--gns-space-3); justify-content: flex-end; padding: var(--gns-space-2) 0;">
                <HlxButton Label="Cancel" Variant="ButtonVariant.Ghost" OnClick="@(() => _showLargeModal = false)" />
                <HlxButton Label="Submit Application" Variant="ButtonVariant.Primary" OnClick="@(() => _showLargeModal = false)" />
            </div>
        </Footer>
    </HlxModal>

    <HlxSection Title="Drawer" Subtitle="Slide-in panels from the left or right edge of the viewport.">
        <div class="gns-preview">
            <div class="gns-preview__canvas gns-preview__canvas--row">
                <HlxButton Label="Open Left Drawer" Variant="ButtonVariant.Outline" OnClick="@(() => _showLeftDrawer = true)" />
                <HlxButton Label="Open Right Drawer" Variant="ButtonVariant.Primary" OnClick="@(() => _showRightDrawer = true)" />
            </div>
        </div>
    </HlxSection>

    <HlxDrawer IsOpen="@_showLeftDrawer" IsOpenChanged="@(v => _showLeftDrawer = v)" Title="Filters" Position="DrawerPosition.Left" Width="320px">
        <div style="display: flex; flex-direction: column; gap: var(--gns-space-4); padding: var(--gns-space-4);">
            <HlxInputText Label="Search" Placeholder="Filter by name..." @bind-Value="_drawerSearch" />
            <HlxSelect Label="Status" Placeholder="All statuses" @bind-Value="_drawerStatus">
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="pending">Pending</option>
            </HlxSelect>
            <HlxSelect Label="Category" Placeholder="All categories" @bind-Value="_drawerCategory">
                <option value="electronics">Electronics</option>
                <option value="clothing">Clothing</option>
                <option value="books">Books</option>
            </HlxSelect>
            <HlxCheckbox Label="In stock only" @bind-Value="_drawerInStock" />
            <div style="display: flex; gap: var(--gns-space-3); margin-top: var(--gns-space-4);">
                <HlxButton Label="Apply Filters" Variant="ButtonVariant.Primary" OnClick="@(() => _showLeftDrawer = false)" />
                <HlxButton Label="Reset" Variant="ButtonVariant.Ghost" />
            </div>
        </div>
    </HlxDrawer>

    <HlxDrawer IsOpen="@_showRightDrawer" IsOpenChanged="@(v => _showRightDrawer = v)" Title="Item Details" Position="DrawerPosition.Right" Width="400px">
        <div style="display: flex; flex-direction: column; gap: var(--gns-space-4); padding: var(--gns-space-4);">
            <div style="display: flex; align-items: center; gap: var(--gns-space-3);">
                <HlxAvatar Initials="WM" Size="AvatarSize.Large" />
                <div>
                    <div style="font-weight: var(--gns-font-weight-semibold);">Wireless Mouse</div>
                    <div style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">Electronics</div>
                </div>
            </div>
            <HlxAlert Severity="AlertSeverity.Success">Item is in stock with 142 units available.</HlxAlert>
            <div>
                <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-medium); margin-bottom: var(--gns-space-1);">Description</div>
                <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary); line-height: var(--gns-leading-relaxed);">
                    Ergonomic wireless mouse with precision tracking, USB-C charging, and multi-device Bluetooth connectivity. 
                    Designed for all-day comfort with a contoured grip and silent click buttons.
                </p>
            </div>
            <div style="display: flex; gap: var(--gns-space-6);">
                <div>
                    <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary);">Price</div>
                    <div style="font-size: var(--gns-text-lg); font-weight: var(--gns-font-weight-semibold);">$29.99</div>
                </div>
                <div>
                    <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary);">Stock</div>
                    <div style="font-size: var(--gns-text-lg); font-weight: var(--gns-font-weight-semibold);">142</div>
                </div>
            </div>
            <div style="display: flex; gap: var(--gns-space-3); margin-top: var(--gns-space-4);">
                <HlxButton Label="Edit Item" Variant="ButtonVariant.Primary" />
                <HlxButton Label="Delete" Variant="ButtonVariant.Danger" />
            </div>
        </div>
    </HlxDrawer>

</div>

@code {
    private bool _showSmallModal = false;
    private bool _showMediumModal = false;
    private bool _showLargeModal = false;
    private bool _showLeftDrawer = false;
    private bool _showRightDrawer = false;

    private string _modalName = "";
    private string _modalEmail = "";
    private string _modalBio = "";
    private string _lgFirst = "";
    private string _lgLast = "";
    private string _lgEmail = "";
    private string _lgDept = "";
    private string _lgCover = "";
    private string _drawerSearch = "";
    private string _drawerStatus = "";
    private string _drawerCategory = "";
    private bool _drawerInStock = false;
}
