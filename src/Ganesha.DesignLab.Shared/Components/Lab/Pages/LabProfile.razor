@page "/lab/profile"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <HlxPageHeader Title="User Profile" Eyebrow="Patterns" Description="User profile page with avatar, stats, activity feed, and settings.">
        <Breadcrumb>
            <HlxBreadcrumb>
                <HlxBreadcrumbItem Label="Dashboard" Href="/lab" />
                <HlxBreadcrumbItem Label="Users" Href="/lab/table-page" />
                <HlxBreadcrumbItem Label="Sarah Johnson" IsActive="true" />
            </HlxBreadcrumb>
        </Breadcrumb>
        <Actions>
            <HlxButton Label="Edit Profile" Variant="ButtonVariant.Primary" />
        </Actions>
    </HlxPageHeader>

    @* Profile Card *@
    <HlxSection>
        <HlxCard>
            <div style="padding: var(--gns-space-8); display: flex; gap: var(--gns-space-8); align-items: flex-start; flex-wrap: wrap;">
                <HlxAvatar Initials="SJ" Size="AvatarSize.XLarge" />
                <div style="flex: 1; min-width: 16rem;">
                    <h2 style="font-size: var(--gns-text-2xl); font-weight: var(--gns-font-weight-bold); margin-bottom: var(--gns-space-1);">Sarah Johnson</h2>
                    <p style="font-size: var(--gns-text-base); color: var(--gns-color-text-secondary); margin-bottom: var(--gns-space-2);">Lead Product Designer</p>
                    <div style="display: flex; gap: var(--gns-space-2); margin-bottom: var(--gns-space-4); flex-wrap: wrap;">
                        <HlxTag Label="Design" Variant="TagVariant.Primary" />
                        <HlxTag Label="UX Research" Variant="TagVariant.Info" />
                        <HlxTag Label="Figma" Variant="TagVariant.Default" />
                    </div>
                    <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary); line-height: var(--gns-leading-relaxed); max-width: 48ch;">
                        Passionate about creating intuitive and accessible user experiences. 
                        Over 8 years of experience in product design for SaaS applications.
                        Currently leading the design system team.
                    </p>
                </div>
            </div>
        </HlxCard>
    </HlxSection>

    @* Stats Row *@
    <HlxSection>
        <HlxGrid Columns="3" Gap="4">
            <HlxStatCard Title="Projects" Value="24" Description="12 active, 12 completed" />
            <HlxStatCard Title="Tasks" Value="186" Trend="+8" TrendDirection="TrendDirection.Up" Description="this month" />
            <HlxStatCard Title="Reviews" Value="47" Description="avg rating: 4.8/5" />
        </HlxGrid>
    </HlxSection>

    @* Activity Feed *@
    <HlxSection Title="Recent Activity" Subtitle="Latest actions and contributions.">
        <HlxCard>
            <div style="display: flex; flex-direction: column;">
                @foreach (var activity in _activities)
                {
                    <div style="display: flex; gap: var(--gns-space-4); padding: var(--gns-space-4); border-bottom: 1px solid var(--gns-color-border-subtle);">
                        <div style="width: 2rem; height: 2rem; border-radius: var(--gns-radius-full); background: var(--gns-color-bg-subtle); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <span style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary);">@activity.Icon</span>
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <div style="font-size: var(--gns-text-sm);">
                                <span style="font-weight: var(--gns-font-weight-medium);">@activity.Action</span>
                                <span style="color: var(--gns-color-text-secondary);"> @activity.Target</span>
                            </div>
                            <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary); margin-top: var(--gns-space-1);">@activity.Time</div>
                        </div>
                        @if (activity.Badge is not null)
                        {
                            <HlxBadge Severity="@activity.Badge.Value" Size="BadgeSize.Small">@activity.BadgeLabel</HlxBadge>
                        }
                    </div>
                }
            </div>
        </HlxCard>
    </HlxSection>

    @* Settings Panel *@
    <HlxSection Title="Settings" Subtitle="Profile preferences and notification settings.">
        <HlxPanel Title="Notification Preferences" IsCollapsible="true">
            <div style="display: flex; flex-direction: column; gap: var(--gns-space-4); padding: var(--gns-space-2) 0;">
                <HlxSwitch Label="Email notifications for project updates" @bind-Value="_emailNotif" />
                <HlxSwitch Label="Push notifications for mentions" @bind-Value="_pushNotif" />
                <HlxSwitch Label="Weekly digest summary" @bind-Value="_weeklyDigest" />
                <HlxSwitch Label="Marketing communications" @bind-Value="_marketing" />
            </div>
        </HlxPanel>
        <div style="margin-top: var(--gns-space-4);">
            <HlxPanel Title="Privacy" IsCollapsible="true" IsCollapsed="true">
                <div style="display: flex; flex-direction: column; gap: var(--gns-space-4); padding: var(--gns-space-2) 0;">
                    <HlxSwitch Label="Show profile to other users" @bind-Value="_profileVisible" />
                    <HlxSwitch Label="Show activity in team feed" @bind-Value="_activityVisible" />
                </div>
            </HlxPanel>
        </div>
    </HlxSection>

</div>

@code {
    private bool _emailNotif = true;
    private bool _pushNotif = true;
    private bool _weeklyDigest = false;
    private bool _marketing = false;
    private bool _profileVisible = true;
    private bool _activityVisible = true;

    private record ActivityItem(string Icon, string Action, string Target, string Time, BadgeSeverity? Badge = null, string? BadgeLabel = null);

    private static readonly ActivityItem[] _activities =
    [
        new("D", "Published design", "Component Library v2.0", "2 hours ago", BadgeSeverity.Success, "Published"),
        new("C", "Commented on", "Navigation redesign proposal", "4 hours ago"),
        new("R", "Reviewed", "Pull request #342 - Button updates", "6 hours ago", BadgeSeverity.Info, "Approved"),
        new("U", "Updated", "Design tokens color scale", "Yesterday at 3:15 PM"),
        new("A", "Assigned to", "Accessibility audit Q1 2026", "Yesterday at 11:00 AM", BadgeSeverity.Warning, "In Progress"),
        new("C", "Created", "User profile wireframes", "2 days ago"),
        new("M", "Mentioned in", "Sprint planning meeting notes", "3 days ago"),
    ];
}
