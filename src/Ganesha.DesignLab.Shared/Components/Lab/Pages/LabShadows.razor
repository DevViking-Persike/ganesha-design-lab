@page "/lab/shadows"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <GnsPageHeader Title="Shadows"
                   Eyebrow="Foundations"
                   Description="Elevation scale for creating depth and visual hierarchy." />

    <GnsSection Title="Elevation Scale" Subtitle="From subtle to dramatic shadow levels.">
        <div class="gns-shadow-scale">
            @foreach (var shadow in _shadows)
            {
                <div class="gns-shadow-sample">
                    <div class="gns-shadow-sample__box" style="box-shadow: var(--gns-shadow-@shadow.Token);"></div>
                    <div class="gns-shadow-sample__label">--gns-shadow-@shadow.Token</div>
                    <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary); text-align: center;">@shadow.Description</div>
                </div>
            }
        </div>
    </GnsSection>

    <GnsSection Title="Component Shadows" Subtitle="Semantic shadow tokens mapped to specific component roles.">
        <table class="gns-token-table">
            <thead>
                <tr><th>Token</th><th>Maps To</th><th>Usage</th></tr>
            </thead>
            <tbody>
                <tr><td class="gns-token-table__name">--gns-shadow-card</td><td class="gns-token-table__value">shadow-sm</td><td>Cards and panels</td></tr>
                <tr><td class="gns-token-table__name">--gns-shadow-card-hover</td><td class="gns-token-table__value">shadow-md</td><td>Card hover elevation</td></tr>
                <tr><td class="gns-token-table__name">--gns-shadow-dropdown</td><td class="gns-token-table__value">shadow-lg</td><td>Dropdown menus</td></tr>
                <tr><td class="gns-token-table__name">--gns-shadow-modal</td><td class="gns-token-table__value">shadow-2xl</td><td>Modals and dialogs</td></tr>
                <tr><td class="gns-token-table__name">--gns-shadow-button</td><td class="gns-token-table__value">shadow-xs</td><td>Button resting state</td></tr>
                <tr><td class="gns-token-table__name">--gns-shadow-input</td><td class="gns-token-table__value">shadow-inner</td><td>Input fields inset</td></tr>
            </tbody>
        </table>
    </GnsSection>

</div>

@code {
    private record ShadowItem(string Token, string Description);

    private static readonly ShadowItem[] _shadows =
    [
        new("none", "No shadow"),
        new("xs", "Focused inputs, active states"),
        new("sm", "Cards, slight lift"),
        new("md", "Floating elements, popovers"),
        new("lg", "Modals, drawers"),
        new("xl", "Elevated panels"),
        new("2xl", "Page-level overlays"),
        new("inner", "Recessed / inset elements"),
    ];
}
