@page "/lab/spacing"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <HlxPageHeader Title="Spacing"
                   Eyebrow="Foundations"
                   Description="A consistent spacing scale based on a 4px (0.25rem) base unit. Used for margins, paddings, and gaps." />

    <HlxSection Title="Spacing Scale" Subtitle="Core spacing tokens from 0 to 96.">
        <div class="gns-spacing-scale">
            @foreach (var item in _spacingTokens)
            {
                <div class="gns-spacing-scale__row">
                    <span class="gns-spacing-scale__label">--gns-space-@item.Name</span>
                    <div class="gns-spacing-scale__bar" style="width: @(item.Px)px; min-width: 2px;"></div>
                    <span class="gns-spacing-scale__value">@item.Rem &middot; @(item.Px)px</span>
                </div>
            }
        </div>
    </HlxSection>

    <HlxSection Title="Visual Reference" Subtitle="Boxes demonstrating spacing token sizes.">
        <div style="display: flex; flex-wrap: wrap; gap: var(--gns-space-4); align-items: flex-end;">
            @foreach (var item in _visualTokens)
            {
                <div style="display: flex; flex-direction: column; align-items: center; gap: var(--gns-space-2);">
                    <div style="width: var(--gns-space-@item.Name); height: var(--gns-space-@item.Name); min-width: 2px; min-height: 2px; background-color: var(--gns-primary-500); border-radius: var(--gns-radius-sm); opacity: 0.8;"></div>
                    <span style="font-size: var(--gns-text-xs); font-family: var(--gns-font-mono); color: var(--gns-color-text-tertiary);">@item.Name</span>
                </div>
            }
        </div>
    </HlxSection>

</div>

@code {
    private record SpacingToken(string Name, string Rem, int Px);

    private static readonly SpacingToken[] _spacingTokens =
    [
        new("0", "0rem", 0),
        new("px", "0.0625rem", 1),
        new("0-5", "0.125rem", 2),
        new("1", "0.25rem", 4),
        new("1-5", "0.375rem", 6),
        new("2", "0.5rem", 8),
        new("2-5", "0.625rem", 10),
        new("3", "0.75rem", 12),
        new("3-5", "0.875rem", 14),
        new("4", "1rem", 16),
        new("5", "1.25rem", 20),
        new("6", "1.5rem", 24),
        new("7", "1.75rem", 28),
        new("8", "2rem", 32),
        new("9", "2.25rem", 36),
        new("10", "2.5rem", 40),
        new("11", "2.75rem", 44),
        new("12", "3rem", 48),
        new("14", "3.5rem", 56),
        new("16", "4rem", 64),
        new("20", "5rem", 80),
        new("24", "6rem", 96),
    ];

    private static readonly SpacingToken[] _visualTokens =
    [
        new("1", "0.25rem", 4),
        new("2", "0.5rem", 8),
        new("3", "0.75rem", 12),
        new("4", "1rem", 16),
        new("5", "1.25rem", 20),
        new("6", "1.5rem", 24),
        new("8", "2rem", 32),
        new("10", "2.5rem", 40),
        new("12", "3rem", 48),
        new("16", "4rem", 64),
    ];
}
