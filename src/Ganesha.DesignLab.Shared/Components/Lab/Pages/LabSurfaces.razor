@page "/lab/surfaces"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <HlxPageHeader Title="Surfaces"
                   Eyebrow="Components"
                   Description="Container components for grouping and structuring content: cards and panels." />

    <HlxSection Title="Card" Subtitle="Flexible container with optional header and footer.">
        <HlxGrid Columns="3" Gap="4">
            <HlxCard>
                <div style="padding: var(--gns-space-4);">
                    <h3 style="font-size: var(--gns-text-base); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-2);">Default Card</h3>
                    <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">A simple card with body content only. No header or footer.</p>
                </div>
            </HlxCard>

            <HlxCard IsHoverable="true">
                <div style="padding: var(--gns-space-4);">
                    <h3 style="font-size: var(--gns-text-base); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-2);">Hoverable Card</h3>
                    <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">This card elevates on hover. Good for clickable items.</p>
                </div>
            </HlxCard>

            <HlxCard IsCompact="true">
                <div style="padding: var(--gns-space-3);">
                    <h3 style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-semibold); margin-bottom: var(--gns-space-1);">Compact Card</h3>
                    <p style="font-size: var(--gns-text-xs); color: var(--gns-color-text-secondary);">Less padding for dense layouts.</p>
                </div>
            </HlxCard>
        </HlxGrid>
    </HlxSection>

    <HlxSection Title="Card with Header & Footer" Subtitle="Full card anatomy with all slots populated.">
        <HlxGrid Columns="2" Gap="4">
            <HlxCard>
                <Header>
                    <div style="padding: var(--gns-space-4); display: flex; align-items: center; justify-content: space-between;">
                        <span style="font-weight: var(--gns-font-weight-semibold);">Project Details</span>
                        <HlxBadge Severity="BadgeSeverity.Success" Size="BadgeSize.Small">Active</HlxBadge>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-4);">
                        <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary); line-height: var(--gns-leading-relaxed);">
                            This project is currently in active development. The team is working on the design system components and documentation.
                        </p>
                    </div>
                </ChildContent>
                <Footer>
                    <div style="padding: var(--gns-space-3) var(--gns-space-4); display: flex; gap: var(--gns-space-2); justify-content: flex-end;">
                        <HlxButton Label="Cancel" Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" />
                        <HlxButton Label="Save" Variant="ButtonVariant.Primary" Size="ButtonSize.Small" />
                    </div>
                </Footer>
            </HlxCard>

            <HlxCard>
                <Header>
                    <div style="padding: var(--gns-space-4);">
                        <span style="font-weight: var(--gns-font-weight-semibold);">Team Members</span>
                    </div>
                </Header>
                <ChildContent>
                    <div style="padding: var(--gns-space-4); display: flex; flex-direction: column; gap: var(--gns-space-3);">
                        <div style="display: flex; align-items: center; gap: var(--gns-space-3);">
                            <HlxAvatar Initials="JD" Size="AvatarSize.Small" />
                            <div>
                                <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-medium);">Jane Doe</div>
                                <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary);">Lead Designer</div>
                            </div>
                        </div>
                        <div style="display: flex; align-items: center; gap: var(--gns-space-3);">
                            <HlxAvatar Initials="MS" Size="AvatarSize.Small" />
                            <div>
                                <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-medium);">Mike Smith</div>
                                <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary);">Senior Developer</div>
                            </div>
                        </div>
                        <div style="display: flex; align-items: center; gap: var(--gns-space-3);">
                            <HlxAvatar Initials="AL" Size="AvatarSize.Small" />
                            <div>
                                <div style="font-size: var(--gns-text-sm); font-weight: var(--gns-font-weight-medium);">Anna Lee</div>
                                <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary);">Product Manager</div>
                            </div>
                        </div>
                    </div>
                </ChildContent>
                <Footer>
                    <div style="padding: var(--gns-space-3) var(--gns-space-4);">
                        <a href="/lab/profile" style="font-size: var(--gns-text-sm); color: var(--gns-color-text-link);">View all members &rarr;</a>
                    </div>
                </Footer>
            </HlxCard>
        </HlxGrid>
    </HlxSection>

    <HlxSection Title="Panel" Subtitle="Collapsible content container with title and optional actions.">
        <div style="display: flex; flex-direction: column; gap: var(--gns-space-4); max-width: 40rem;">
            <HlxPanel Title="Default Panel">
                <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">This is a standard panel with a title and content area. Panels are useful for organizing related content.</p>
            </HlxPanel>

            <HlxPanel Title="Collapsible Panel" IsCollapsible="true">
                <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">This panel can be collapsed by clicking the toggle. Try it out! The content smoothly hides and shows.</p>
            </HlxPanel>

            <HlxPanel Title="Panel with Actions" IsCollapsible="true">
                <Actions>
                    <HlxButton Label="Edit" Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" />
                </Actions>
                <ChildContent>
                    <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">This collapsible panel also has action buttons in the header area for quick access to related operations.</p>
                </ChildContent>
            </HlxPanel>

            <HlxPanel Title="Initially Collapsed" IsCollapsible="true" IsCollapsed="true">
                <p style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">This panel starts in a collapsed state. Click to expand and see the content.</p>
            </HlxPanel>
        </div>
    </HlxSection>

</div>
