@page "/lab/table-page"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <GnsPageHeader Title="Users" Eyebrow="Patterns" Description="Full data table page with search, filters, and pagination.">
        <Actions>
            <GnsButton Label="Add User" Variant="ButtonVariant.Primary" />
        </Actions>
    </GnsPageHeader>

    @* Search and Filters *@
    <GnsSection>
        <div style="display: flex; gap: var(--gns-space-4); align-items: flex-end; flex-wrap: wrap; margin-bottom: var(--gns-space-4);">
            <div style="flex: 1; min-width: 16rem;">
                <GnsInputText Placeholder="Search users by name or email..." @bind-Value="_search" />
            </div>
            <div style="min-width: 10rem;">
                <GnsSelect Placeholder="All Statuses" @bind-Value="_statusFilter">
                    <option value="">All Statuses</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                    <option value="pending">Pending</option>
                </GnsSelect>
            </div>
            <div style="min-width: 10rem;">
                <GnsSelect Placeholder="All Roles" @bind-Value="_roleFilter">
                    <option value="">All Roles</option>
                    <option value="admin">Admin</option>
                    <option value="editor">Editor</option>
                    <option value="viewer">Viewer</option>
                </GnsSelect>
            </div>
        </div>

        <GnsTable TItem="UserRecord" Items="_filteredUsers" IsStriped="true" IsHoverable="true">
            <HeaderTemplate>
                <th class="gns-table__head-cell">Name</th>
                <th class="gns-table__head-cell">Email</th>
                <th class="gns-table__head-cell">Role</th>
                <th class="gns-table__head-cell">Status</th>
                <th class="gns-table__head-cell" style="text-align: right;">Actions</th>
            </HeaderTemplate>
            <RowTemplate Context="user">
                <tr class="gns-table__body-row">
                    <td class="gns-table__body-cell">
                        <div style="display: flex; align-items: center; gap: var(--gns-space-3);">
                            <GnsAvatar Initials="@user.Initials" Size="AvatarSize.Small" />
                            <div>
                                <div style="font-weight: var(--gns-font-weight-medium);">@user.Name</div>
                                <div style="font-size: var(--gns-text-xs); color: var(--gns-color-text-tertiary);">Joined @user.JoinDate</div>
                            </div>
                        </div>
                    </td>
                    <td class="gns-table__body-cell" style="color: var(--gns-color-text-secondary);">@user.Email</td>
                    <td class="gns-table__body-cell">
                        <GnsTag Label="@user.Role" Variant="@user.RoleVariant" />
                    </td>
                    <td class="gns-table__body-cell">
                        <GnsBadge Severity="@user.StatusSeverity" Size="BadgeSize.Small">@user.Status</GnsBadge>
                    </td>
                    <td class="gns-table__body-cell" style="text-align: right;">
                        <div style="display: flex; gap: var(--gns-space-1); justify-content: flex-end;">
                            <GnsButton Label="Edit" Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" />
                            <GnsButton Label="Delete" Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" />
                        </div>
                    </td>
                </tr>
            </RowTemplate>
        </GnsTable>

        <div style="display: flex; align-items: center; justify-content: space-between; margin-top: var(--gns-space-4); flex-wrap: wrap; gap: var(--gns-space-3);">
            <span style="font-size: var(--gns-text-sm); color: var(--gns-color-text-secondary);">Showing @_filteredUsers.Count of @_allUsers.Count users</span>
            <GnsPagination CurrentPage="@_currentPage" TotalPages="5" CurrentPageChanged="@(p => _currentPage = p)" />
        </div>
    </GnsSection>

</div>

@code {
    private string _search = "";
    private string _statusFilter = "";
    private string _roleFilter = "";
    private int _currentPage = 1;

    private record UserRecord(string Name, string Initials, string Email, string Role, TagVariant RoleVariant, string Status, BadgeSeverity StatusSeverity, string JoinDate);

    private static readonly IReadOnlyList<UserRecord> _allUsers =
    [
        new("Alice Thompson", "AT", "alice@example.com", "Admin", TagVariant.Primary, "Active", BadgeSeverity.Success, "Jan 2024"),
        new("Bob Martinez", "BM", "bob@example.com", "Editor", TagVariant.Info, "Active", BadgeSeverity.Success, "Feb 2024"),
        new("Carol White", "CW", "carol@example.com", "Viewer", TagVariant.Default, "Inactive", BadgeSeverity.Danger, "Mar 2024"),
        new("David Lee", "DL", "david@example.com", "Admin", TagVariant.Primary, "Active", BadgeSeverity.Success, "Apr 2024"),
        new("Emma Johnson", "EJ", "emma@example.com", "Editor", TagVariant.Info, "Pending", BadgeSeverity.Warning, "May 2024"),
        new("Frank Garcia", "FG", "frank@example.com", "Viewer", TagVariant.Default, "Active", BadgeSeverity.Success, "Jun 2024"),
        new("Grace Kim", "GK", "grace@example.com", "Editor", TagVariant.Info, "Active", BadgeSeverity.Success, "Jul 2024"),
        new("Henry Chen", "HC", "henry@example.com", "Admin", TagVariant.Primary, "Inactive", BadgeSeverity.Danger, "Aug 2024"),
        new("Ivy Wilson", "IW", "ivy@example.com", "Viewer", TagVariant.Default, "Active", BadgeSeverity.Success, "Sep 2024"),
        new("Jack Brown", "JB", "jack@example.com", "Editor", TagVariant.Info, "Pending", BadgeSeverity.Warning, "Oct 2024"),
        new("Karen Davis", "KD", "karen@example.com", "Viewer", TagVariant.Default, "Active", BadgeSeverity.Success, "Nov 2024"),
        new("Leo Taylor", "LT", "leo@example.com", "Admin", TagVariant.Primary, "Active", BadgeSeverity.Success, "Dec 2024"),
    ];

    private IReadOnlyList<UserRecord> _filteredUsers => _allUsers
        .Where(u => string.IsNullOrEmpty(_search) || u.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) || u.Email.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(u => string.IsNullOrEmpty(_statusFilter) || u.Status.Equals(_statusFilter, StringComparison.OrdinalIgnoreCase))
        .Where(u => string.IsNullOrEmpty(_roleFilter) || u.Role.Equals(_roleFilter, StringComparison.OrdinalIgnoreCase))
        .ToList()
        .AsReadOnly();
}
