@page "/lab/typography"
@namespace Ganesha.DesignLab.Shared.Components.Lab.Pages
@layout Ganesha.DesignLab.Shared.Components.Lab.Layout.LabLayout

<div class="gns-lab-page">

    <GnsPageHeader Title="Typography"
                   Eyebrow="Foundations"
                   Description="Type scale, font weights, line heights, and tracking values for consistent text styling." />

    @* Heading Scale *@
    <GnsSection Title="Heading Scale" Subtitle="Six heading levels from H1 to H6.">
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta">
                <span class="gns-type-sample__label">H1</span>
                <span class="gns-type-sample__specs">2.25rem / 36px &middot; Bold &middot; 1.25</span>
            </div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-type-h1-size); font-weight: var(--gns-type-h1-weight); line-height: var(--gns-type-h1-leading);">
                The quick brown fox jumps over the lazy dog
            </div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta">
                <span class="gns-type-sample__label">H2</span>
                <span class="gns-type-sample__specs">1.875rem / 30px &middot; Semibold &middot; 1.25</span>
            </div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-type-h2-size); font-weight: var(--gns-type-h2-weight); line-height: var(--gns-type-h2-leading);">
                The quick brown fox jumps over the lazy dog
            </div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta">
                <span class="gns-type-sample__label">H3</span>
                <span class="gns-type-sample__specs">1.5rem / 24px &middot; Semibold &middot; 1.375</span>
            </div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-type-h3-size); font-weight: var(--gns-type-h3-weight); line-height: var(--gns-type-h3-leading);">
                The quick brown fox jumps over the lazy dog
            </div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta">
                <span class="gns-type-sample__label">H4</span>
                <span class="gns-type-sample__specs">1.25rem / 20px &middot; Semibold &middot; 1.375</span>
            </div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-type-h4-size); font-weight: var(--gns-type-h4-weight); line-height: var(--gns-type-h4-leading);">
                The quick brown fox jumps over the lazy dog
            </div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta">
                <span class="gns-type-sample__label">H5</span>
                <span class="gns-type-sample__specs">1.125rem / 18px &middot; Semibold &middot; 1.375</span>
            </div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-type-h5-size); font-weight: var(--gns-type-h5-weight); line-height: var(--gns-type-h5-leading);">
                The quick brown fox jumps over the lazy dog
            </div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta">
                <span class="gns-type-sample__label">H6</span>
                <span class="gns-type-sample__specs">1rem / 16px &middot; Semibold &middot; 1.5</span>
            </div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-type-h6-size); font-weight: var(--gns-type-h6-weight); line-height: var(--gns-type-h6-leading);">
                The quick brown fox jumps over the lazy dog
            </div>
        </div>
    </GnsSection>

    @* Body Text *@
    <GnsSection Title="Body Text" Subtitle="Body text at three sizes.">
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta">
                <span class="gns-type-sample__label">Body Large</span>
                <span class="gns-type-sample__specs">1.125rem / 18px &middot; Regular &middot; 1.625</span>
            </div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-type-body-lg-size); font-weight: var(--gns-type-body-lg-weight); line-height: var(--gns-type-body-lg-leading);">
                Design tokens are the visual design atoms of the system. They store values such as colors, typography, spacing, and more, allowing teams to maintain consistency across products and platforms.
            </div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta">
                <span class="gns-type-sample__label">Body</span>
                <span class="gns-type-sample__specs">1rem / 16px &middot; Regular &middot; 1.5</span>
            </div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-type-body-size); font-weight: var(--gns-type-body-weight); line-height: var(--gns-type-body-leading);">
                Design tokens are the visual design atoms of the system. They store values such as colors, typography, spacing, and more, allowing teams to maintain consistency across products and platforms.
            </div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta">
                <span class="gns-type-sample__label">Body Small</span>
                <span class="gns-type-sample__specs">0.875rem / 14px &middot; Regular &middot; 1.5</span>
            </div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-type-body-sm-size); font-weight: var(--gns-type-body-sm-weight); line-height: var(--gns-type-body-sm-leading);">
                Design tokens are the visual design atoms of the system. They store values such as colors, typography, spacing, and more, allowing teams to maintain consistency across products and platforms.
            </div>
        </div>
    </GnsSection>

    @* Font Weights *@
    <GnsSection Title="Font Weights" Subtitle="Available weight variations.">
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta"><span class="gns-type-sample__label">Regular 400</span></div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-text-xl); font-weight: var(--gns-font-weight-regular);">The quick brown fox jumps over the lazy dog</div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta"><span class="gns-type-sample__label">Medium 500</span></div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-text-xl); font-weight: var(--gns-font-weight-medium);">The quick brown fox jumps over the lazy dog</div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta"><span class="gns-type-sample__label">Semibold 600</span></div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-text-xl); font-weight: var(--gns-font-weight-semibold);">The quick brown fox jumps over the lazy dog</div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta"><span class="gns-type-sample__label">Bold 700</span></div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-text-xl); font-weight: var(--gns-font-weight-bold);">The quick brown fox jumps over the lazy dog</div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta"><span class="gns-type-sample__label">Extrabold 800</span></div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-text-xl); font-weight: var(--gns-font-weight-extrabold);">The quick brown fox jumps over the lazy dog</div>
        </div>
    </GnsSection>

    @* Font Size Scale *@
    <GnsSection Title="Font Size Scale" Subtitle="All available font sizes from xs to 6xl.">
        <table class="gns-type-scale-table">
            <thead><tr><th>Token</th><th>Size</th><th>Sample</th></tr></thead>
            <tbody>
                <tr><td>--gns-text-xs</td><td>0.75rem / 12px</td><td style="font-size: var(--gns-text-xs);">The quick brown fox</td></tr>
                <tr><td>--gns-text-sm</td><td>0.875rem / 14px</td><td style="font-size: var(--gns-text-sm);">The quick brown fox</td></tr>
                <tr><td>--gns-text-base</td><td>1rem / 16px</td><td style="font-size: var(--gns-text-base);">The quick brown fox</td></tr>
                <tr><td>--gns-text-lg</td><td>1.125rem / 18px</td><td style="font-size: var(--gns-text-lg);">The quick brown fox</td></tr>
                <tr><td>--gns-text-xl</td><td>1.25rem / 20px</td><td style="font-size: var(--gns-text-xl);">The quick brown fox</td></tr>
                <tr><td>--gns-text-2xl</td><td>1.5rem / 24px</td><td style="font-size: var(--gns-text-2xl);">The quick brown fox</td></tr>
                <tr><td>--gns-text-3xl</td><td>1.875rem / 30px</td><td style="font-size: var(--gns-text-3xl);">The quick brown fox</td></tr>
                <tr><td>--gns-text-4xl</td><td>2.25rem / 36px</td><td style="font-size: var(--gns-text-4xl);">The quick brown fox</td></tr>
                <tr><td>--gns-text-5xl</td><td>3rem / 48px</td><td style="font-size: var(--gns-text-5xl);">The quick brown fox</td></tr>
                <tr><td>--gns-text-6xl</td><td>3.75rem / 60px</td><td style="font-size: var(--gns-text-6xl);">The quick brown fox</td></tr>
            </tbody>
        </table>
    </GnsSection>

    @* Code / Mono *@
    <GnsSection Title="Code / Monospace" Subtitle="Monospace font for code, data, and identifiers.">
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta"><span class="gns-type-sample__label">Code Block</span></div>
            <div class="gns-type-sample__text" style="font-family: var(--gns-font-mono); font-size: var(--gns-text-sm); background: var(--gns-color-bg-subtle); padding: var(--gns-space-4); border-radius: var(--gns-radius-lg); border: 1px solid var(--gns-color-border-default);">
                <div>const theme = useTheme();</div>
                <div>const primary = theme.colors.primary[600];</div>
                <div>console.log("Current: " + primary);</div>
            </div>
        </div>
        <div class="gns-type-sample">
            <div class="gns-type-sample__meta"><span class="gns-type-sample__label">Inline Code</span></div>
            <div class="gns-type-sample__text" style="font-size: var(--gns-text-base);">
                Use the <code style="font-family: var(--gns-font-mono); font-size: 0.9em; background: var(--gns-color-bg-subtle); padding: 0.1em 0.4em; border-radius: var(--gns-radius-sm); border: 1px solid var(--gns-color-border-default);">--gns-primary-600</code> token for primary actions.
            </div>
        </div>
    </GnsSection>

</div>
