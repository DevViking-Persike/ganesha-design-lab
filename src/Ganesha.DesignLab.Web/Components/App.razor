@inject IConfiguration Configuration
@{
    var configuredPathBase = Configuration["PathBase"]?.Trim().Trim('/');
    var baseHref = string.IsNullOrWhiteSpace(configuredPathBase)
        ? "/"
        : $"/{configuredPathBase}/";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@baseHref" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Yatra+One&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="_content/Ganesha.DesignLab.Shared/css/ganesha.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Ganesha.DesignLab.Web.styles.css"]" />
    <link rel="stylesheet" href="_content/Ganesha.DesignLab.Shared/Ganesha.DesignLab.Shared.bundle.scp.css" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="_content/Ganesha.DesignLab.Shared/js/ganesha-charts.js"></script>
</body>

</html>
